# ============================================
# Function: Get-RelativeLuminance
# ============================================
function Get-RelativeLuminance {
    <#
    .SYNOPSIS
        Calculates the relative luminance of a color according to WCAG 2.1 standards.
    
    .PARAMETER Color
        A System.Drawing.Color object representing the color to analyze.
    
    .OUTPUTS
        A float representing the relative luminance value (0.0 to 1.0).
    #>
    param(
        [Parameter(Mandatory = $true)]
        [System.Drawing.Color]$Color
    )
    
    # Validate input
    if (-not $Color) {
        throw [System.ArgumentNullException]::new("Color parameter cannot be null")
    }
    
    # Convert RGB to linear RGB with gamma correction
    $r = $Color.R / 255.0
    $g = $Color.G / 255.0
    $b = $Color.B / 255.0
    
    # Apply gamma correction for sRGB
    $r = if ($r -le 0.03928) { $r / 12.92 } else { [Math]::Pow(($r + 0.055) / 1.055, 2.4) }
    $g = if ($g -le 0.03928) { $g / 12.92 } else { [Math]::Pow(($g + 0.055) / 1.055, 2.4) }
    $b = if ($b -le 0.03928) { $b / 12.92 } else { [Math]::Pow(($b + 0.055) / 1.055, 2.4) }
    
    # Calculate relative luminance
    return (0.2126 * $r + 0.7152 * $g + 0.0722 * $b)
}

# ============================================
# Function: Ensure-HighContrastColor
# ============================================
function Ensure-HighContrastColor {
    <#
    .SYNOPSIS
        Ensures a color has sufficient contrast against a background using WCAG 2.1 standards.
    
    .PARAMETER BackgroundColor
        The background color to compare against.
    
    .PARAMETER CandidateColor
        The candidate color to evaluate for contrast.
    
    .PARAMETER ContrastRatio
        Optional minimum contrast ratio threshold (default: 4.5 for AA compliance).
    
    .OUTPUTS
        A System.Drawing.Color object with sufficient contrast, or the original candidate color if it meets requirements.
    #>
    param(
        [Parameter(Mandatory = $true)]
        [System.Drawing.Color]$BackgroundColor,
        
        [Parameter(Mandatory = $true)]
        [System.Drawing.Color]$CandidateColor,
        
        [Parameter()]
        [double]$ContrastRatio = $script:MIN_CONTRAST_RATIO
    )
    
    # Validate inputs
    if (-not $BackgroundColor) {
        throw [System.ArgumentNullException]::new("BackgroundColor cannot be null")
    }
    if (-not $CandidateColor) {
        throw [System.ArgumentNullException]::new("CandidateColor cannot be null")
    }
    
    # Calculate luminance values
    $backLum = ((0.299 * $BackgroundColor.R) + (0.587 * $BackgroundColor.G) + (0.114 * $BackgroundColor.B)) / 255.0
    $candidateLum = ((0.299 * $CandidateColor.R) + (0.587 * $CandidateColor.G) + (0.114 * $CandidateColor.B)) / 255.0
    
    # Calculate contrast ratio using max and min values
    $max = [math]::Max($backLum, $candidateLum)
    $min = [math]::Min($backLum, $candidateLum)
    $contrastRatio = ($max + 0.05) / ($min + 0.05)
    
    # Return appropriate color based on contrast
    if ($contrastRatio -lt $ContrastRatio) {
        if ($backLum -gt 0.5) {
            return [System.Drawing.Color]::FromArgb(20, 20, 20)  # Dark text on light background
        }
        return [System.Drawing.Color]::FromArgb(240, 240, 240)  # Light text on dark background
    }
    
    return $CandidateColor
}

