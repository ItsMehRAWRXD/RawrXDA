function Get-VideoMetadata {
    <#
    .SYNOPSIS
        Gets metadata for a video stream

    .PARAMETER StreamId
        Video stream identifier

    .EXAMPLE
        $metadata = Get-VideoMetadata -StreamId "youtube-video"
    #>
    param([string]$StreamId)

    $stream = Get-VideoStream -Id $StreamId
    if ($stream) {
        return $stream.GetMetadata()
    }
    return $null
}

function Get-VideoStreams {
    <#
    .SYNOPSIS
        Gets all active video streams

    .EXAMPLE
        $streams = Get-VideoStreams
    #>
    return $script:VideoStreams.Keys
}

function Stop-AllVideos {
    <#
    .SYNOPSIS
        Stops all playing videos

    .EXAMPLE
        Stop-AllVideos
    #>
    foreach ($stream in $script:VideoStreams.Values) {
        if ($stream.IsPlaying) {
            $stream.Stop()
        }
    }
    Write-DevConsole "⏹️ Stopped all video streams" "SUCCESS"
}

function Get-VideoCapabilities {
    <#
    .SYNOPSIS
        Gets video system capabilities

    .EXAMPLE
        $caps = Get-VideoCapabilities
    #>
    $capabilities = @{
        WPFMediaAvailable = $script:WPFMediaAvailable
        ActiveStreams = $script:VideoStreams.Count
        SupportedFormats = @("MP4", "WebM", "AVI", "MKV", "MOV", "YouTube", "Vimeo", "HLS", "DASH")
        Features = @(
            "Local file playback",
            "URL streaming",
            "Volume control",
            "Position seeking",
            "Playlist support",
            "Format detection"
        )
    }

    return $capabilities
}

function Initialize-VideoModule {
    <#
    .SYNOPSIS
        Initializes the video streaming module

    .EXAMPLE
        Initialize-VideoModule
    #>
    Write-DevConsole "🎬 Initializing RawrXD Video Streaming Module..." "INFO"
    Write-DevConsole "WPF Media Available: $($script:WPFMediaAvailable)" "INFO"
    Write-DevConsole "Supported Formats: MP4, WebM, AVI, MKV, MOV, YouTube, Vimeo, HLS, DASH" "INFO"
    Write-DevConsole "✅ Video streaming module ready" "SUCCESS"
}

# Initialize on module load
Initialize-VideoModule
