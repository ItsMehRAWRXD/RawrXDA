# Import necessary assemblies
Add-Type -AssemblyName System.Windows.Forms

# Define constants for GUI elements
$gitStatusBox = New-Object System.Windows.Forms.Textbox
$gitStatusBox.Multiline = $true
$gitStatusBox.ReadOnly = $true

# Module variables
$script:ModuleName = 'RawrXD.Git'
$script:ModuleVersion = '1.0.0'

# Function definitions

# ============================================
# Function: Update-GitStatus
# ============================================
function Update-GitStatus {
    # Get the current Git status using a custom function (not shown in this code snippet)
    $gitStatus = Get-GitStatus
    
    # Clear and update the GUI text box with the new Git status
    $gitStatusBox.Clear()
    $gitStatusBox.AppendText($gitStatus)
}

# Function: Show-GitStatusDialogue
# ============================================
function Show-GitStatusDialogue {
    # Create a new form to display the Git status dialogue
    $form = New-Object System.Windows.Forms.Form
    $form.Text = 'Git Status'
    
    # Add the text box for displaying the Git status
    $form.Controls.Add($gitStatusBox)
    
    # Display the form as a modal dialog
    [System.Windows.Forms.MessageBox]::Show($form)
}

# Export functions
$ExportedFunctions = @(
    'Update-GitStatus'
    'Show-GitStatusDialogue'
)

Export-ModuleMember -Function $ExportedFunctions
