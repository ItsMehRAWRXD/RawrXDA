Session Key: Yes (unique per session)
"@
            
                Write-SecurityLog "Encryption test completed" "SUCCESS" "Duration: $([math]::Round($encryptTime + $decryptTime, 2))ms"
            }
            catch {
                $infoBox.Text = "Full test failed: $($_.Exception.Message)"
            }
        })
    
    $testForm.ShowDialog()
