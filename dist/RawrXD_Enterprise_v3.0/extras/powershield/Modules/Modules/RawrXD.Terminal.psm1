            # Apply saved customization settings
            if ($layoutData.Theme) { Apply-Theme $layoutData.Theme }
            if ($layoutData.FontSize) { Apply-FontSize $layoutData.FontSize }
            if ($layoutData.UIScale) { Apply-UIScaling $layoutData.UIScale }
            
