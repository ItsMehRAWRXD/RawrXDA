    global _start

_start:
    ; Write message
    mov rax, 1
    mov rdi, 1
    mov rsi, msg
    mov rdx, len
    syscall

    ; Exit
    mov rax, 60
    mov rdi, 0
    syscall
"@
            $files["build.sh"] = @"
#!/bin/bash
# Build script for Linux x86-64
nasm -f elf64 main.asm -o main.o
ld main.o -o main
./main
"@
            $files["build.bat"] = @"
