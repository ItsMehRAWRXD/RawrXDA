            $openDialog = New-Object System.Windows.Forms.OpenFileDialog
            $openDialog.Filter = "All Files (*.*)|*.*|Text Files (*.txt)|*.txt|PowerShell (*.ps1)|*.ps1|Markdown (*.md)|*.md"
            $openDialog.Title = "Open File"
            
