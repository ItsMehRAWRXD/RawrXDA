; Minimal Windows 64-bit definitions for CODEX REVERSE ENGINE

; Calling conventions
OPTION WIN64:3
OPTION CASEMAP:NONE

; Basic Windows types
LPSTR typedef PTR BYTE
LPCSTR typedef PTR BYTE
LPWSTR typedef PTR WORD
LPCWSTR typedef PTR WORD
HANDLE typedef QWORD
HWND typedef HANDLE
HINSTANCE typedef HANDLE
HMODULE typedef HANDLE
HFILE typedef QWORD
BOOL typedef DWORD
BYTE typedef UCHAR
WORD typedef USHORT
DWORD typedef ULONG
QWORD typedef ULONGLONG

; NULL definition
NULL EQU 0

; Standard Windows constants
TRUE EQU 1
FALSE EQU 0
INVALID_HANDLE_VALUE EQU -1

; Console handles
STD_INPUT_HANDLE EQU -10
STD_OUTPUT_HANDLE EQU -11
STD_ERROR_HANDLE EQU -12

; File access constants
GENERIC_READ EQU 80000000h
GENERIC_WRITE EQU 40000000h
GENERIC_EXECUTE EQU 20000000h
GENERIC_ALL EQU 10000000h

; File share constants
FILE_SHARE_READ EQU 1
FILE_SHARE_WRITE EQU 2
FILE_SHARE_DELETE EQU 4

; File creation constants
CREATE_NEW EQU 1
CREATE_ALWAYS EQU 2
OPEN_EXISTING EQU 3
OPEN_ALWAYS EQU 4
TRUNCATE_EXISTING EQU 5

; File attributes
FILE_ATTRIBUTE_READONLY EQU 1
FILE_ATTRIBUTE_HIDDEN EQU 2
FILE_ATTRIBUTE_SYSTEM EQU 4
FILE_ATTRIBUTE_DIRECTORY EQU 10h
FILE_ATTRIBUTE_ARCHIVE EQU 20h
FILE_ATTRIBUTE_NORMAL EQU 80h

; FormatMessage flags
FORMAT_MESSAGE_ALLOCATE_BUFFER EQU 100h
FORMAT_MESSAGE_FROM_SYSTEM EQU 1000h
FORMAT_MESSAGE_IGNORE_INSERTS EQU 200h

; Error codes
ERROR_SUCCESS EQU 0
ERROR_FILE_NOT_FOUND EQU 2
ERROR_PATH_NOT_FOUND EQU 3
ERROR_ACCESS_DENIED EQU 5
ERROR_INVALID_HANDLE EQU 6
ERROR_NOT_ENOUGH_MEMORY EQU 8
ERROR_INVALID_DRIVE EQU 15
ERROR_NO_MORE_FILES EQU 18
ERROR_WRITE_PROTECT EQU 19
ERROR_NOT_READY EQU 21
ERROR_SEEK EQU 25
ERROR_WRITE_FAULT EQU 29
ERROR_READ_FAULT EQU 30
ERROR_GEN_FAILURE EQU 31
ERROR_SHARING_VIOLATION EQU 20h
ERROR_LOCK_VIOLATION EQU 21h
ERROR_HANDLE_EOF EQU 26h
ERROR_HANDLE_DISK_FULL EQU 27h
ERROR_NOT_SUPPORTED EQU 32h
ERROR_FILE_EXISTS EQU 50h
ERROR_CANNOT_MAKE EQU 52h
ERROR_INVALID_PARAMETER EQU 57h
ERROR_BROKEN_PIPE EQU 6Dh
ERROR_DISK_FULL EQU 70h
ERROR_INVALID_NAME EQU 7Bh
ERROR_DIR_NOT_EMPTY EQU 91h
ERROR_ALREADY_EXISTS EQU 0B7h
ERROR_BAD_PATHNAME EQU 0A1h
ERROR_TOO_MANY_CMDS EQU 38h

; Seek constants
FILE_BEGIN EQU 0
FILE_CURRENT EQU 1
FILE_END EQU 2