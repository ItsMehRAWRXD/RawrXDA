{
  "name": "ai-cli",
  "displayName": "AI CLI - Multi-Provider AI Assistant",
  "description": "AI-powered development assistant with support for ChatGPT, Amazon Q, CodeGPT, Gemini, and Ollama",
  "version": "1.0.0",
  "publisher": "ai-cli",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "chatgpt",
    "amazon-q",
    "codegpt",
    "gemini",
    "ollama",
    "code-generation",
    "completion",
    "refactoring"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCli.selectProvider",
        "title": "AI CLI: Select Provider",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.ask",
        "title": "AI CLI: Ask AI",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.generateCode",
        "title": "AI CLI: Generate Code",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.refactorCode",
        "title": "AI CLI: Refactor Code",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.debugCode",
        "title": "AI CLI: Debug Code",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.generateTests",
        "title": "AI CLI: Generate Tests",
        "category": "AI CLI"
      },
      {
        "command": "aiCli.webSearch",
        "title": "AI CLI: Web Search",
        "category": "AI CLI"
      }
    ],
    "configuration": {
      "title": "AI CLI",
      "properties": {
        "aiCli.defaultProvider": {
          "type": "string",
          "default": "chatgpt",
          "enum": ["chatgpt", "amazonq", "codegpt", "gemini", "ollama"],
          "description": "Default AI provider to use"
        },
        "aiCli.providers.chatgpt.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ChatGPT provider"
        },
        "aiCli.providers.chatgpt.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for ChatGPT"
        },
        "aiCli.providers.chatgpt.defaultModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Default ChatGPT model"
        },
        "aiCli.providers.amazonq.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Amazon Q provider"
        },
        "aiCli.providers.codegpt.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable CodeGPT provider"
        },
        "aiCli.providers.gemini.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Google Gemini provider"
        },
        "aiCli.providers.ollama.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Ollama provider"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4",
    "vscode-languageclient": "^8.1.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}