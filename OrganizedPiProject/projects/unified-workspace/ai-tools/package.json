{
  "name": "ai-foundation",
  "displayName": "AI Foundation Editor",
  "description": "Multi-AI text editor with chat, review, and suggestion features",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiFoundation.openUnifiedEditor",
        "title": "Open Unified Editor"
      },
      {
        "command": "aiFoundation.openNotepad",
        "title": "Open AI Notepad"
      },
      {
        "command": "aiFoundation.setApiKey",
        "title": "Set AI API Key"
      },
      {
        "command": "aiFoundation.viewWorkflows",
        "title": "View AI Agent Workflows"
      },
      {
        "command": "aiFoundation.searchAgents",
        "title": "Search & Add AI Agents"
      },
      {
        "command": "aiFoundation.showCapabilities",
        "title": "Show AI Capabilities"
      },
      {
        "command": "aiFoundation.newChat",
        "title": "New AI Chat Tab"
      },
      {
        "command": "aiFoundation.enhanceVSCode",
        "title": "Maximize VS Code Limits"
      },
      {
        "command": "aiFoundation.openQDeveloper",
        "title": "Open Q Developer Pro"
      },
      {
        "command": "aiFoundation.findCodingAgents",
        "title": "Find & Help Coding Agents"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}