{
  "name": "rawrz-http",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node launch-control-center.js",
    "web": "node server.js",
    "gui": "node server.js",
    "control-center": "node launch-control-center.js",
    "server": "node server.js",
    "cli": "node scripts/toggle-cli.js",
    "dev": "NODE_ENV=development node server.js",
    "scaffold": "node tools/scaffold-infra.mjs --name rawrz-http --domain rawrz.example.com --registry ghcr.io/your-org/rawrz-http --write-server",
    "audit": "node scripts/audit.js",
    "audit:fix": "npm audit fix",
    "audit:force": "npm audit fix --force",
    "security": "npm run audit && echo 'Security check completed'"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.0.1",
    "file-type": "^18.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
