{
  "name": "RawrXD Production Deployment",
  "version": "3.0.0",
  "description": "Ultimate production deployment configuration for RawrXD autonomous agent system",
  "author": "RawrXD Auto-Generation System",
  "deployment": {
    "mode": "Maximum",
    "sourcePath": "C:\\RawrXD\\Autonomous",
    "targetPath": "C:\\RawrXD\\Production",
    "logPath": "C:\\RawrXD\\Logs",
    "backupPath": "C:\\RawrXD\\Backups",
    "skipTesting": false,
    "skipOptimization": false,
    "skipSecurity": false
  },
  "modules": {
    "RawrXD.ModelLoader": {
      "description": "AWS Bedrock support integration",
      "enabled": true,
      "priority": 1
    },
    "RawrXD.TestFramework": {
      "description": "Performance benchmarks and testing",
      "enabled": true,
      "priority": 2
    },
    "RawrXD.Win32Deployment": {
      "description": "NASM build support and Win32 integration",
      "enabled": true,
      "priority": 3
    }
  },
  "system": {
    "minimumPowerShellVersion": "5.1",
    "requireAdmin": true,
    "minimumDiskSpaceGB": 5,
    "minimumMemoryGB": 4,
    "requireDotNet": "4.7.2+"
  },
  "logging": {
    "level": "Info",
    "enableFileLogging": true,
    "enableConsoleOutput": true,
    "maxLogSizeMB": 10
  },
  "security": {
    "enableAuditLogging": true,
    "enableChecksumValidation": true,
    "enableBackupCreation": true,
    "hashAlgorithm": "SHA256"
  },
  "optimization": {
    "enableCaching": true,
    "enableCompression": true,
    "enableParallelProcessing": true,
    "maxConcurrentJobs": 4
  }
}