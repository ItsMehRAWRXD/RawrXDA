{
  "name": "cursor-simple-ai",
  "displayName": "Simple AI Integration",
  "description": "Direct integration with your-custom-model - no external servers needed",
  "version": "1.0.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:simple-ai.ask"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simple-ai.ask",
        "title": "Ask Your Custom AI",
        "category": "Simple AI"
      },
      {
        "command": "simple-ai.explain",
        "title": "Explain Code",
        "category": "Simple AI"
      },
      {
        "command": "simple-ai.optimize",
        "title": "Optimize Code",
        "category": "Simple AI"
      }
    ],
    "keybindings": [
      {
        "command": "simple-ai.ask",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "simple-ai.explain",
          "group": "simple-ai@1"
        },
        {
          "when": "editorHasSelection",
          "command": "simple-ai.optimize",
          "group": "simple-ai@2"
        }
      ]
    }
  }
}
