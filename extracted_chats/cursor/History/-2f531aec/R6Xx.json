{
  "name": "cursor-machine-id-rotator",
  "displayName": "Cursor Machine ID Rotator",
  "description": "Rotates Cursor's machine IDs to bypass license checks",
  "version": "1.0.0",
  "publisher": "circumvention-tools",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cursor-rotator.rotate",
    "onCommand:cursor-rotator.stealth",
    "onCommand:cursor-rotator.batch"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursor-rotator.rotate",
        "title": "🔄 Rotate Machine ID",
        "category": "Cursor Rotator"
      },
      {
        "command": "cursor-rotator.stealth",
        "title": "🥷 Stealth Rotate",
        "category": "Cursor Rotator"
      },
      {
        "command": "cursor-rotator.batch",
        "title": "⚡ Batch Rotate All",
        "category": "Cursor Rotator"
      },
      {
        "command": "cursor-rotator.status",
        "title": "📊 Show Status",
        "category": "Cursor Rotator"
      }
    ],
    "keybindings": [
      {
        "command": "cursor-rotator.rotate",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "cursor-rotator.stealth",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cursor-rotator.rotate"
        },
        {
          "command": "cursor-rotator.stealth"
        },
        {
          "command": "cursor-rotator.batch"
        },
        {
          "command": "cursor-rotator.status"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package"
  }
}
