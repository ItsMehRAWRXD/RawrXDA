# Dockerfile   –  18 lines
FROM node:20-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxi6 libgl1-mesa-glx libglib2.0-0 && rm -rf /var/lib/apt/lists/*
COPY package*.json ./
RUN npm ci --omit=dev
COPY *.js godtier.html ./
EXPOSE 3000 8001
CMD ["node","micro-server.js"] & ["node","gpu-chain.js"] & ["npx","electron","main.js"]
