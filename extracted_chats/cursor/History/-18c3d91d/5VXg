        .message.system {
            background: #0e639c;
            color: white;
            align-self: center;
            text-align: center;
            font-size: 14px;
        }

        .input-container {
            padding: 20px;
            background: #2d2d30;
            border-top: 1px solid #3e3e42;
            display: flex;
            gap: 10px;
        }

        .input-field {
            flex: 1;
            background: #3c3c3c;
            border: 1px solid #3e3e42;
            color: #d4d4d4;
            padding: 12px;
            border-radius: 4px;
            font-size: 14px;
            outline: none;
        }

        .input-field:focus {
            border-color: #007acc;
        }

        .send-button {
            background: #007acc;
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.2s;
        }

        .send-button:hover {
            background: #005a9e;
        }

        .send-button:disabled {
            background: #555;
            cursor: not-allowed;
        }

        .voice-button {
            background: #28a745;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 4px;
            cursor: pointer;
            margin-right: 10px;
            transition: background 0.2s;
        }

        .voice-button:hover {
            background: #218838;
        }

        .voice-button.recording {
            background: #dc3545;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        .sidebar-header {
            padding: 15px;
            background: #2d2d30;
            border-bottom: 1px solid #3e3e42;
        }

        .sidebar-content {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
        }

        .feature-list {
            list-style: none;
        }

        .feature-list li {
            padding: 8px 0;
            border-bottom: 1px solid #3e3e42;
            cursor: pointer;
            transition: color 0.2s;
        }

        .feature-list li:hover {
            color: #007acc;
        }

        .code-suggestion {
            background: #1e1e1e;
            border: 1px solid #3e3e42;
            border-radius: 4px;
            padding: 10px;
            margin: 10px 0;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            overflow-x: auto;
        }

        .typing-indicator {
            display: none;
            color: #888;
            font-style: italic;
        }

        .typing-indicator.show {
            display: block;
        }

        .settings-panel {
            background: #2d2d30;
            border: 1px solid #3e3e42;
            border-radius: 4px;
            padding: 15px;
            margin: 10px 0;
        }

        .settings-panel h3 {
            margin-bottom: 10px;
            color: #007acc;
        }

        .setting-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 10px 0;
        }

        .toggle {
            width: 40px;
            height: 20px;
            background: #555;
            border-radius: 10px;
            position: relative;
            cursor: pointer;
            transition: background 0.2s;
        }

        .toggle.active {
            background: #007acc;
        }

        .toggle::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            background: white;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: transform 0.2s;
        }

        .toggle.active::after {
            transform: translateX(20px);
        }
