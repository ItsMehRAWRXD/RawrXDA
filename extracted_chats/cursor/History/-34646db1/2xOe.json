{
  "name": "bigdaddyg-browser",
  "version": "1.0.0",
  "description": "Self-made BigDaddyG Agentic Browser - Native Desktop Application",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": "BigDaddyG",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "child_process": "^1.0.2",
    "path": "^0.12.7",
    "fs": "^0.0.1-security"
  },
  "build": {
    "appId": "com.bigdaddyg.browser",
    "productName": "BigDaddyG Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.md",
      "!*.sh",
      "!*.bat",
      "!frontend/index.html"
    ],
    "extraFiles": [
      {
        "from": "frontend/index-electron.html",
        "to": "frontend/index.html"
      }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}