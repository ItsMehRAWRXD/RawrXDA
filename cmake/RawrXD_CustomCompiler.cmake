set(CMAKE_SYSTEM_NAME Windows)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
if(NOT DEFINED RAWRXD_CXX_COMPILER OR NOT EXISTS "${RAWRXD_CXX_COMPILER}")
  message(FATAL_ERROR "RAWRXD_CXX_COMPILER must be set to your custom C++ compiler")
endif()
set(CMAKE_CXX_COMPILER "${RAWRXD_CXX_COMPILER}")
if(DEFINED RAWRXD_C_COMPILER AND EXISTS "${RAWRXD_C_COMPILER}")
  set(CMAKE_C_COMPILER "${RAWRXD_C_COMPILER}")
else()
  set(CMAKE_C_COMPILER "${RAWRXD_CXX_COMPILER}")
endif()
add_compile_definitions(RAWRXD_NO_QT)
message(STATUS "RawrXD custom C++ compiler: ${CMAKE_CXX_COMPILER}")
