# RawrXD Full Stack Container
# Runs Win32 IDE via Wine + noVNC for browser access + Backend API

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV WINEDEBUG=-all
ENV DISPLAY=:1
ENV VNC_PORT=5901
ENV NOVNC_PORT=8080
ENV RAWRXD_PORT=23959

# Install dependencies
RUN dpkg --add-architecture i386 && \
    apt-get update && \
    apt-get install -y \
    wine64 wine32 xvfb x11vnc novnc websockify \
    python3 python3-pip \
    supervisor fluxbox xterm \
    libvulkan1 mesa-vulkan-drivers \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Setup Wine prefix
ENV WINEPREFIX=/root/.wine
ENV WINEARCH=win64
RUN wineboot --init && wineserver -w

# Copy IDE binaries (ensure RawrXD-Win32IDE.exe exists in build context for desktop profile)
# Build with: docker build -f docker/Dockerfile.full --build-arg IDE_EXE=path/to/RawrXD-Win32IDE.exe ..
COPY web_interface/ /opt/rawrxd/web/

# Copy backend
COPY Ship/ /opt/rawrxd/backend/

# Setup supervisor config
COPY docker/supervisord.conf /etc/supervisor/conf.d/rawrxd.conf

# Expose ports
EXPOSE 8080 23959 5901

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
    CMD curl -f http://localhost:23959/status || exit 1

CMD ["/usr/bin/supervisord", "-n", "-c", "/etc/supervisor/supervisord.conf"]
