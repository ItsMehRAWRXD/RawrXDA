@PACKAGE_INIT@

set(PEWriter_VERSION "@PROJECT_VERSION@")

set_and_check(PEWriter_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set_and_check(PEWriter_LIBRARY_DIR "@PACKAGE_CMAKE_INSTALL_LIBDIR@")

include("${CMAKE_CURRENT_LIST_DIR}/PEWriterTargets.cmake")

check_required_components(PEWriter)

# Provide legacy variables
set(PEWriter_LIBRARIES PEWriter::pe_writer)
set(PEWriter_INCLUDE_DIRS "${PEWriter_INCLUDE_DIR}")