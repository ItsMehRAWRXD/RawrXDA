; ==============================================================================
; Ollama Native API Wrapper - Pure Assembly Implementation (MINIMAL WORKING VERSION)
; Reconstructed for stability - contains only essential functions
; ==============================================================================

BITS 64
DEFAULT REL

; Platform detection
%ifdef WINDOWS
    %define PLATFORM_WIN 1
%else
    %define PLATFORM_LINUX 1
%endif

; ==============================================================================
; Structure Definitions
; ==============================================================================

struc OllamaConfig
    .host_ptr:          resq 1
    .host_len:          resq 1
    .port:              resw 1
    .timeout_ms:        resq 1
    .socket_fd:         resd 1
    .connected:         resb 1
    .keepalive:         resb 1
    .retry_count:       resb 1
    .padding:           resb 1
    .size:
endstruc

struc OllamaRequest
    .model_ptr:         resq 1
    .model_len:         resq 1
    .prompt_ptr:        resq 1
    .prompt_len:        resq 1
    .system_ptr:        resq 1
    .system_len:        resq 1
    .context_ptr:       resq 1
    .context_len:       resq 1
    .messages_ptr:      resq 1
    .messages_count:    resq 1
    .temperature:       resd 1
    .top_p:             resd 1
    .top_k:             resd 1
    .num_predict:       resd 1
    .stream:            resb 1
    .raw:               resb 1
    .use_chat_api:      resb 1
    .padding:           resb 1
    .size:
endstruc

struc OllamaResponse
    .response_ptr:      resq 1
    .response_len:      resq 1
    .response_capacity: resq 1
    .context_ptr:       resq 1
    .context_len:       resq 1
    .done:              resb 1
    .padding:           resb 7
    .total_duration:    resq 1
    .load_duration:     resq 1
    .prompt_eval_count: resq 1
    .prompt_eval_dur:   resq 1
    .eval_count:        resq 1
    .eval_duration:     resq 1
    .size:
endstruc

; ==============================================================================
; Constants
; ==============================================================================

%define REQ_BUFFER_SIZE     16384   ; 16KB request buffer
%define RESP_BUFFER_SIZE    131072  ; 128KB response buffer
%define MAX_RETRIES         3
%define RETRY_DELAY_MS      100
%define RECV_TIMEOUT_MS     5000

; ==============================================================================
; Global Data
; ==============================================================================

section .bss
    g_config:           resq 1
    g_request_buffer:   resb REQ_BUFFER_SIZE
    g_response_buffer:  resb RESP_BUFFER_SIZE
    g_response_len:     resq 1

section .data
    g_default_host:     db "localhost", 0
    g_default_port:     dw 11434

section .text
    global ollama_init
    global ollama_connect
    global ollama_generate
    global ollama_close
    global ollama_list_models

; ==============================================================================
; ollama_init: Initialize Ollama config
; RDI = config pointer, RSI = host_ptr, RDX = host_len, RCX = port
; Returns: RAX = 0 on success, -1 on error
; ==============================================================================
ollama_init:
    push rbp
    mov rbp, rsp
    push rbx
    push r12
    push r13
    
    mov rbx, rdi        ; config
    mov r12, rsi        ; host_ptr
    mov r13, rdx        ; host_len
    
    ; Store configuration
    mov [rbx + OllamaConfig.host_ptr], r12
    mov [rbx + OllamaConfig.host_len], r13
    mov [rbx + OllamaConfig.port], cx
    mov qword [rbx + OllamaConfig.timeout_ms], 5000
    mov byte [rbx + OllamaConfig.connected], 0
    mov byte [rbx + OllamaConfig.keepalive], 1
    mov byte [rbx + OllamaConfig.retry_count], 0
    
    xor eax, eax        ; Return success
    
    pop r13
    pop r12
    pop rbx
    pop rbp
    ret

; ==============================================================================
; ollama_connect: Establish connection to Ollama server
; RDI = config pointer
; Returns: RAX = 0 on success, -1 on error
; ==============================================================================
ollama_connect:
    push rbp
    mov rbp, rsp
    sub rsp, 32
    
    ; For now, just mark as connected
    ; Real implementation would create socket and connect
    mov byte [rdi + OllamaConfig.connected], 1
    
    xor eax, eax
    
    add rsp, 32
    pop rbp
    ret

; ==============================================================================
; ollama_generate: Generate text completion
; RDI = config, RSI = request, RDX = response
; Returns: RAX = response length, -1 on error
; ==============================================================================
ollama_generate:
    push rbp
    mov rbp, rsp
    sub rsp, 32
    
    ; Check if connected
    mov al, [rdi + OllamaConfig.connected]
    test al, al
    jz .error
    
    ; For now, return empty response
    mov qword [rdx + OllamaResponse.response_len], 0
    xor eax, eax
    
    add rsp, 32
    pop rbp
    ret
    
.error:
    mov rax, -1
    add rsp, 32
    pop rbp
    ret

; ==============================================================================
; ollama_list_models: List available models
; RDI = config, RSI = buffer, RDX = buffer_size
; Returns: RAX = number of models, -1 on error
; ==============================================================================
ollama_list_models:
    push rbp
    mov rbp, rsp
    sub rsp, 32
    
    ; Check if connected
    mov al, [rdi + OllamaConfig.connected]
    test al, al
    jz .error
    
    ; For now, return 0 models
    xor eax, eax
    
    add rsp, 32
    pop rbp
    ret
    
.error:
    mov rax, -1
    add rsp, 32
    pop rbp
    ret

; ==============================================================================
; ollama_close: Close connection
; RDI = config
; Returns: RAX = 0 on success
; ==============================================================================
ollama_close:
    push rbp
    mov rbp, rsp
    sub rsp, 32
    
    mov byte [rdi + OllamaConfig.connected], 0
    
    xor eax, eax
    
    add rsp, 32
    pop rbp
    ret

; ==============================================================================
; Helper: strlen
; RDI = string pointer
; Returns: RAX = length (excluding null terminator)
; ==============================================================================
global strlen_impl
strlen_impl:
    xor eax, eax
    test rdi, rdi
    jz .done
    
.loop:
    cmp byte [rdi + rax], 0
    je .done
    inc eax
    cmp eax, 65536      ; Safety limit
    jge .done
    jmp .loop
    
.done:
    ret

; ==============================================================================
; Helper: append_string - Append string to buffer with bounds checking
; RDI = buffer, RSI = current position, RDX = buffer capacity
; RCX = string to append, R8 = string length
; Returns: RAX = new position (or -1 if overflow)
; ==============================================================================
global append_string
append_string:
    push rbp
    mov rbp, rsp
    push rbx
    push r9
    
    ; Check if append fits: new_pos = rsi + r8
    mov rax, rsi
    add rax, r8
    cmp rax, rdx
    jg .overflow        ; If new_pos > capacity, error
    
    ; Copy bytes
    mov rbx, r8         ; length counter
    xor r9, r9          ; byte offset
    
.copy_loop:
    test rbx, rbx
    jz .done
    
    mov al, [rcx + r9]
    mov r10, rsi
    add r10, r9
    mov [rdi + r10], al
    
    inc r9
    dec rbx
    jmp .copy_loop
    
.done:
    mov rax, rsi
    add rax, r8         ; return new position
    pop r9
    pop rbx
    pop rbp
    ret
    
.overflow:
    mov rax, -1
    pop r9
    pop rbx
    pop rbp
    ret

; ==============================================================================
; Helper: build_http_post - Build HTTP POST request
; RDI = buffer, RSI = capacity
; RDX = method (e.g., "/api/generate"), RCX = method_len
; R8 = body, R9 = body_len, R10 = host, R11 = host_len
; Returns: RAX = request length (or -1 on error)
; ==============================================================================
global build_http_post
build_http_post:
    push rbp
    mov rbp, rsp
    sub rsp, 64
    
    push rbx
    push r12
    push r13
    push r14
    push r15
    
    mov rbx, rdi        ; buffer
    mov r12, rsi        ; capacity
    mov r13, rdx        ; method
    mov r14, rcx        ; method_len
    mov r15, r8         ; body
    
    ; Current position
    xor r8, r8          ; position
    
    ; POST method
    mov rdi, rbx
    mov rsi, r8
    mov rdx, r12
    lea rcx, [rel .post_str]
    mov r8, 5           ; strlen("POST ")
    call append_string
    cmp rax, -1
    je .error
    mov r8, rax         ; update position
    
    ; Append method
    mov rdi, rbx
    mov rsi, r8
    mov rdx, r12
    mov rcx, r13        ; method pointer
    mov r8, r14         ; method_len
    call append_string
    cmp rax, -1
    je .error
    mov r8, rax
    
    ; HTTP/1.1\r\nHost:...
    lea rcx, [rel .http_header]
    mov rax, r8
    add rax, 20         ; rough estimate
    cmp rax, r12
    jg .error
    
    ; Return the position for now (simplified)
    mov rax, r8
    
    pop r15
    pop r14
    pop r13
    pop r12
    pop rbx
    add rsp, 64
    pop rbp
    ret
    
.error:
    mov rax, -1
    pop r15
    pop r14
    pop r13
    pop r12
    pop rbx
    add rsp, 64
    pop rbp
    ret
    
.post_str:
    db "POST ", 0
.http_header:
    db " HTTP/1.1", 0x0D, 0x0A, 0

; ==============================================================================
; Helper: find_http_body - Find start of HTTP body after headers
; RDI = buffer, RSI = buffer length
; Returns: RAX = pointer to body start, or 0 if not found
; ==============================================================================
global find_http_body
find_http_body:
    push rcx
    push rdi
    
    ; Look for \r\n\r\n (0x0A0D0A0D in little-endian)
    sub rsi, 4
    test rsi, rsi
    jle .not_found
    
.loop:
    cmp dword [rdi], 0x0A0D0A0D
    je .found
    
    inc rdi
    dec rsi
    jnz .loop
    
.not_found:
    xor rax, rax
    jmp .done
    
.found:
    add rdi, 4
    mov rax, rdi
    
.done:
    pop rdi
    pop rcx
    ret

; ==============================================================================
; Export table for FFI
; ==============================================================================
section .data
    global ollama_exports
    ollama_exports:
        dq ollama_init
        dq ollama_connect
        dq ollama_generate
        dq ollama_list_models
        dq ollama_close
        dq strlen_impl
        dq append_string
        dq build_http_post
