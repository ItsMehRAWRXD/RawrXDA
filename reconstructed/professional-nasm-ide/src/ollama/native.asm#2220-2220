; ==============================================================================
; Linux Socket Functions
; ==============================================================================

%ifndef PLATFORM_WIN

global create_socket_linux
global connect_socket_linux
global close_socket_linux
global send_linux
global recv_linux

create_socket_linux:
    push rbp
    mov rbp, rsp
    
    mov rax, 41         ; sys_socket
    mov rdi, 2          ; AF_INET
    mov rsi, 1          ; SOCK_STREAM
    mov rdx, 6          ; IPPROTO_TCP
    syscall
    
    pop rbp
    ret

connect_socket_linux:
    push rbp
    mov rbp, rsp
    
    mov rax, 42         ; sys_connect
    mov rdi, rcx        ; socket
    mov rsi, rdx        ; sockaddr
    mov rdx, r8         ; namelen
    syscall
    
    pop rbp
    ret

close_socket_linux:
    push rbp
    mov rbp, rsp
    
    mov rax, 3          ; sys_close
    mov rdi, rcx        ; socket
    syscall
    
    pop rbp
    ret

send_linux:
    push rbp
    mov rbp, rsp
    
    mov rax, 44         ; sys_sendto
    mov rdi, rcx        ; socket
    mov rsi, rdx        ; buffer
    mov rdx, r8         ; len
    mov r10, r9         ; flags
    syscall
    
    pop rbp
    ret

recv_linux:
    push rbp
    mov rbp, rsp
    
    mov rax, 45         ; sys_recvfrom
    mov rdi, rcx        ; socket
    mov rsi, rdx        ; buffer
    mov rdx, r8         ; len
    mov r10, r9         ; flags
    syscall
    
    pop rbp
    ret

%endif
