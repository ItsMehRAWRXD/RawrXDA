    mov edx, 1          ; SOCK_STREAM
    mov r8d, 6          ; IPPROTO_TCP
    
    ; Call socket (would be from ws2_32.dll)
    ; For now stub: return fake socket handle
    mov eax, 1          ; Fake socket 1
    
    add rsp, 32
    pop rbp
