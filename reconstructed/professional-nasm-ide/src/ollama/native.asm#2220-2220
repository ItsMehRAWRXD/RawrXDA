    push rbp
    mov rbp, rsp
    sub rsp, 32
    
    ; WSAStartup(MAKEWORD(2,2), &wsaData)
    mov ecx, 0x0202
    lea rdx, [rsp]
    
    ; Call WSAStartup through stub (would be imported from ws2_32.dll)
