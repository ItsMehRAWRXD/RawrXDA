; =============================================================================
; RawrXD_Installer.wxs — WiX v4 Installer Bootstrapper
; =============================================================================
; VC++ Redist check, VulkanRT install, start menu shortcuts, PATH registration
;
; Build: wix build -o RawrXD-Setup.msi RawrXD_Installer.wxs
; Prerequisites: wix.exe (WiX v4 CLI), heat.exe (dir harvesting)
;
; Rule: NO SOURCE FILE IS TO BE SIMPLIFIED
; =============================================================================

<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <!-- ================================================================= -->
    <!-- Product Definition                                                  -->
    <!-- ================================================================= -->
    <Package Name="RawrXD IDE"
             Manufacturer="RawrXD / ItsMehRAWRXD"
             Version="7.4.0.0"
             UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
             Scope="perMachine"
             InstallerVersion="500">

        <SummaryInformation Description="RawrXD IDE — Advanced GGUF Model Loader with Live Hotpatching"
                            Manufacturer="RawrXD" />

        <!-- Major upgrade support (removes older versions) -->
        <MajorUpgrade DowngradeErrorMessage="A newer version of RawrXD IDE is already installed."
                      AllowSameVersionUpgrades="yes" />

        <!-- Embedded UI (basic + license dialog) -->
        <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

        <!-- ============================================================= -->
        <!-- Prerequisites Check: VC++ 2022 Redistributable               -->
        <!-- ============================================================= -->
        <Property Id="VCREDIST2022_INSTALLED">
            <RegistrySearch Id="VCRedist2022Search"
                            Root="HKLM"
                            Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\X64"
                            Name="Installed"
                            Type="raw" />
        </Property>

        <Launch Condition="VCREDIST2022_INSTALLED OR Installed"
                Message="Microsoft Visual C++ 2022 Redistributable (x64) is required. Please install it from https://aka.ms/vs/17/release/vc_redist.x64.exe and run this setup again." />

        <!-- ============================================================= -->
        <!-- Prerequisites Check: Vulkan Runtime                           -->
        <!-- ============================================================= -->
        <Property Id="VULKANRT_INSTALLED">
            <RegistrySearch Id="VulkanRTSearch"
                            Root="HKLM"
                            Key="SOFTWARE\Khronos\Vulkan\Drivers"
                            Type="raw" />
        </Property>

        <!-- Vulkan is optional — warn but don't block -->
        <!-- Custom action to show warning if VulkanRT not found -->

        <!-- ============================================================= -->
        <!-- Directory Layout                                                -->
        <!-- ============================================================= -->
        <StandardDirectory Id="ProgramFiles6432Folder">
            <Directory Id="INSTALLFOLDER" Name="RawrXD IDE">
                <Directory Id="DIR_BIN" Name="bin" />
                <Directory Id="DIR_ENGINES" Name="engines" />
                <Directory Id="DIR_PLUGINS" Name="plugins" />
                <Directory Id="DIR_CONFIG" Name="config" />
                <Directory Id="DIR_CRASH_DUMPS" Name="crash_dumps" />
                <Directory Id="DIR_MODELS" Name="models" />
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="DIR_STARTMENU" Name="RawrXD IDE" />
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder" />

        <!-- ============================================================= -->
        <!-- Core Files Component Group                                      -->
        <!-- ============================================================= -->
        <ComponentGroup Id="CoreFiles" Directory="INSTALLFOLDER">

            <!-- Main IDE executable + Win32IDE -->
            <Component Id="MainExe" Guid="11111111-1111-1111-1111-111111111111">
                <File Id="RawrXD_Gold_Exe"
                      Source="$(var.BuildDir)\bin\RawrXD_Gold.exe"
                      Name="RawrXD_Gold.exe"
                      KeyPath="yes">
                    <Shortcut Id="StartMenuShortcut"
                              Directory="DIR_STARTMENU"
                              Name="RawrXD IDE"
                              Description="Advanced GGUF Model Loader with Live Hotpatching"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="RawrXD.ico"
                              Advertise="yes" />
                    <Shortcut Id="DesktopShortcut"
                              Directory="DesktopFolder"
                              Name="RawrXD IDE"
                              Description="RawrXD IDE"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="RawrXD.ico"
                              Advertise="yes" />
                </File>
            </Component>

            <Component Id="Win32IDE" Guid="22222222-2222-2222-2222-222222222222">
                <File Id="RawrXD_Win32IDE_Exe"
                      Source="$(var.BuildDir)\bin\RawrXD-Win32IDE.exe"
                      Name="RawrXD-Win32IDE.exe"
                      KeyPath="yes">
                    <Shortcut Id="StartMenuWin32IDE"
                              Directory="DIR_STARTMENU"
                              Name="RawrXD Win32 IDE"
                              Description="Win32 Native IDE Surface"
                              WorkingDirectory="INSTALLFOLDER"
                              Icon="RawrXD.ico"
                              Advertise="yes" />
                </File>
            </Component>

            <Component Id="EngineExe" Guid="33333333-3333-3333-3333-333333333333">
                <File Id="RawrEngine_Exe"
                      Source="$(var.BuildDir)\RawrEngine.exe"
                      Name="RawrEngine.exe"
                      KeyPath="yes" />
            </Component>

            <!-- License file -->
            <Component Id="LicenseFile" Guid="44444444-4444-4444-4444-444444444444">
                <File Id="LICENSE_TXT"
                      Source="$(var.SourceDir)\LICENSE"
                      Name="LICENSE.txt"
                      KeyPath="yes" />
            </Component>

            <!-- Version info manifest -->
            <Component Id="VersionManifest" Guid="55555555-5555-5555-5555-555555555555">
                <File Id="VERSION_JSON"
                      Source="$(var.SourceDir)\version.json"
                      Name="version.json"
                      KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <!-- ============================================================= -->
        <!-- PATH Environment Variable                                       -->
        <!-- ============================================================= -->
        <ComponentGroup Id="PathRegistration" Directory="INSTALLFOLDER">
            <Component Id="PathEnvVar" Guid="66666666-6666-6666-6666-666666666666">
                <CreateFolder />
                <Environment Id="PATH_ENTRY"
                             Name="PATH"
                             Value="[INSTALLFOLDER]"
                             Permanent="no"
                             Part="last"
                             Action="set"
                             System="yes" />
            </Component>
        </ComponentGroup>

        <!-- ============================================================= -->
        <!-- File Associations: .gguf, .rawrlic                             -->
        <!-- ============================================================= -->
        <ComponentGroup Id="FileAssociations" Directory="INSTALLFOLDER">
            <Component Id="GGUFAssoc" Guid="77777777-7777-7777-7777-777777777777">
                <RegistryValue Root="HKCR" Key="RawrXD.GGUF" Type="string"
                               Value="GGUF Model File" KeyPath="yes" />
                <RegistryValue Root="HKCR" Key="RawrXD.GGUF\shell\open\command" Type="string"
                               Value="&quot;[INSTALLFOLDER]RawrXD_Gold.exe&quot; &quot;%1&quot;" />
                <RegistryValue Root="HKCR" Key=".gguf" Type="string"
                               Value="RawrXD.GGUF" />
            </Component>

            <Component Id="LicenseAssoc" Guid="88888888-8888-8888-8888-888888888888">
                <RegistryValue Root="HKCR" Key="RawrXD.License" Type="string"
                               Value="RawrXD License File" KeyPath="yes" />
                <RegistryValue Root="HKCR" Key="RawrXD.License\shell\open\command" Type="string"
                               Value="&quot;[INSTALLFOLDER]RawrXD_Gold.exe&quot; --install-license &quot;%1&quot;" />
                <RegistryValue Root="HKCR" Key=".rawrlic" Type="string"
                               Value="RawrXD.License" />
            </Component>
        </ComponentGroup>

        <!-- ============================================================= -->
        <!-- Uninstall Registry Entry                                        -->
        <!-- ============================================================= -->
        <ComponentGroup Id="RegistryEntries" Directory="INSTALLFOLDER">
            <Component Id="RegInstallPath" Guid="99999999-9999-9999-9999-999999999999">
                <RegistryKey Root="HKLM" Key="SOFTWARE\RawrXD\IDE">
                    <RegistryValue Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
                    <RegistryValue Name="Version" Type="string" Value="7.4.0" />
                    <RegistryValue Name="BuildDate" Type="string" Value="2026-02-11" />
                </RegistryKey>
            </Component>
        </ComponentGroup>

        <!-- ============================================================= -->
        <!-- Icon                                                            -->
        <!-- ============================================================= -->
        <Icon Id="RawrXD.ico" SourceFile="$(var.SourceDir)\resources\rawrxd.ico" />
        <Property Id="ARPPRODUCTICON" Value="RawrXD.ico" />
        <Property Id="ARPHELPLINK" Value="https://github.com/ItsMehRAWRXD/RawrXD" />

        <!-- ============================================================= -->
        <!-- Features                                                        -->
        <!-- ============================================================= -->
        <Feature Id="CoreFeature" Title="RawrXD IDE Core"
                 Description="Core IDE, inference engine, and MASM kernel modules"
                 Level="1" AllowAbsent="no">
            <ComponentGroupRef Id="CoreFiles" />
            <ComponentGroupRef Id="PathRegistration" />
            <ComponentGroupRef Id="FileAssociations" />
            <ComponentGroupRef Id="RegistryEntries" />
        </Feature>

        <Feature Id="PluginsFeature" Title="Plugin System"
                 Description="QuickJS extension host and plugin directory"
                 Level="1" AllowAbsent="yes">
            <!-- Plugin files would be harvested by heat.exe -->
        </Feature>

    </Package>
</Wix>
