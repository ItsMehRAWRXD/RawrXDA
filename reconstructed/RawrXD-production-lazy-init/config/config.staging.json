{
  "_comment": "RawrXD Production Configuration - Staging Environment",
  "version": "1.0.0",
  "environment": "staging",
  "paths": {
    "model_path": "C:\\ProgramData\\RawrXD\\models",
    "config_path": "C:\\ProgramData\\RawrXD\\config",
    "log_path": "C:\\ProgramData\\RawrXD\\logs",
    "cache_path": "C:\\ProgramData\\RawrXD\\cache"
  },
  "api": {
    "endpoint": "https://staging-api.rawrxd.com/v1",
    "api_key": "${RAWRXD_API_KEY}",
    "timeout_ms": 45000,
    "retry_count": 5,
    "retry_delay_ms": 2000
  },
  "model": {
    "default_model": "llama3.2:3b-instruct-q4_0",
    "max_model_size_bytes": 2147483648,
    "model_cache_size": 1024,
    "auto_download": true,
    "quantization_level": "q4_0"
  },
  "logging": {
    "log_level": "INFO",
    "log_to_file": true,
    "log_to_console": false,
    "log_file_max_size_mb": 500,
    "log_file_retention_days": 30,
    "structured_logging": true
  },
  "performance": {
    "thread_pool_size": 8,
    "max_concurrent_requests": 50,
    "request_timeout_ms": 45000,
    "worker_threads": 8,
    "io_threads": 4
  },
  "features": {
    "gpu_acceleration": true,
    "distributed_trace": true,
    "advanced_metrics": true,
    "hotpatch_dynamic": true,
    "quantum_ops": true,
    "experimental_models": true,
    "debug_mode": false,
    "auto_update": true
  },
  "ui": {
    "theme": "dark",
    "font_family": "Consolas",
    "font_size": 11,
    "line_numbers": true,
    "minimap": true,
    "word_wrap": false
  },
  "security": {
    "enable_api_key_validation": true,
    "enable_tls": true,
    "enable_cors": true,
    "allowed_origins": [
      "https://staging.rawrxd.com"
    ]
  }
}