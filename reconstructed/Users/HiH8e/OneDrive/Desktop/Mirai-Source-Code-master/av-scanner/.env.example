# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database
DB_PATH=./database/av_scanner.db

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook

# Payment (Stripe/PayPal)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# AV Engine Configuration
# Add your AV engine API keys/endpoints here
AV_ENGINE_TIMEOUT=300000
ENABLE_PRIVATE_MODE=true

# Pricing
BASIC_PRICE_PER_SCAN=0.30
PERSONAL_PLAN_PRICE=60
PERSONAL_PLAN_SCANS=200
PROFESSIONAL_PLAN_PRICE=180
PROFESSIONAL_PLAN_SCANS=600
ENTERPRISE_PLAN_PRICE=360
ENTERPRISE_PLAN_SCANS=1200
DISCOUNT_RATE=0.35
