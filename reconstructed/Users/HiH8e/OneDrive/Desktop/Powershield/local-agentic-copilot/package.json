{
  "name": "local-agentic-copilot",
  "displayName": "Local Agentic Copilot",
  "description": "GitHub Copilot-like experience using local Ollama models with agentic reasoning",
  "version": "1.0.0",
  "publisher": "RawrXD",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "copilot",
    "ai",
    "ollama",
    "agentic",
    "code-completion",
    "local-ai"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentic-copilot.toggleAgenticMode",
        "title": "Toggle Agentic Mode",
        "category": "Agentic Copilot"
      },
      {
        "command": "agentic-copilot.generateCode",
        "title": "Generate Code (Agentic)",
        "category": "Agentic Copilot"
      },
      {
        "command": "agentic-copilot.explainCode",
        "title": "Explain Code",
        "category": "Agentic Copilot"
      },
      {
        "command": "agentic-copilot.fixCode",
        "title": "Fix Code Issues",
        "category": "Agentic Copilot"
      },
      {
        "command": "agentic-copilot.showStatus",
        "title": "Show Agentic Status",
        "category": "Agentic Copilot"
      }
    ],
    "keybindings": [
      {
        "command": "agentic-copilot.toggleAgenticMode",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "agentic-copilot.generateCode",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j"
      }
    ],
    "configuration": {
      "title": "Agentic Copilot",
      "properties": {
        "agenticCopilot.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API endpoint"
        },
        "agenticCopilot.agenticModel": {
          "type": "string",
          "default": "cheetah-stealth-agentic:latest",
          "description": "Model to use for agentic mode"
        },
        "agenticCopilot.standardModel": {
          "type": "string",
          "default": "bigdaddyg-fast:latest",
          "description": "Model to use for standard mode"
        },
        "agenticCopilot.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completion suggestions"
        },
        "agenticCopilot.completionDelay": {
          "type": "number",
          "default": 500,
          "description": "Delay before showing completion suggestions (ms)"
        },
        "agenticCopilot.autoFormat": {
          "type": "boolean",
          "default": true,
          "description": "Auto-format generated code"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentic-copilot-view",
          "title": "Agentic Copilot",
          "icon": "media/agentic-icon.svg"
        }
      ]
    },
    "views": {
      "agentic-copilot-view": [
        {
          "id": "agenticStatus",
          "name": "Status",
          "icon": "media/status.svg"
        },
        {
          "id": "agenticChat",
          "name": "Chat",
          "icon": "media/chat.svg"
        },
        {
          "id": "agenticSettings",
          "name": "Settings",
          "icon": "media/settings.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}