+std::string ChatWorkspace::GenerateChatId() {
+    static std::random_device rd;
+    static std::mt19937 gen(rd());
+    static std::uniform_int_distribution<> dis(0, 15);
+    
+    const char* hex = "0123456789abcdef";
+    std::string id = "chat_";
+    
+    for (int i = 0; i < 16; ++i) {
+        id += hex[dis(gen)];
+    }
+    
+    return id;
