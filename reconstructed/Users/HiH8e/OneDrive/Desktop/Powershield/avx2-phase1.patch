+  <div class="main-content">
+    <div class="editor-header">Code Editor</div>
+    <div class="editor-area">
+      <textarea class="code-editor" id="codeEditor">// Write your code here
+function example() {
+  console.log('Hello, Copilot!');
+}</textarea>
+    </div>
+    <div class="context-info" id="contextInfo">
+      Context: Current file (4 lines)
+    </div>
+  </div>
+
+  <script>
+    const chatHistory = document.getElementById('chatHistory');
+    const userInput = document.getElementById('userInput');
+    const sendBtn = document.getElementById('sendBtn');
+    const codeEditor = document.getElementById('codeEditor');
+    const contextInfo = document.getElementById('contextInfo');
+
+    let messages = [];
+
+    function addMessage(role, content, feedbackEnabled = false) {
+      const msg = { role, content, timestamp: new Date().toISOString() };
+      messages.push(msg);
+
+      const msgEl = document.createElement('div');
+      msgEl.className = `message ${role}`;
+      msgEl.textContent = content;
+
+      if (feedbackEnabled && role === 'assistant') {
+        const feedbackDiv = document.createElement('div');
+        feedbackDiv.className = 'feedback-actions';
+        feedbackDiv.innerHTML = `
+          <button class="feedback-btn" data-feedback="helpful">👍 Helpful</button>
+          <button class="feedback-btn" data-feedback="unhelpful">👎 Not helpful</button>
+        `;
+        feedbackDiv.addEventListener('click', (e) => {
+          if (e.target.classList.contains('feedback-btn')) {
+            feedbackDiv.querySelectorAll('.feedback-btn').forEach(b => b.classList.remove('active'));
+            e.target.classList.add('active');
+            msg.feedback = e.target.dataset.feedback;
+            console.log('Feedback recorded:', msg.feedback);
+          }
+        });
+        msgEl.appendChild(feedbackDiv);
+      }
+
+      chatHistory.appendChild(msgEl);
+      chatHistory.scrollTop = chatHistory.scrollHeight;
+      return msgEl;
+    }
+
+    function updateContext() {
+      const lines = codeEditor.value.split('\n').length;
+      const chars = codeEditor.value.length;
+      contextInfo.textContent = `Context: Current file (${lines} lines, ${chars} chars)`;
+    }
+
+    async function sendMessage() {
+      const userMessage = userInput.value.trim();
+      if (!userMessage) return;
+
+      userInput.value = '';
+      sendBtn.disabled = true;
+
+      addMessage('user', userMessage);
+
+      // Include code context in the request
+      const context = codeEditor.value;
+      const prompt = `User's code:\n\`\`\`\n${context}\n\`\`\`\n\nUser question: ${userMessage}`;
+
+      try {
+        const response = await fetch('/stream', {
+          method: 'POST',
+          headers: { 'Content-Type': 'application/json' },
+          body: JSON.stringify({
+            upstream: 'http://localhost:11434/api/generate',
+            provider: 'ollama',
+            model: 'llama3.1:8b-instruct',
+            prompt: prompt,
+            max_tokens: 512
+          })
+        });
+
+        if (!response.ok) {
+          addMessage('system', 'Error: ' + (await response.text()));
+          sendBtn.disabled = false;
+          return;
+        }
+
+        const assistantMsgEl = addMessage('assistant', '', true);
+        let fullResponse = '';
+
+        const reader = response.body.getReader();
+        const decoder = new TextDecoder('utf-8');
+        let buffer = '';
+
+        while (true) {
+          const { value, done } = await reader.read();
+          if (done) break;
+
+          buffer += decoder.decode(value, { stream: true });
+          const parts = buffer.split(/\n\n/);
+          buffer = parts.pop();
+
+          for (const part of parts) {
+            if (!part.startsWith('data:')) continue;
+            const payload = part.replace(/^data:\s*/, '');
+            try {
+              const j = JSON.parse(payload);
+              if (j.response) {
+                fullResponse += j.response;
+                assistantMsgEl.childNodes[0].textContent = fullResponse;
+                chatHistory.scrollTop = chatHistory.scrollHeight;
+              }
+            } catch {
+              // Ignore non-JSON
+            }
+          }
+        }
+
+        messages[messages.length - 1].content = fullResponse;
+
+      } catch (err) {
+        addMessage('system', 'Network error: ' + err.message);
+      }
+
+      sendBtn.disabled = false;
+    }
+
+    sendBtn.addEventListener('click', sendMessage);
+    userInput.addEventListener('keydown', (e) => {
+      if (e.key === 'Enter' && !e.shiftKey) {
+        e.preventDefault();
+        sendMessage();
+      }
+    });
+
+    codeEditor.addEventListener('input', updateContext);
+    updateContext();
+
+    // Auto-save chat history to localStorage
+    window.addEventListener('beforeunload', () => {
+      localStorage.setItem('copilot_chat_history', JSON.stringify(messages));
+    });
+
+    // Load chat history on start
+    const saved = localStorage.getItem('copilot_chat_history');
+    if (saved) {
+      try {
+        const loaded = JSON.parse(saved);
+        loaded.forEach(msg => {
+          if (msg.role !== 'system') {
+            addMessage(msg.role, msg.content, msg.role === 'assistant');
+          }
+        });
+      } catch {
+        // Ignore parse errors
+      }
+    }
+  </script>
+</body>
+
+</html>
