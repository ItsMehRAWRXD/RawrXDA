+<body>
+  <div class="sidebar">
+    <div class="sidebar-header">Copilot Chat</div>
+    <div class="chat-history" id="chatHistory">
+      <div class="message system">Chat started. Ask me anything about your code.</div>
+    </div>
+    <div class="chat-input">
+      <textarea id="userInput" placeholder="Ask Copilot..."></textarea>
+      <button id="sendBtn">Send</button>
+    </div>
+  </div>
