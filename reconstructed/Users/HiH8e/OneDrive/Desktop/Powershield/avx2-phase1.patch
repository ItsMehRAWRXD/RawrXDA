+bool GGUFLoader::UploadAllTensorsToVulkan() {
+    if (!vulkan_engine_) {
+        throw std::runtime_error("Vulkan engine not attached to GGUFLoader");
+    }
+    if (!is_open_) {
+        throw std::runtime_error("GGUF file is not open; call Open() before uploading tensors");
+    }
+
+    // For memory-mapped files, skip bulk upload to avoid OOM
+    // Tensors will be uploaded on-demand during inference
+    if (use_mmap_) {
+        std::cout << "Memory-mapped mode: skipping bulk tensor upload" << std::endl;
+        std::cout << "Tensors will be streamed to GPU on-demand during inference" << std::endl;
+        std::cout << "Total tensors available: " << tensors_.size() << std::endl;
+        return true;
+    }
+
+    std::vector<uint8_t> tensor_data;
+    
+    for (const auto& tensor : tensors_) {
+        // In dummy mode, create synthetic data instead of reading from file
+        if (use_dummy_mode_) {
+            // Generate simple test pattern: sequential floats 1.0, 2.0, 3.0...
+            size_t float_count = tensor.size_bytes / sizeof(float);
+            tensor_data.resize(tensor.size_bytes);
+            float* float_data = reinterpret_cast<float*>(tensor_data.data());
+            for (size_t i = 0; i < float_count; ++i) {
+                float_data[i] = static_cast<float>(i % 256) / 10.0f;  // Pattern 0.0-25.5
+            }
+            std::cout << "Generated synthetic data for: " << tensor.name << std::endl;
+        } else {
+            LoadTensorZone(tensor.name, tensor_data);
+        }
+        
+        VulkanTensor vt = vulkan_engine_->TransferGGUFTensor(tensor.name,
+                                                             tensor_data.data(),
+                                                             tensor_data.size());
+        vulkan_tensors_[tensor.name] = vt;
+        std::cout << "Transferred tensor to Vulkan: " << tensor.name
+                  << " (" << static_cast<double>(tensor_data.size()) / (1024.0 * 1024.0)
+                  << " MB)" << std::endl;
+    }
+    return true;
+}
+
+bool GGUFLoader::UploadTensorToVulkan(const std::string& tensor_name) {
+    if (!vulkan_engine_) {
+        throw std::runtime_error("Vulkan engine not attached");
+    }
+    
+    // Check if already uploaded
+    if (vulkan_tensors_.find(tensor_name) != vulkan_tensors_.end()) {
+        return true;  // Already uploaded
+    }
+    
+    std::vector<uint8_t> tensor_data;
+    
+    if (use_dummy_mode_) {
+        // Find tensor info
+        auto it = std::find_if(tensors_.begin(), tensors_.end(),
+                              [&tensor_name](const TensorInfo& t) { return t.name == tensor_name; });
+        if (it == tensors_.end()) {
+            std::cerr << "Tensor not found: " << tensor_name << std::endl;
+            return false;
+        }
+        
+        // Generate synthetic data
+        size_t float_count = it->size_bytes / sizeof(float);
+        tensor_data.resize(it->size_bytes);
+        float* float_data = reinterpret_cast<float*>(tensor_data.data());
+        for (size_t i = 0; i < float_count; ++i) {
+            float_data[i] = static_cast<float>(i % 256) / 10.0f;
+        }
+    } else {
+        // Load from file/mmap
+        LoadTensorZone(tensor_name, tensor_data);
+    }
+    
+    VulkanTensor vt = vulkan_engine_->TransferGGUFTensor(tensor_name,
+                                                         tensor_data.data(),
+                                                         tensor_data.size());
+    vulkan_tensors_[tensor_name] = vt;
+    
+    std::cout << "Uploaded tensor on-demand: " << tensor_name 
+              << " (" << (tensor_data.size() / (1024.0 * 1024.0)) << " MB)" << std::endl;
+    
+    return true;
+}
