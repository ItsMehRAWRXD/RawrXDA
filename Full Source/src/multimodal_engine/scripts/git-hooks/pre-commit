#!/usr/bin/env bash
# Run quantization discovery and fail the commit if MULTIMODAL_ENGINE_FOLDER_AUDIT.md changed
set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
PY="python"
$PY "$SCRIPT_DIR/../update_quant_types.py"
# Check for changes
if ! git diff --quiet -- "src/multimodal_engine/MULTIMODAL_ENGINE_FOLDER_AUDIT.md"; then
    echo "Error: MULTIMODAL_ENGINE_FOLDER_AUDIT.md changed. Please add it to the commit (it is auto-generated by scripts/update_quant_types.py)."
    git --no-pager diff -- "src/multimodal_engine/MULTIMODAL_ENGINE_FOLDER_AUDIT.md"
    exit 1
fi
