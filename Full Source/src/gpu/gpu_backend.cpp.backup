#include "gpu_backend.h"
#include "../gpu_masm/gpu_masm_bridge.h"
#include <iostream>

// Static member initialization
GpuBackend::Backend GpuBackend::s_currentBackend = GpuBackend::CPU;
bool GpuBackend::s_initialized = false;

bool GpuBackend::initialize(Backend backend)
{
    if (s_initialized && s_currentBackend == backend) {
        std::cerr << "[GPU] backend already initialized: " << backendName(backend) << "\n";
        return true;
    }

    // Initialize GPU detection system first
    if (GPU_Initialize() != 0) {
        std::cerr << "[GPU] Failed to initialize GPU detection system\n";
        return initializeCpu();
    }

    // Detect available GPUs
    int32_t gpuCount = GPU_Detect();
    std::cerr << "[GPU] Detected " << gpuCount << " GPU(s)\n";

    // Map our backend enum to MASM backend codes (0=CPU, 1=Vulkan, 2=CUDA, 3=ROCm)
    int64_t masmBackend = 0;
    switch (backend) {
    case Vulkan:
        masmBackend = 1;
        break;
    case CUDA:
        masmBackend = 2;
        break;
    case CPU:
        masmBackend = 0;
        break;
    }

    // Call MASM backend initialization
    int64_t result = InitializeGPUBackend(masmBackend);
    
    if (result == 0) {
        // Success - update state
        s_currentBackend = backend;
        s_initialized = true;
bool GpuBackend::isBackendAvailable(Backend backend)
{
    // Initialize GPU detection if not already done
    static bool detectionInitialized = false;
    if (!detectionInitialized) {
        GPU_Initialize();
        GPU_Detect();
        detectionInitialized = true;
    }

    int32_t gpuCount = GPU_GetDeviceCount();
    
    switch (backend) {
    case Vulkan:
        // Check if any GPU is available (Vulkan supports NVIDIA, AMD, Intel)
        std::cerr << "[GPU] Checking Vulkan availability...\n";
        return gpuCount > 0;
        
    case CUDA:
        // Check for NVIDIA GPU specifically
        std::cerr << "[GPU] Checking CUDA availability...\n";
        for (int32_t i = 0; i < gpuCount; i++) {
            GpuDeviceInfo devInfo;
            if (GPU_GetDevice(i, &devInfo) == 0) {
                // NVIDIA vendor ID is 0x10DE
                if (devInfo.vendorId == 0x10DE) {
                    return true;
                }
            }
        }
bool GpuBackend::initializeWithFallback()
{
    // Try Vulkan first (most compatible)
    if (isBackendAvailable(Vulkan)) {
        std::cerr << "[GPU] Attempting Vulkan initialization...\n";
        if (initialize(Vulkan)) {
            return true;
        }
    }

    // Fall back to CUDA (NVIDIA only)
    if (isBackendAvailable(CUDA)) {
        std::cerr << "[GPU] Attempting CUDA initialization...\n";
        if (initialize(CUDA)) {
            return true;
        }
    }

    // Final fallback to CPU
    std::cerr << "[GPU] No GPU backends available, falling back to CPU (slower performance)\n";
    return initialize(CPU);
}       return false;  // Assume not available for this example
    case CPU:
bool GpuBackend::initializeVulkan()
{
    std::cerr << "[GPU] Attempting to initialize Vulkan...\n";
    
    // Create Vulkan instance through MASM
    int64_t result = VK_CreateInstance();
    if (result != 0) {
        std::cerr << "[GPU] Failed to create Vulkan instance\n";
        return false;
    }

    // Enumerate physical devices
    int32_t deviceCount = VK_EnumeratePhysicalDevices();
    if (deviceCount == 0) {
        std::cerr << "[GPU] No Vulkan-compatible devices found\n";
        VK_DestroyInstance();
        return false;
    }

    std::cerr << "[GPU] Vulkan initialized successfully with " << deviceCount << " device(s)\n";
    return true;
}

bool GpuBackend::initializeCuda()
{
    std::cerr << "[GPU] Attempting to initialize CUDA...\n";
    
    // Initialize CUDA runtime through MASM
    int64_t result = CUDA_Initialize();
    if (result != 0) {
        std::cerr << "[GPU] Failed to initialize CUDA runtime\n";
        return false;
    }

    // Get CUDA device count
    int32_t deviceCount = CUDA_GetDeviceCount();
    if (deviceCount == 0) {
        std::cerr << "[GPU] No CUDA-compatible devices found\n";
        return false;
    }

    // Set device 0 as active
    result = CUDA_SetDevice(0);
    if (result != 0) {
        std::cerr << "[GPU] Failed to set CUDA device\n";
        return false;
    }

    std::cerr << "[GPU] CUDA initialized successfully with " << deviceCount << " device(s)\n";
    return true;
}       s_currentBackend = Vulkan;
        s_initialized = true;
        std::cerr << "[GPU] GPU Backend initialized with Vulkan\n";
        return true;
    }

    // Fall back to CUDA
    if (isBackendAvailable(CUDA) && initializeCuda()) {
        s_currentBackend = CUDA;
        s_initialized = true;
        std::cerr << "[GPU] GPU Backend initialized with CUDA\n";
        return true;
    }

    // Final fallback to CPU
    std::cerr << "[GPU] No GPU backends available, falling back to CPU (slower performance)\n";
    return initializeCpu();
}

bool GpuBackend::initializeVulkan()
{
    std::cerr << "[GPU] Attempting to initialize Vulkan...\n";
    
    // In a real implementation, this would:
    // 1. Call ggml_vk_init()
    // 2. Return true on success
    // 3. Return false on failure (no Vulkan support, etc.)
    
    // For this example, we'll simulate success
    std::cerr << "[GPU] Vulkan initialized successfully\n";
    return true;
}

bool GpuBackend::initializeCuda()
{
    std::cerr << "[GPU] Attempting to initialize CUDA...\n";
    
    // In a real implementation, this would check for CUDA support
    // For this example, we'll simulate failure
    std::cerr << "[GPU] CUDA not available\n";
    return false;
}

bool GpuBackend::initializeCpu()
{
    std::cerr << "[GPU] Initializing CPU backend...\n";
    s_currentBackend = CPU;
    s_initialized = true;
    std::cerr << "[GPU] CPU backend ready (models will run on CPU - slower performance)\n";
    return true;
}