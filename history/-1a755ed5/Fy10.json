{
  "_comment": "RawrXD Default Configuration - Auto-detected environment",
  "version": "1.0.0",
  "environment": "development",
  
  "paths": {
    "model_path": "./models",
    "config_path": "./config",
    "log_path": "./logs",
    "cache_path": "./cache"
  },
  
  "api": {
    "endpoint": "http://localhost:11434",
    "api_key": "",
    "timeout_ms": 30000,
    "retry_count": 3,
    "retry_delay_ms": 1000
  },
  
  "model": {
    "default_model": "llama3.2:3b",
    "max_model_size_bytes": 1073741824,
    "model_cache_size": 512,
    "auto_download": true,
    "quantization_level": "q4_0"
  },
  
  "logging": {
    "log_level": "INFO",
    "log_to_file": true,
    "log_to_console": true,
    "log_file_max_size_mb": 100,
    "log_file_retention_days": 7,
    "structured_logging": true
  },
  
  "performance": {
    "thread_pool_size": 4,
    "max_concurrent_requests": 10,
    "request_timeout_ms": 30000,
    "worker_threads": 4,
    "io_threads": 2
  },
  
  "features": {
    "gpu_acceleration": false,
    "distributed_trace": false,
    "advanced_metrics": true,
    "hotpatch_dynamic": false,
    "quantum_ops": false,
    "experimental_models": false,
    "debug_mode": false,
    "auto_update": false
  },
  
  "ui": {
    "theme": "dark",
    "font_family": "Consolas",
    "font_size": 12,
    "line_numbers": true,
    "minimap": true,
    "word_wrap": false
  },
  
  "security": {
    "enable_api_key_validation": false,
    "enable_tls": false,
    "enable_cors": true,
    "allowed_origins": ["http://localhost:*"]
  }
}
