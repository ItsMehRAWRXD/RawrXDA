; =============================================================================
; DiskKernel.def — Module definition for RawrXD_DiskKernel.dll + AgentToolExecutor
; =============================================================================
LIBRARY RawrXD_DiskKernel
EXPORTS
    ; === DiskKernel Core ===
    DiskKernel_Init                 @1
    DiskKernel_Shutdown             @2
    DiskKernel_EnumerateDrives      @3
    DiskKernel_DetectPartitions     @4
    DiskKernel_AsyncReadSectors     @5
    DiskKernel_GetAsyncStatus       @6

    ; === Universal Sector I/O ===
    DK_ReadSectors                  @10
    DK_ScsiReadSectors              @11
    DK_AtaReadSectors               @12

    ; === Partition Parsing ===
    ParseGPT                        @20
    ParseMBR                        @21
    DetectFileSystem                @22

    ; === NTFS Driver ===
    NTFS_MountVolume                @30
    NTFS_ReadMftRecord              @31

    ; === FAT32 Driver ===
    FAT32_MountVolume               @40
    FAT32_ReadCluster               @41
    FAT32_GetNextCluster            @42

    ; === IDE File Explorer API ===
    DiskExplorer_Init               @50
    DiskExplorer_Shutdown           @51
    DiskExplorer_ScanDrives         @52
    DiskExplorer_OpenDrive          @53
    DiskExplorer_DetectPartitions   @54
    DiskExplorer_ReadSector         @55
    DiskExplorer_GetDriveCount      @56
    DiskExplorer_GetDriveInfo       @57

    ; === DiskRecoveryAgent ===
    DiskRecovery_FindDrive          @60
    DiskRecovery_Init               @61
    DiskRecovery_ExtractKey         @62
    DiskRecovery_Run                @63
    DiskRecovery_Abort              @64
    DiskRecovery_Cleanup            @65
    DiskRecovery_GetStats           @66

    ; === AgentToolExecutor ===
    AgentTool_DetectMode            @70
    AgentTool_Launch                @71
    AgentTool_Abort                 @72
    AgentTool_GetStatus             @73
    AgentTool_GetStats              @74
    AgentTool_WaitForCompletion     @75
    AgentTool_Cleanup               @76
    ; === NanoDisk Bridge (Async Tensor Loader) ===
    NanoDisk_Init                   @80
    NanoDisk_Shutdown               @81
    NanoDisk_LoadQuantizedTensor    @82
    NanoDisk_Callback               @83
    NanoDisk_GetJobStatus           @84
    NanoDisk_GetJobResult           @85
    NanoDisk_AbortJob               @86
    AgentTool_QuantizeModel         @87