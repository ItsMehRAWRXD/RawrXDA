{
  "name": "rawrxd-lsp-client",
  "displayName": "RawrXD — Hotpatch & GGUF IDE",
  "description": "VS Code client for the RawrXD LSP server. Provides hotpatch management, GGUF model diagnostics, and ASM-accelerated workspace symbols via 9 custom JSON-RPC methods.",
  "version": "1.0.0",
  "publisher": "ItsMehRAWRXD",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "rawrxd",
    "hotpatch",
    "gguf",
    "llm",
    "masm",
    "reverse-engineering"
  ],
  "activationEvents": [
    "workspaceContains:**/*.gguf",
    "workspaceContains:**/*.asm",
    "onLanguage:asm",
    "onLanguage:masm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rawrxd.hotpatch.list",
        "title": "RawrXD: List Active Hotpatches",
        "category": "RawrXD",
        "icon": "$(list-unordered)"
      },
      {
        "command": "rawrxd.hotpatch.apply",
        "title": "RawrXD: Apply Hotpatch",
        "category": "RawrXD",
        "icon": "$(play)"
      },
      {
        "command": "rawrxd.hotpatch.revert",
        "title": "RawrXD: Revert Hotpatch",
        "category": "RawrXD",
        "icon": "$(discard)"
      },
      {
        "command": "rawrxd.hotpatch.diagnostics",
        "title": "RawrXD: Hotpatch Diagnostics",
        "category": "RawrXD",
        "icon": "$(warning)"
      },
      {
        "command": "rawrxd.gguf.modelInfo",
        "title": "RawrXD: GGUF Model Info",
        "category": "RawrXD",
        "icon": "$(info)"
      },
      {
        "command": "rawrxd.gguf.tensorList",
        "title": "RawrXD: GGUF Tensor List",
        "category": "RawrXD",
        "icon": "$(symbol-array)"
      },
      {
        "command": "rawrxd.gguf.validate",
        "title": "RawrXD: Validate GGUF File",
        "category": "RawrXD",
        "icon": "$(check)"
      },
      {
        "command": "rawrxd.workspace.symbols",
        "title": "RawrXD: Workspace Symbols",
        "category": "RawrXD",
        "icon": "$(symbol-method)"
      },
      {
        "command": "rawrxd.workspace.stats",
        "title": "RawrXD: Workspace Stats",
        "category": "RawrXD",
        "icon": "$(dashboard)"
      },
      {
        "command": "rawrxd.hotpatch.refreshView",
        "title": "Refresh",
        "category": "RawrXD",
        "icon": "$(refresh)"
      },
      {
        "command": "rawrxd.gguf.refreshView",
        "title": "Refresh",
        "category": "RawrXD",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rawrxd-sidebar",
          "title": "RawrXD",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "rawrxd-sidebar": [
        {
          "id": "rawrxd.hotpatchView",
          "name": "Hotpatches",
          "contextualTitle": "Active Hotpatches"
        },
        {
          "id": "rawrxd.ggufView",
          "name": "GGUF Models",
          "contextualTitle": "Loaded GGUF Models"
        },
        {
          "id": "rawrxd.statsView",
          "name": "Statistics",
          "contextualTitle": "Hotpatch Manager Stats"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "rawrxd.hotpatch.refreshView",
          "when": "view == rawrxd.hotpatchView",
          "group": "navigation"
        },
        {
          "command": "rawrxd.gguf.refreshView",
          "when": "view == rawrxd.ggufView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "rawrxd.hotpatch.revert",
          "when": "view == rawrxd.hotpatchView && viewItem == activePatch",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "RawrXD LSP",
      "properties": {
        "rawrxd.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the RawrXD LSP server binary (RawrXD_IDE_unified.exe). If empty, searches PATH."
        },
        "rawrxd.server.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["--lsp"],
          "description": "Arguments passed to the RawrXD LSP server."
        },
        "rawrxd.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace communication between VS Code and the RawrXD LSP server."
        },
        "rawrxd.diagnostics.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh diagnostics when hotpatch events occur."
        },
        "rawrxd.diagnostics.showInline": {
          "type": "boolean",
          "default": true,
          "description": "Show hotpatch diagnostics inline in the editor."
        },
        "rawrxd.gguf.autoValidate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically validate GGUF files when opened or changed."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0"
  }
}
