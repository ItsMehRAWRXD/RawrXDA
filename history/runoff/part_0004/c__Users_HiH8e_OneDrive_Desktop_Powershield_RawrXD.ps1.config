<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <!-- Force .NET 8 to enable WebView2 compatibility -->
    <!-- .NET 9+ has ContextMenu type conflicts with WebView2 -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <runtime>
    <!-- Roll forward to .NET 8 if available, prevent .NET 9 loading -->
    <AppContextSwitchOverrides value="Switch.System.Windows.Forms.UseLegacyContextMenuStripSourceControlValue=false"/>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Prefer .NET 8.0 assemblies for WebView2 compatibility -->
      <dependentAssembly>
        <assemblyIdentity name="System.Windows.Forms" publicKeyToken="b77a5c561934e089" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-8.0.0.0" newVersion="8.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
