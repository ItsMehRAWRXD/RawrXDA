# Copy this to .env and fill values
CLIENT_ID=your_github_oauth_app_client_id
CLIENT_SECRET=your_github_oauth_app_client_secret
# Redirect URL must match your GitHub OAuth app (e.g. http://localhost:3000/callback)
REDIRECT_URI=http://localhost:3000/callback
# Encryption key (use a long random string, 32+ chars). Used to encrypt tokens on disk
ENCRYPTION_KEY=replace_with_a_strong_secret
# Optional: server port
PORT=3000
# Optional: scopes (adjust if Copilot requires special scopes)
SCOPES=repo,read:user
