{
  "server": {
    "port": 8443,
    "logRequests": true,
    "metricsEnabled": true,
    "maxConnections": 1000
  },
  "tls": {
    "enabled": true,
    "certificatePath": "/etc/rawrxd/certs/server.crt",
    "privateKeyPath": "/etc/rawrxd/certs/server.key",
    "caChainPath": "/etc/rawrxd/certs/ca-chain.crt",
    "minTLSVersion": 12,
    "cipherSuites": [
      "ECDHE-RSA-AES256-GCM-SHA384",
      "ECDHE-RSA-AES128-GCM-SHA256",
      "DHE-RSA-AES256-GCM-SHA384",
      "DHE-RSA-AES128-GCM-SHA256",
      "ECDHE-ECDSA-AES256-GCM-SHA384",
      "ECDHE-ECDSA-AES128-GCM-SHA256"
    ]
  },
  "oidc": {
    "enabled": true,
    "issuerUrl": "https://auth.example.com",
    "clientId": "rawrxd-app",
    "clientSecret": "${OIDC_CLIENT_SECRET}",
    "jwksUrl": "https://auth.example.com/.well-known/jwks.json",
    "audience": "https://api.example.com",
    "tokenExpirationSeconds": 3600,
    "validateIssuer": true,
    "validateAudience": true,
    "scopes": [
      "openid",
      "profile",
      "email"
    ]
  },
  "authentication": {
    "tokenCacheSizeMax": 1000,
    "tokenCacheCleanupIntervalSeconds": 300,
    "allowRefreshTokens": true,
    "refreshTokenExpirationSeconds": 2592000,
    "requireStrictSSL": true
  },
  "rateLimit": {
    "enabled": true,
    "requestsPerMinute": 1000,
    "requestsPerSecond": 100,
    "burstSize": 150,
    "enablePerIPLimiting": true
  },
  "restEndpoints": [
    {
      "method": "GET",
      "path": "/health",
      "requiresAuth": false,
      "description": "Health check endpoint"
    },
    {
      "method": "GET",
      "path": "/status",
      "requiresAuth": true,
      "description": "Server status endpoint"
    },
    {
      "method": "GET",
      "path": "/metrics",
      "requiresAuth": true,
      "description": "Prometheus metrics endpoint"
    },
    {
      "method": "POST",
      "path": "/api/users",
      "requiresAuth": true,
      "description": "Create new user"
    },
    {
      "method": "GET",
      "path": "/api/users/*",
      "requiresAuth": true,
      "description": "Get user by ID"
    },
    {
      "method": "PUT",
      "path": "/api/users/*",
      "requiresAuth": true,
      "description": "Update user"
    },
    {
      "method": "DELETE",
      "path": "/api/users/*",
      "requiresAuth": true,
      "description": "Delete user"
    }
  ],
  "graphql": {
    "enabled": true,
    "endpoint": "/graphql",
    "requiresAuth": true,
    "introspectionEnabled": true,
    "maxQueryDepth": 10,
    "maxQueryComplexity": 100,
    "queryTimeoutMs": 5000
  },
  "securityHeaders": {
    "content-security-policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'",
    "x-content-type-options": "nosniff",
    "x-frame-options": "DENY",
    "x-xss-protection": "1; mode=block",
    "strict-transport-security": "max-age=31536000; includeSubDomains; preload",
    "referrer-policy": "strict-origin-when-cross-origin",
    "permissions-policy": "geolocation=(), microphone=(), camera=()"
  },
  "cors": {
    "enabled": true,
    "allowedOrigins": [
      "https://app.example.com",
      "https://dashboard.example.com"
    ],
    "allowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "allowedHeaders": [
      "Content-Type",
      "Authorization"
    ],
    "exposedHeaders": [
      "X-Request-ID",
      "X-RateLimit-Remaining"
    ],
    "allowCredentials": true,
    "maxAge": 3600
  },
  "logging": {
    "level": "INFO",
    "format": "json",
    "outputFile": "/var/log/rawrxd/api-server.log",
    "maxFileSizeBytes": 10485760,
    "maxBackupFiles": 5,
    "includeSensitiveData": false
  },
  "monitoring": {
    "metricsEnabled": true,
    "metricsPort": 9090,
    "metricsPath": "/metrics",
    "tracingEnabled": true,
    "tracingServiceName": "rawrxd-api",
    "samplingRate": 0.1
  },
  "database": {
    "enabled": true,
    "type": "postgresql",
    "host": "db.example.com",
    "port": 5432,
    "database": "rawrxd",
    "username": "${DB_USERNAME}",
    "password": "${DB_PASSWORD}",
    "maxConnections": 20,
    "connectionTimeoutSeconds": 5,
    "sslMode": "require"
  },
  "cache": {
    "enabled": true,
    "type": "redis",
    "host": "cache.example.com",
    "port": 6379,
    "password": "${REDIS_PASSWORD}",
    "ttlSeconds": 3600,
    "maxEntries": 10000
  },
  "features": {
    "enableApiDocumentation": true,
    "enableGraphiQL": true,
    "enableReflection": true,
    "enableBatchRequests": true,
    "enableWebSockets": true,
    "enableSubscriptions": true
  }
}