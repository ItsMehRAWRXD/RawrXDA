{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Wire (Production Toolchain)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/src/agent/Build-And-Wire.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Start Local Copilot",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/start_copilot.ps1",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}