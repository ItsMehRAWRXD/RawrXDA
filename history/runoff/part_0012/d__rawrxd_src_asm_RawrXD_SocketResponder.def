; =============================================================================
; RawrXD_SocketResponder.def — IOCP HTTP Server DLL Exports
; =============================================================================
LIBRARY RawrXD_SocketResponder
EXPORTS
    ; === Server Lifecycle ===
    RawrXD_StartSocketServer        @1
    RawrXD_StopSocketServer         @2
    RawrXD_IsServerRunning          @3

    ; === Cache Updates ===
    RawrXD_UpdateHealthCache        @10
    RawrXD_UpdateStatusCache        @11
    RawrXD_UpdateModelsCache        @12

    ; === Statistics ===
    RawrXD_GetServerStats           @20
