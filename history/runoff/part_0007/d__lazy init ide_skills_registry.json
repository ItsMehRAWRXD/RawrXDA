{
  "schema_version": "2.0",
  "tools": [
    {
      "name": "CodeEdit",
      "description": "Atomic file modification with rollback capability",
      "category": "file_system",
      "danger_level": 3,
      "params": {
        "target": {
          "type": "string",
          "required": true,
          "pattern": "^[a-zA-Z0-9_\\\\/.]+$"
        },
        "line_start": {
          "type": "integer",
          "min": 1
        },
        "line_end": {
          "type": "integer",
          "min": 1
        },
        "replacement": {
          "type": "string",
          "max_length": 65536
        },
        "create_backup": {
          "type": "boolean",
          "default": true
        }
      },
      "sandbox": {
        "allow_paths": [
          "${PROJECT_ROOT}",
          "${TEMP}"
        ],
        "deny_patterns": [
          "*.dll",
          "*.exe",
          ".*"
        ],
        "max_file_size": 10485760
      },
      "validation": "strict"
    },
    {
      "name": "BuildProject",
      "description": "Execute build with error capture",
      "category": "build",
      "danger_level": 2,
      "params": {
        "config": {
          "type": "string",
          "enum": [
            "Debug",
            "Release"
          ],
          "default": "Release"
        },
        "target": {
          "type": "string",
          "default": "all"
        },
        "parallel_jobs": {
          "type": "integer",
          "min": 1,
          "max": 32,
          "default": 8
        }
      },
      "sandbox": {
        "timeout_ms": 300000,
        "memory_limit_mb": 8192,
        "capture_output": true
      }
    },
    {
      "name": "StaticAnalysis",
      "description": "Run clang-tidy and custom linters",
      "category": "analysis",
      "danger_level": 1,
      "params": {
        "files": {
          "type": "array",
          "items": "string"
        },
        "checks": {
          "type": "array",
          "items": "string",
          "default": [
            "cppcoreguidelines-*",
            "modernize-*"
          ]
        }
      }
    },
    {
      "name": "GitOperation",
      "description": "Safe git commands (no force push)",
      "category": "vcs",
      "danger_level": 4,
      "params": {
        "command": {
          "type": "string",
          "enum": [
            "status",
            "diff",
            "commit",
            "branch",
            "checkout",
            "pull"
          ]
        },
        "args": {
          "type": "array",
          "items": "string"
        }
      },
      "sandbox": {
        "deny_commands": [
          "push",
          "reset",
          "rebase",
          "clean"
        ],
        "require_confirmation": true
      }
    }
  ],
  "hot_reload": {
    "enabled": true,
    "watch_path": "./skills",
    "debounce_ms": 500
  }
}