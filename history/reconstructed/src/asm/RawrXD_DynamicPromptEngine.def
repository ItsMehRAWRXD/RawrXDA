; =============================================================================
; RawrXD_DynamicPromptEngine.def — DLL Exports for Engine Interop
; =============================================================================
; Used by Unity (C# P/Invoke), Unreal Engine (extern "C" FFI), and
; any other consumer that loads the DLL at runtime.
;
; Ordinal ranges:
;   @1-@9    Core ASM exports
;   @10-@19  C glue wrappers (engine-friendly)
; =============================================================================

LIBRARY RawrXD_DynamicPromptEngine

EXPORTS
    ; === Core ASM Kernel Exports ===
    PromptGen_AnalyzeContext        @1
    PromptGen_BuildCritic           @2
    PromptGen_BuildAuditor          @3
    PromptGen_Interpolate           @4
    PromptGen_GetTemplate           @5
    PromptGen_ForceMode             @6

    ; === C Glue — Engine-Friendly Wrappers ===
    PromptGen_ClassifyToStruct      @10
    PromptGen_GetVersion            @11
    PromptGen_GetModeName           @12
