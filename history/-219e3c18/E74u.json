{
  "name": "cyberforge-advanced-security-suite",
  "version": "2.0.0",
  "description": "Advanced polymorphic security research platform with quantum-resistant encryption",
  "type": "module",
  "main": "core/main.js",
  "scripts": {
    "start": "node core/main.js",
    "dev": "node --watch core/main.js --dev",
    "build": "npm run build:core && npm run build:gui",
    "build:core": "node build/compile-core.js",
    "build:gui": "node build/compile-gui.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node test/unit-tests.js",
    "test:integration": "node test/integration-tests.js",
    "security-scan": "node tools/security-scanner.js",
    "generate-payload": "node tools/payload-generator.js",
    "cross-compile": "node tools/cross-compiler.js",
    "encrypt": "node tools/advanced-encryptor.js",
    "polymorphic-build": "node engines/polymorphic/builder.js",
    "docs": "node build/generate-docs.js",
    "clean": "node build/clean.js",
    "setup": "node setup/initialize.js",
    "payload": "node payload-cli.js",
    "payload-build": "node payload-cli.js build",
    "payload-research": "node payload-cli.js research",
    "payload-targets": "node payload-cli.js list-targets",
    "file-types": "node engines/file-types/file-type-manager.js",
    "research-framework": "node engines/research/payload-research-framework.js"
  },
  "keywords": [
    "cybersecurity",
    "encryption",
    "polymorphic",
    "red-team",
    "security-research",
    "quantum-resistant",
    "penetration-testing",
    "advanced-encryption"
  ],
  "author": "CyberForge Security Research Team",
  "license": "Research-Only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyberforge/advanced-security-suite"
  },
  "bugs": {
    "url": "https://github.com/cyberforge/advanced-security-suite/issues"
  },
  "homepage": "https://cyberforge.security",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "node-fetch": "^3.3.2",
    "crypto-js": "^4.2.0",
    "node-forge": "^1.3.1",
    "elliptic": "^6.5.4",
    "argon2": "^0.31.0",
    "blake3": "^2.1.7",
    "chacha": "^2.1.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.14.0",
    "sqlite3": "^5.1.6",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.11",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "rate-limiter-flexible": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "typescript": "^5.2.0",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0"
  },
  "cyberforge": {
    "features": {
      "polymorphic_generation": true,
      "quantum_resistant_crypto": true,
      "cross_platform_builds": true,
      "anti_detection": true,
      "gui_interface": true,
      "api_server": true,
      "database_storage": true,
      "real_time_monitoring": true
    },
    "platforms": {
      "windows": [
        "x86",
        "x64",
        "arm64"
      ],
      "linux": [
        "x86",
        "x64",
        "arm",
        "arm64",
        "mips"
      ],
      "macos": [
        "intel",
        "apple_silicon"
      ],
      "mobile": [
        "android"
      ]
    },
    "encryption": {
      "quantum_resistant": [
        "Kyber-1024",
        "SPHINCS+",
        "Crystal-Dilithium"
      ],
      "symmetric": [
        "AES-256-GCM",
        "ChaCha20-Poly1305",
        "Camellia-256",
        "ARIA-256"
      ],
      "asymmetric": [
        "ECC-P521",
        "RSA-4096",
        "X25519",
        "Ed25519"
      ],
      "hashing": [
        "Blake3",
        "SHA3-512",
        "Argon2id",
        "PBKDF2"
      ],
      "custom": [
        "Polymorphic-XOR",
        "Morphing-Stream",
        "Dynamic-Key"
      ]
    }
  }
}