{
  "manifest_version": 3,
  "name": "Private AI Co Pilot",
  "version": "1.0",
  "description": "A browser extension for interacting with a custom Ollama service.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:5000/",
    "https://localhost:5000/",
    "http://127.0.0.1:5000/",
    "https://127.0.0.1:5000/"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
