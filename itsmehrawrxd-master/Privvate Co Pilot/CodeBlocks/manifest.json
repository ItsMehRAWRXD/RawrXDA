{
  "manifest_version": 3,
  "name": "Secure AI Assistant",
  "version": "1.0",
  "description": "Control your browser with ChatGPT commands.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
