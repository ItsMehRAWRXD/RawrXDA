{
  "name": "rawrz-botnet-control-panel",
  "version": "1.0.0",
  "description": "Professional Botnet Management & Data Extraction Platform",
  "main": "test-botnet-panel-secure.js",
  "scripts": {
    "start": "node test-botnet-panel-secure.js",
    "dev": "nodemon test-botnet-panel-secure.js",
    "test": "node test-bot-client.js",
    "audit": "npm audit --audit-level=moderate",
    "security-check": "npm audit && npm outdated",
    "build": "echo 'Production build complete'",
    "deploy": "pm2 start test-botnet-panel-secure.js --name rawrz-panel"
  },
  "keywords": [
    "botnet",
    "control-panel",
    "data-extraction",
    "security",
    "monitoring",
    "cryptocurrency",
    "stealer",
    "keylogger",
    "remote-access"
  ],
  "author": "RawrZ Security Platform",
  "license": "PROPRIETARY",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "crypto": "^1.0.1",
    "fs-extra": "^11.1.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0",
    "eslint": "^8.55.0",
    "eslint-config-security": "^0.2.0",
    "eslint-plugin-security": "^1.7.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "private"
  },
  "private": true,
  "security": {
    "audit": {
      "level": "moderate"
    }
  },
  "config": {
    "port": 3000,
    "websocket_port": 3001,
    "max_bots": 10000,
    "rate_limit": {
      "windowMs": 900000,
      "max": 100
    }
  }
}
