class CodeGenerator {
    function generate(ast: ASTNode, semantic_info: SemanticInfo) -> string {
        ; Generate x64 assembly code
        var code = "section .text\n" +
                  "global _start\n" +
                  "_start:\n" +
                  "    mov rax, 60\n" +
                  "    mov rdi, 0\n" +
                  "    syscall\n"
        return code
    }
}

; Data structures
struct Token {
    type: TokenType,
    value: string,
    line: uint,
    column: uint
}

enum TokenType {
    IDENTIFIER, NUMBER, STRING, KEYWORD, OPERATOR, DELIMITER, EOF
}

struct ASTNode {
    type: NodeType,
    value: string,
    children: Array<ASTNode>
}

enum NodeType {
    PROGRAM, FUNCTION, STATEMENT, EXPRESSION, LITERAL
}

struct SemanticInfo {
    valid: bool,
    error: string
}

