{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-postgres-host;Database=ai_desktop_helper;Username=your-username;Password=your-password"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-jwt-key-here-must-be-at-least-256-bits",
    "Issuer": "AIDesktopHelper",
    "Audience": "AIDesktopHelper-Users",
    "ExpiryMinutes": 60
  },
  "OpenAI": {
    "ApiKey": "your-openai-api-key-here"
  },
  "DigitalOcean": {
    "Spaces": {
      "AccessKey": "your-spaces-access-key",
      "SecretKey": "your-spaces-secret-key",
      "Endpoint": "https://nyc3.digitaloceanspaces.com",
      "BucketName": "your-business-files",
      "Region": "nyc3"
    }
  },
  "Encryption": {
    "AES256_Key": "your-aes-256-key-base64-encoded",
    "Camellia256_Key": "your-camellia-256-key-base64-encoded"
  },
  "RateLimiting": {
    "RequestsPerMinute": 100,
    "BurstLimit": 20
  },
  "Security": {
    "MaxFileSize": 104857600,
    "AllowedFileTypes": [".cs", ".js", ".ts", ".py", ".java", ".cpp", ".c", ".h", ".hpp", ".txt", ".json", ".xml", ".yaml", ".yml"],
    "RequireHttps": true,
    "EnableCors": true
  }
}