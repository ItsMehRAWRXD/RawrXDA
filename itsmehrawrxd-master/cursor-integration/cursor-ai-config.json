{
  "name": "Airtight AI Integration",
  "version": "1.0.0",
  "description": "Complete AI integration for Cursor IDE with unlimited access to all models",
  "type": "ai-assistant",
  "config": {
    "backend": {
      "url": "http://localhost:3001",
      "websocket": "ws://localhost:3002",
      "timeout": 30000
    },
    "models": {
      "default": "gpt-5",
      "available": [
        {
          "id": "gpt-5",
          "name": "GPT-5 (OpenAI)",
          "provider": "openai",
          "capabilities": ["code_generation", "code_review", "debugging", "refactoring", "documentation"],
          "maxTokens": 100000,
          "temperature": 0.1
        },
        {
          "id": "claude-3.5",
          "name": "Claude 3.5 Sonnet",
          "provider": "claude",
          "capabilities": ["code_analysis", "architecture_design", "testing", "optimization"],
          "maxTokens": 200000,
          "temperature": 0.1
        },
        {
          "id": "gemini-2.0",
          "name": "Gemini 2.0",
          "provider": "gemini",
          "capabilities": ["multimodal_coding", "visual_analysis", "code_explanation"],
          "maxTokens": 100000,
          "temperature": 0.1
        },
        {
          "id": "copilot",
          "name": "GitHub Copilot Pro",
          "provider": "copilot",
          "capabilities": ["autocomplete", "code_suggestions", "pattern_recognition"],
          "maxTokens": 50000,
          "temperature": 0.0
        }
      ]
    },
    "features": {
      "codeGeneration": true,
      "codeReview": true,
      "debugging": true,
      "refactoring": true,
      "explanation": true,
      "testGeneration": true,
      "optimization": true,
      "realTimeSuggestions": true,
      "contextAware": true
    },
    "ui": {
      "showStatusBar": true,
      "showToolWindow": true,
      "enableNotifications": true,
      "theme": "auto"
    }
  },
  "commands": [
    {
      "id": "start-session",
      "name": "Start AI Session",
      "description": "Start a new AI coding session",
      "action": "startSession"
    },
    {
      "id": "generate-code",
      "name": "Generate Code",
      "description": "Generate code using AI",
      "action": "generateCode",
      "context": "editor"
    },
    {
      "id": "code-review",
      "name": "Code Review",
      "description": "Review code with AI",
      "action": "codeReview",
      "context": "editor"
    },
    {
      "id": "debug-code",
      "name": "Debug Code",
      "description": "Debug code with AI assistance",
      "action": "debugCode",
      "context": "editor"
    },
    {
      "id": "refactor-code",
      "name": "Refactor Code",
      "description": "Refactor code using AI",
      "action": "refactorCode",
      "context": "editor"
    },
    {
      "id": "explain-code",
      "name": "Explain Code",
      "description": "Explain code with AI",
      "action": "explainCode",
      "context": "editor"
    },
    {
      "id": "generate-tests",
      "name": "Generate Tests",
      "description": "Generate tests using AI",
      "action": "generateTests",
      "context": "editor"
    },
    {
      "id": "optimize-code",
      "name": "Optimize Code",
      "description": "Optimize code using AI",
      "action": "optimizeCode",
      "context": "editor"
    }
  ],
  "keybindings": [
    {
      "command": "start-session",
      "key": "ctrl+shift+a",
      "when": "!aiSessionActive"
    },
    {
      "command": "generate-code",
      "key": "ctrl+shift+g",
      "when": "editorTextFocus"
    },
    {
      "command": "code-review",
      "key": "ctrl+shift+r",
      "when": "editorTextFocus"
    },
    {
      "command": "explain-code",
      "key": "ctrl+shift+e",
      "when": "editorTextFocus"
    }
  ],
  "settings": {
    "ai.defaultModel": {
      "type": "string",
      "default": "gpt-5",
      "description": "Default AI model to use"
    },
    "ai.backendUrl": {
      "type": "string",
      "default": "http://localhost:3001",
      "description": "Backend server URL"
    },
    "ai.websocketUrl": {
      "type": "string",
      "default": "ws://localhost:3002",
      "description": "WebSocket server URL"
    },
    "ai.autoStart": {
      "type": "boolean",
      "default": true,
      "description": "Automatically start AI session on IDE launch"
    },
    "ai.showSuggestions": {
      "type": "boolean",
      "default": true,
      "description": "Show AI suggestions in editor"
    },
    "ai.maxSuggestions": {
      "type": "number",
      "default": 5,
      "description": "Maximum number of suggestions to show"
    }
  }
}
