{
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install --production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v --rmi all",
    "setup": "chmod +x setup.sh && ./setup.sh",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "health": "curl -f http://localhost:3000/api/health",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "deploy": "npm run build && npm run docker:build && npm run docker:up",
    "logs": "tail -f logs/app.log",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "update": "npm update && npm run docker:build",
    "security": "npm audit && npm audit fix",
    "docs": "jsdoc -c jsdoc.conf.json",
    "benchmark": "node scripts/benchmark.js",
    "profile": "node --prof server.js",
    "analyze": "node --prof-process isolate-*.log > profile.txt"
  }
}
