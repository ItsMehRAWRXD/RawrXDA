; === Test the AI Copilot Framework ===
function main() -> int {
    println("=== AI COPILOT FOR SDKLESS IDE ===")
    println("Testing GitHub Copilot-style assistants...")
    
    var copilot_framework = AICopilotFramework()
    copilot_framework.init()
    
    ; Start a C++ session
    var session = copilot_framework.startCopilotSession("cpp", "./test_project")
    
    ; Test code suggestions
    var test_code = """
class TestClass {
public:
    TestClass();
    
"""
    
    var suggestions = copilot_framework.getCodeSuggestions(test_code, test_code.length, Array<string>())
    
    if (suggestions.length > 0) {
        println("=== SUCCESS ===")
        println("AI Copilot is working!")
        println("Generated " + suggestions.length.toString() + " code suggestions")
        
        for i in 0 to min(suggestions.length, 3) {
            var suggestion = suggestions[i]
            println("Suggestion " + (i + 1).toString() + ": " + suggestion.display_text)
            println("  Description: " + suggestion.description)
            println("  Confidence: " + (suggestion.confidence * 100).toFixed(1) + "%")
        }
        
        ; Test pair programming
        var advice = copilot_framework.getPairProgrammingAdvice(test_code, "How do I implement a destructor?")
        println("Pair Programming Advice: " + advice.suggestions.length.toString() + " suggestions provided")
        
        ; Show stats
        var stats = copilot_framework.getCopilotStats()
        println("Session Stats:")
        println("  Suggestions provided: " + stats.suggestions_provided.toString())
        println("  Acceptance rate: " + stats.acceptance_rate.toFixed(1) + "%")
        
    } else {
        println("=== FAILED ===")
        println("No suggestions generated")
    }
    
    return 0
}

function min(a: int, b: int) -> int {
    return a < b ? a : b
}

export main
