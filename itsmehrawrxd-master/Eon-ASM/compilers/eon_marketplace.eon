; === Utility Functions ===
function formatDownloadCount(count: int) -> string {
    if count < 1000 {
        return count.toString()
    } else if count < 1000000 {
        return (count / 1000).toString() + "K"
    } else {
        return (count / 1000000).toString() + "M"
    }
}

function formatBytes(bytes: int) -> string {
    if bytes < 1024 {
        return bytes.toString() + " B"
    } else if bytes < 1048576 {
        return (bytes / 1024).toString() + " KB"
    } else {
        return (bytes / 1048576).toString() + " MB"
    }
}

function isNewerVersion(version1: string, version2: string) -> bool {
    ; Simple semantic version comparison
    var parts1 = version1.split(".")
    var parts2 = version2.split(".")
    
    for i in 0..3 {
        var v1 = (i < parts1.size()) ? parseInt(parts1[i]) : 0
        var v2 = (i < parts2.size()) ? parseInt(parts2[i]) : 0
        
        if v1 > v2 {
            return true
        } else if v1 < v2 {
            return false
        }
    }
    
    return false
}

function generateTempId() -> string {
    return "temp_" + getCurrentTimestamp().toString() + "_" + Random.next(1000, 9999).toString()
}

function getCurrentTimestamp() -> int {
    return System.getCurrentTime()
}

function getApiKey() -> string {
    ; Get API key from settings or environment
    return Settings.get("marketplace.api_key", "")
}
