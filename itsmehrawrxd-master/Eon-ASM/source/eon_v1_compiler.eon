// eon_v1_compiler.eon
// Eon v1 compiler written using only minimal Eon kernel features
// This compiler bootstraps from the kernel to provide more advanced features

// Basic Eon kernel syntax:
// def model - define a structure/class
// def func - define a function
// loop - infinite loop (with break/continue)
// if - conditional statement
// let - variable declaration
// ret - return statement

// Token types for the lexer
def model TokenType {
    EOF: int
    IDENTIFIER: int
    NUMBER: int
    STRING: int
    DEF: int
    MODEL: int
    FUNC: int
    LOOP: int
    IF: int
    LET: int
    RET: int
    LPAREN: int
    RPAREN: int
    LBRACE: int
    RBRACE: int
    SEMICOLON: int
    COMMA: int
    COLON: int
    ARROW: int
    PLUS: int
    MINUS: int
    MULTIPLY: int
    DIVIDE: int
    ASSIGN: int
    EQUALS: int
    GREATER: int
    LESS: int
}

// Token structure
def model Token {
    type: TokenType
    value: *int  // Using int array as char array
    length: int
    line: int
    column: int
}

// AST node types
def model ASTNodeType {
    PROGRAM: int
    MODEL_DEF: int
    FUNC_DEF: int
    BLOCK: int
    VAR_DECL: int
    ASSIGNMENT: int
    RETURN: int
    IF_STMT: int
    LOOP_STMT: int
    BINARY_OP: int
    UNARY_OP: int
    LITERAL: int
    IDENTIFIER: int
    FUNC_CALL: int
}

// AST node structure
def model ASTNode {
    type: ASTNodeType
    value: *int
    left: *ASTNode
    right: *ASTNode
    next: *ASTNode
    children: *ASTNode
}

// Lexer state
def model Lexer {
    source: *int
    position: int
    current_char: int
    line: int
    column: int
    length: int
}

// Parser state
def model Parser {
    lexer: *Lexer
    current_token: Token
    error_count: int
}

// Code generator state
def model CodeGen {
    output: *int
    output_pos: int
    output_capacity: int
    label_count: int
}

// Initialize lexer with source code
def func init_lexer(lexer: *Lexer, source: *int, len: int) -> int {
    lexer->source = source
    lexer->position = 0
    lexer->line = 1
    lexer->column = 1
    lexer->length = len
    
    if (len > 0) {
        lexer->current_char = source[0]
    } else {
        lexer->current_char = 0
    }
    
    ret 1
}

// Advance lexer to next character
def func advance_lexer(lexer: *Lexer) -> int {
    lexer->position = lexer->position + 1
    
    if (lexer->current_char == 10) {  // newline
        lexer->line = lexer->line + 1
        lexer->column = 1
    } else {
        lexer->column = lexer->column + 1
    }
    
    if (lexer->position < lexer->length) {
        lexer->current_char = lexer->source[lexer->position]
    } else {
        lexer->current_char = 0
    }
    
    ret 1
}

// Skip whitespace characters
def func skip_whitespace(lexer: *Lexer) -> int {
    loop {
        if (lexer->current_char == 32) {  // space
            advance_lexer(lexer)
        } else if (lexer->current_char == 9) {  // tab
            advance_lexer(lexer)
        } else if (lexer->current_char == 10) {  // newline
            advance_lexer(lexer)
        } else if (lexer->current_char == 13) {  // carriage return
            advance_lexer(lexer)
        } else {
            ret 1
        }
    }
}

// Check if character is alphabetic
def func is_alpha(c: int) -> int {
    if (c >= 65) {  // 'A'
        if (c <= 90) {  // 'Z'
            ret 1
        }
    }
    if (c >= 97) {  // 'a'
        if (c <= 122) {  // 'z'
            ret 1
        }
    }
    ret 0
}

// Check if character is numeric
def func is_digit(c: int) -> int {
    if (c >= 48) {  // '0'
        if (c <= 57) {  // '9'
            ret 1
        }
    }
    ret 0
}

// Check if character is alphanumeric
def func is_alnum(c: int) -> int {
    if (is_alpha(c)) {
        ret 1
    }
    if (is_digit(c)) {
        ret 1
    }
    ret 0
}

// Read identifier or keyword
def func read_identifier(lexer: *Lexer, token: *Token) -> int {
    let start: int = lexer->position
    
    loop {
        if (is_alnum(lexer->current_char)) {
            advance_lexer(lexer)
        } else {
            ret 1
        }
    }
    
    token->value = lexer->source + start
    token->length = lexer->position - start
    token->line = lexer->line
    token->column = lexer->column - token->length
    
    // Check for keywords
    if (string_match(token->value, token->length, "def", 3)) {
        token->type = TokenType.DEF
    } else if (string_match(token->value, token->length, "model", 5)) {
        token->type = TokenType.MODEL
    } else if (string_match(token->value, token->length, "func", 4)) {
        token->type = TokenType.FUNC
    } else if (string_match(token->value, token->length, "loop", 4)) {
        token->type = TokenType.LOOP
    } else if (string_match(token->value, token->length, "if", 2)) {
        token->type = TokenType.IF
    } else if (string_match(token->value, token->length, "let", 3)) {
        token->type = TokenType.LET
    } else if (string_match(token->value, token->length, "ret", 3)) {
        token->type = TokenType.RET
    } else {
        token->type = TokenType.IDENTIFIER
    }
    
    ret 1
}

// Read number literal
def func read_number(lexer: *Lexer, token: *Token) -> int {
    let start: int = lexer->position
    
    loop {
        if (is_digit(lexer->current_char)) {
            advance_lexer(lexer)
        } else {
            ret 1
        }
    }
    
    token->type = TokenType.NUMBER
    token->value = lexer->source + start
    token->length = lexer->position - start
    token->line = lexer->line
    token->column = lexer->column - token->length
    
    ret 1
}

// Skip whitespace and comments
def func skip_whitespace_and_comments(lexer: *Lexer) -> int {
    loop {
        skip_whitespace(lexer)
        
        // Handle single line comments
        if (lexer->current_char == 47) {  // '/'
            if (lexer->position + 1 < lexer->length) {
                if (lexer->source[lexer->position + 1] == 47) {  // '//'
                    // Skip until newline
                    loop {
                        if (lexer->current_char == 10) {  // newline
                            advance_lexer(lexer)
                            ret 1
                        }
                        if (lexer->current_char == 0) {
                            ret 1
                        }
                        advance_lexer(lexer)
                    }
                }
            }
        }
        
        ret 1
    }
}

// Read numeric literal (enhanced version)
def func read_numeric_literal(lexer: *Lexer) -> Token {
    let token: Token
    let start: int = lexer->position
    
    loop {
        if (is_digit(lexer->current_char)) {
            advance_lexer(lexer)
        } else {
            ret 1
        }
    }
    
    token.type = TokenType.NUMBER
    token.value = lexer->source + start
    token.length = lexer->position - start
    token.line = lexer->line
    token.column = lexer->column - token.length
    
    ret token
}

// Read string literal
def func read_string_literal(lexer: *Lexer) -> Token {
    let token: Token
    let start: int = lexer->position + 1  // Skip opening quote
    
    advance_lexer(lexer)  // Skip opening quote
    
    loop {
        if (lexer->current_char == 34) {  // closing quote
            advance_lexer(lexer)
            ret 1
        }
        if (lexer->current_char == 0) {
            ret 1  // Unterminated string
        }
        advance_lexer(lexer)
    }
    
    token.type = TokenType.STRING
    token.value = lexer->source + start
    token.length = lexer->position - start - 1
    token.line = lexer->line
    token.column = lexer->column - token.length
    
    ret token
}

// Read character literal
