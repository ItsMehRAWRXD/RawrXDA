; === Test the AI Agent Framework ===
function main() -> int {
    println("=== AI AGENTS FOR SDKLESS IDE ===")
    println("Testing autonomous development assistants...")
    
    var agent_framework = AIAgentFramework()
    agent_framework.init()
    
    ; Activate some agents
    agent_framework.activateAgent("coding_assistant")
    agent_framework.activateAgent("debugger")
    agent_framework.activateAgent("project_manager")
    agent_framework.activateAgent("security_analyst")
    
    ; Test coding assistant
    var coding_task = AgentTask()
    coding_task.id = "test_task_1"
    coding_task.task_type = "generate_code"
    coding_task.parameters = Map<string, string>()
    coding_task.parameters["language"] = "cpp"
    coding_task.parameters["code_type"] = "class"
    coding_task.parameters["class_name"] = "TestClass"
    coding_task.required_capabilities = ["code_generation"]
    
    var success = agent_framework.sendTaskToAgent("coding_assistant", coding_task)
    
    if (success) {
        println("=== SUCCESS ===")
        println("AI Agents are working!")
        println("Coding Assistant generated code successfully")
        
        ; Show agent status
        var status_map = agent_framework.getAgentStatus()
        for agent_name in status_map.keys() {
            var status = status_map[agent_name]
            println("Agent: " + status.name + " - Active: " + status.is_active.toString())
        }
    } else {
        println("=== FAILED ===")
        println("Agent task failed")
    }
    
    return 0
}

export main
