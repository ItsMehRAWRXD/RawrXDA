// Filename: tinyasm.hex
// An extremely simple, hand-crafted assembler.
// This assembler understands a few basic instructions.

0x48, 0xC7, 0xC0, 0x01, 0x00, 0x00, 0x00,  // mov rax, 1 (sys_write)
0x48, 0xC7, 0xC7, 0x01, 0x00, 0x00, 0x00,  // mov rdi, 1 (stdout)
0x48, 0x8D, 0x35, 0x00, 0x00, 0x00, 0x00,  // lea rsi, [rel message]
0x48, 0xC7, 0xC2, 0x0D, 0x00, 0x00, 0x00,  // mov rdx, 13 (message length)
0x0F, 0x05,                                 // syscall
0x48, 0xC7, 0xC0, 0x3C, 0x00, 0x00, 0x00,  // mov rax, 60 (sys_exit)
0x48, 0x31, 0xFF,                          // xor rdi, rdi (exit code 0)
0x0F, 0x05,                                 // syscall
// message: "Hello World\n"
0x48, 0x65, 0x6C, 0x6C, 0x6F, 0x20, 0x57, 0x6F, 0x72, 0x6C, 0x64, 0x0A, 0x00
