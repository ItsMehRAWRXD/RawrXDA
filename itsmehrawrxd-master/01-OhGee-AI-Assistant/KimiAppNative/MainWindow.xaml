<Window x:Class="KimiAppNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="OhGee AI Assistant Hub" 
        Height="800" 
        Width="1200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">
    
    <Border Background="#2D2D30" CornerRadius="10" BorderBrush="#007ACC" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#007ACC">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="🧠 OhGee AI Assistant Hub" 
                          Foreground="White" 
                          FontWeight="Bold" 
                          VerticalAlignment="Center" 
                          Margin="10,0"/>
                
                <Button Grid.Column="1" 
                       Name="MinimizeButton" 
                       Content="−" 
                       Width="30" 
                       Height="30" 
                       Background="Transparent" 
                       Foreground="White" 
                       BorderThickness="0" 
                       FontSize="16" 
                       Click="MinimizeButton_Click"/>
                
                <Button Grid.Column="2" 
                       Name="CloseButton" 
                       Content="×" 
                       Width="30" 
                       Height="30" 
                       Background="Transparent" 
                       Foreground="White" 
                       BorderThickness="0" 
                       FontSize="16" 
                       Click="CloseButton_Click"/>
            </Grid>
            
            <!-- Tab Bar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#3C3C3C">
                <Button Name="KimiTab" 
                       Content="🧠 Kimi AI" 
                       Width="120" 
                       Height="40" 
                       Background="#6C757D" 
                       Foreground="White" 
                       BorderThickness="0" 
                       Margin="5" 
                       Click="KimiTab_Click"/>
                
                <Button Name="CursorTab" 
                       Content="🎯 Cursor" 
                       Width="120" 
                       Height="40" 
                       Background="#6C757D" 
                       Foreground="White" 
                       BorderThickness="0" 
                       Margin="5" 
                       Click="CursorTab_Click"/>
                
                <Button Name="ChatGPTTab" 
                       Content="💬 ChatGPT" 
                       Width="120" 
                       Height="40" 
                       Background="#6C757D" 
                       Foreground="White" 
                       BorderThickness="0" 
                       Margin="5" 
                       Click="ChatGPTTab_Click"/>
            </StackPanel>
            
            <!-- WebView -->
            <wv2:WebView2 Grid.Row="2" 
                         Name="WebView" 
                         Margin="5"/>
            
            <!-- Live Stream Panel -->
            <Border Grid.Row="3" 
                   Background="#1E1E1E" 
                   BorderBrush="#007ACC" 
                   BorderThickness="1" 
                   Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" 
                              Text="📡 Live AI Response Stream" 
                              Background="#007ACC" 
                              Foreground="White" 
                              Padding="5" 
                              FontWeight="Bold"/>
                    
                    <ScrollViewer Grid.Row="1" 
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto">
                        <TextBlock Name="LiveStreamText" 
                                  Background="#1E1E1E" 
                                  Foreground="#00FF00" 
                                  FontFamily="Consolas" 
                                  FontSize="11" 
                                  Padding="10" 
                                  TextWrapping="Wrap" 
                                  Text="[Live Stream] Waiting for AI responses..."/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>