{
  "name": "n0mn0m-ai-extension",
  "displayName": "n0mn0m AI Extension",
  "description": "Custom AI coding assistant with unlimited access to all unauthorized models",
  "version": "1.0.0",
  "publisher": "n0mn0m",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Snippets"
  ],
  "activationEvents": [
    "onCommand:n0mn0m.startSession",
    "onCommand:n0mn0m.generateCode",
    "onCommand:n0mn0m.codeReview",
    "onCommand:n0mn0m.debugCode",
    "onCommand:n0mn0m.refactorCode",
    "onCommand:n0mn0m.explainCode",
    "onCommand:n0mn0m.generateTests",
    "onCommand:n0mn0m.optimizeCode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "n0mn0m.startSession",
        "title": "Start AI Session",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.generateCode",
        "title": "Generate Code",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.codeReview",
        "title": "Code Review",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.debugCode",
        "title": "Debug Code",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.refactorCode",
        "title": "Refactor Code",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.explainCode",
        "title": "Explain Code",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.generateTests",
        "title": "Generate Tests",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.optimizeCode",
        "title": "Optimize Code",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.openProjectHub",
        "title": "Open Project Hub",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.switchToRawrZ",
        "title": "Switch to RawrZ Security Platform",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.switchToKimi",
        "title": "Switch to Kimi AI Assistant",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.switchToOllama",
        "title": "Switch to Ollama Chat Panel",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.openTerminal",
        "title": "Open AI Terminal",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.installServices",
        "title": "Install Auto-Services",
        "category": "n0mn0m"
      },
      {
        "command": "n0mn0m.testSystem",
        "title": "Test Complete System",
        "category": "n0mn0m"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "n0mn0m.generateCode",
          "group": "n0mn0m",
          "when": "editorHasSelection"
        },
        {
          "command": "n0mn0m.codeReview",
          "group": "n0mn0m",
          "when": "editorHasSelection"
        },
        {
          "command": "n0mn0m.explainCode",
          "group": "n0mn0m",
          "when": "editorHasSelection"
        },
        {
          "command": "n0mn0m.refactorCode",
          "group": "n0mn0m",
          "when": "editorHasSelection"
        }
      ],
      "commandPalette": [
        {
          "command": "n0mn0m.openProjectHub",
          "when": "!n0mn0m.sessionActive"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "n0mn0m-projects",
          "name": "n0mn0m Projects",
          "when": "n0mn0m.sessionActive"
        }
      ]
    },
    "configuration": {
      "title": "n0mn0m AI",
      "properties": {
        "n0mn0m.backendUrl": {
          "type": "string",
          "default": "http://localhost:9999",
          "description": "Backend server URL"
        },
        "n0mn0m.defaultModel": {
          "type": "string",
          "default": "gpt-5",
          "description": "Default AI model"
        },
        "n0mn0m.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect to backend on startup"
        },
        "n0mn0m.projectPath": {
          "type": "string",
          "default": "",
          "description": "Path to n0mn0m projects directory"
        },
        "n0mn0m.autoInstallServices": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install system services"
        },
        "n0mn0m.enableStealth": {
          "type": "boolean",
          "default": true,
          "description": "Enable stealth mode for anti-detection"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.0"
  }
}
