        layout.addWidget(advanced_group)
        
        ; Output Options Section
        var output_group = GroupBox("Output Options")
        var output_layout = VerticalLayout()
        
        var namespace_layout = HorizontalLayout()
        var namespace_label = Label("Namespace/Package:")
        var namespace_input = LineEdit("GeneratedAPI")
        namespace_layout.addWidget(namespace_label)
        namespace_layout.addWidget(namespace_input)
        
        var class_name_layout = HorizontalLayout()
        var class_name_label = Label("Main Class Name:")
        var class_name_input = LineEdit("APIWrapper")
        class_name_layout.addWidget(class_name_label)
        class_name_layout.addWidget(class_name_input)
        
        var output_dir_layout = HorizontalLayout()
        var output_dir_label = Label("Output Directory:")
        var output_dir_input = LineEdit("./generated_wrappers/")
        var browse_btn = Button("Browse...", "folder-open")
        output_dir_layout.addWidget(output_dir_label)
        output_dir_layout.addWidget(output_dir_input)
        output_dir_layout.addWidget(browse_btn)
        
        output_layout.addWidget(namespace_layout)
        output_layout.addWidget(class_name_layout)
        output_layout.addWidget(output_dir_layout)
        
        output_group.setLayout(output_layout)
        layout.addWidget(output_group)
        
        panel.setLayout(layout)
        return panel
    }
    
    function createPreviewPanel() -> Widget {
        var panel = Panel()
        panel.setTitle("Generated Code Preview")
        
        var layout = VerticalLayout()
        
        ; Language tabs for preview
        var preview_tabs = TabContainer()
        
        ; Add preview tabs for each language
        var cpp_preview = TextWidget()
        cpp_preview.setFont(Font.MONOSPACE)
        cpp_preview.setReadOnly(true)
        preview_tabs.addTab("C++", cpp_preview)
        
        var python_preview = TextWidget()
        python_preview.setFont(Font.MONOSPACE)
        python_preview.setReadOnly(true)
        preview_tabs.addTab("Python", python_preview)
        
        var rust_preview = TextWidget()
        rust_preview.setFont(Font.MONOSPACE)
        rust_preview.setReadOnly(true)
        preview_tabs.addTab("Rust", rust_preview)
        
        layout.addWidget(preview_tabs)
        
        panel.setLayout(layout)
        return panel
    }
    
    function onPreview() {
        var generator = WrapperGenerator()
        generator.setOptions(wrapper_options)
        generator.setFunctions(selected_functions)
        
        ; Generate previews for selected languages
        if (wrapper_options.languages.contains("cpp")) {
            var cpp_code = generator.generateCppWrapper()
            updatePreview("C++", cpp_code)
        }
        
        if (wrapper_options.languages.contains("python")) {
            var python_code = generator.generatePythonWrapper()
            updatePreview("Python", python_code)
        }
        
        if (wrapper_options.languages.contains("rust")) {
            var rust_code = generator.generateRustWrapper()
            updatePreview("Rust", rust_code)
        }
    }
    
    function onGenerate() {
        var generator = WrapperGenerator()
        generator.setOptions(wrapper_options)
        generator.setFunctions(selected_functions)
        
        var result = generator.generateAllWrappers()
        
        if (result.success) {
            showSuccessDialog("Wrapper generation completed!\n" +
                            "Generated " + result.files_created.length.toString() + " files in:\n" +
                            wrapper_options.output_directory)
            dialog.accept()
        } else {
            showErrorDialog("Wrapper generation failed:\n" + result.error_message)
        }
    }
}

; Wrapper Generator Engine
class WrapperGenerator {
    var options: WrapperOptions
    var functions: Array<Function>
    var template_engine: TemplateEngine
    var type_mapper: TypeMapper
    
    function init() {
        template_engine = TemplateEngine()
        type_mapper = TypeMapper()
        loadTemplates()
    }
    
    function loadTemplates() {
        ; Load wrapper templates for each language
        template_engine.loadTemplate("cpp_class", getCppClassTemplate())
        template_engine.loadTemplate("cpp_function", getCppFunctionTemplate())
        template_engine.loadTemplate("python_class", getPythonClassTemplate())
        template_engine.loadTemplate("python_function", getPythonFunctionTemplate())
        template_engine.loadTemplate("rust_module", getRustModuleTemplate())
        template_engine.loadTemplate("rust_function", getRustFunctionTemplate())
    }
    
    function generateCppWrapper() -> string {
        var wrapper = StringBuilder()
        
        ; Header guard
        wrapper.appendLine("#ifndef " + options.namespace.toUpperCase() + "_WRAPPER_H")
        wrapper.appendLine("#define " + options.namespace.toUpperCase() + "_WRAPPER_H")
        wrapper.appendLine("")
        
        ; Includes
        wrapper.appendLine("#include <cstdint>")
        wrapper.appendLine("#include <string>")
        wrapper.appendLine("#include <vector>")
        wrapper.appendLine("#include <memory>")
        
        if (options.include_error_handling) {
            wrapper.appendLine("#include <stdexcept>")
        }
        
        if (options.thread_safe) {
            wrapper.appendLine("#include <mutex>")
        }
        
        wrapper.appendLine("")
        
        ; Namespace
        wrapper.appendLine("namespace " + options.namespace + " {")
        wrapper.appendLine("")
        
        ; Forward declarations
        for func in functions {
            wrapper.appendLine("// " + func.name + " at 0x" + func.address.toHex())
        }
        wrapper.appendLine("")
        
        ; Main wrapper class
        wrapper.appendLine("class " + options.class_name + " {")
        
        ; Private members
        wrapper.appendLine("private:")
        wrapper.appendLine("    void* m_library_handle;")
        
        if (options.thread_safe) {
            wrapper.appendLine("    mutable std::mutex m_mutex;")
        }
        
        ; Function pointers
        for func in functions {
            var return_type = type_mapper.mapToCppType(func.return_type)
            var params = buildCppParameterList(func.parameters)
            
            wrapper.appendLine("    typedef " + return_type + " (*" + func.name + "_t)(" + params + ");")
            wrapper.appendLine("    " + func.name + "_t " + func.name + "_ptr;")
        }
        
        wrapper.appendLine("")
        
        ; Public interface
        wrapper.appendLine("public:")
        wrapper.appendLine("    " + options.class_name + "(const std::string& library_path);")
        wrapper.appendLine("    ~" + options.class_name + "();")
        wrapper.appendLine("")
        
        ; Wrapper functions
        for func in functions {
            var return_type = type_mapper.mapToCppType(func.return_type)
            var params = buildCppParameterList(func.parameters)
            var func_signature = return_type + " " + func.name + "(" + params + ")"
            
            if (options.include_documentation) {
                wrapper.appendLine("    /**")
                wrapper.appendLine("     * " + func.name + " - Wrapper function")
                wrapper.appendLine("     * Original address: 0x" + func.address.toHex())
                if (func.description.length > 0) {
                    wrapper.appendLine("     * " + func.description)
                }
                wrapper.appendLine("     */")
            }
            
            wrapper.appendLine("    " + func_signature + ";")
        }
        
        wrapper.appendLine("};")
        wrapper.appendLine("")
        wrapper.appendLine("} // namespace " + options.namespace)
        wrapper.appendLine("")
        wrapper.appendLine("#endif // " + options.namespace.toUpperCase() + "_WRAPPER_H")
        
        return wrapper.toString()
    }
    
    function generatePythonWrapper() -> string {
        var wrapper = StringBuilder()
        
        ; Header comments
        wrapper.appendLine("\"\"\"")
        wrapper.appendLine("Generated Python API Wrapper")
        wrapper.appendLine("Created by RawrZ Reverse Engineering IDE")
        wrapper.appendLine("\"\"\"")
        wrapper.appendLine("")
        
        ; Imports
        wrapper.appendLine("import ctypes")
        wrapper.appendLine("from ctypes import *")
        wrapper.appendLine("import os")
        wrapper.appendLine("import platform")
        
        if (options.include_error_handling) {
            wrapper.appendLine("import traceback")
        }
        
        if (options.include_logging) {
            wrapper.appendLine("import logging")
        }
        
        wrapper.appendLine("")
        
        ; Exception class
        if (options.include_error_handling) {
            wrapper.appendLine("class " + options.class_name + "Error(Exception):")
            wrapper.appendLine("    pass")
            wrapper.appendLine("")
        }
        
        ; Main wrapper class
        wrapper.appendLine("class " + options.class_name + ":")
        wrapper.appendLine("    def __init__(self, library_path=None):")
        wrapper.appendLine("        self._lib = None")
        wrapper.appendLine("        self._library_path = library_path")
        
        if (options.include_logging) {
            wrapper.appendLine("        self._logger = logging.getLogger(__name__)")
        }
        
        wrapper.appendLine("        ")
        wrapper.appendLine("        if library_path:")
        wrapper.appendLine("            self.load_library(library_path)")
        wrapper.appendLine("")
        
        ; Library loading
        wrapper.appendLine("    def load_library(self, path):")
        wrapper.appendLine("        try:")
        wrapper.appendLine("            self._lib = ctypes.CDLL(path)")
        wrapper.appendLine("            self._setup_function_prototypes()")
        
        if (options.include_logging) {
            wrapper.appendLine("            self._logger.info(f'Loaded library: {path}')")
        }
        
        if (options.include_error_handling) {
            wrapper.appendLine("        except OSError as e:")
            wrapper.appendLine("            raise " + options.class_name + "Error(f'Failed to load library {path}: {e}')")
        }
        
        wrapper.appendLine("")
        
        ; Function prototype setup
        wrapper.appendLine("    def _setup_function_prototypes(self):")
        wrapper.appendLine("        if not self._lib:")
        wrapper.appendLine("            return")
        wrapper.appendLine("")
        
        for func in functions {
            wrapper.appendLine("        # " + func.name + " at 0x" + func.address.toHex())
            wrapper.appendLine("        self._lib." + func.name + ".argtypes = [")
            
            for param in func.parameters {
                var python_type = type_mapper.mapToPythonType(param.type)
                wrapper.appendLine("            " + python_type + ",")
            }
            
            wrapper.appendLine("        ]")
            
            var return_type = type_mapper.mapToPythonType(func.return_type)
            wrapper.appendLine("        self._lib." + func.name + ".restype = " + return_type)
            wrapper.appendLine("")
        }
        
        ; Wrapper methods
        for func in functions {
            wrapper.appendLine("    def " + func.name + "(self" + buildPythonParameterList(func.parameters) + "):")
            
            if (options.include_documentation) {
                wrapper.appendLine("        \"\"\"")
                wrapper.appendLine("        " + func.name + " - Wrapper method")
                wrapper.appendLine("        Original address: 0x" + func.address.toHex())
                wrapper.appendLine("        \"\"\"")
            }
            
            wrapper.appendLine("        if not self._lib:")
            wrapper.appendLine("            raise " + options.class_name + "Error('Library not loaded')")
            wrapper.appendLine("")
            
            if (options.include_logging) {
                wrapper.appendLine("        self._logger.debug(f'Calling " + func.name + "')")
            }
            
            ; Build parameter list for call
            var param_names = Array<string>()
            for param in func.parameters {
                param_names.add(param.name)
            }
            
            var call_params = param_names.join(", ")
            
            if (options.include_error_handling) {
                wrapper.appendLine("        try:")
                wrapper.appendLine("            result = self._lib." + func.name + "(" + call_params + ")")
                wrapper.appendLine("            return result")
                wrapper.appendLine("        except Exception as e:")
                wrapper.appendLine("            raise " + options.class_name + "Error(f'" + func.name + " failed: {e}')")
            } else {
                wrapper.appendLine("        return self._lib." + func.name + "(" + call_params + ")")
            }
            
            wrapper.appendLine("")
        }
        
        return wrapper.toString()
    }
    
    function generateRustWrapper() -> string {
        var wrapper = StringBuilder()
        
        ; Module header
        wrapper.appendLine("//! Generated Rust FFI Wrapper")
        wrapper.appendLine("//! Created by RawrZ Reverse Engineering IDE")
        wrapper.appendLine("")
        
        ; Use statements
        wrapper.appendLine("use std::ffi::{c_char, c_void, CStr, CString};")
        wrapper.appendLine("use std::ptr;")
        
        if (options.include_error_handling) {
            wrapper.appendLine("use std::error::Error;")
            wrapper.appendLine("use std::fmt;")
        }
        
        wrapper.appendLine("")
        
        ; Error type
        if (options.include_error_handling) {
            wrapper.appendLine("#[derive(Debug)]")
            wrapper.appendLine("pub enum " + options.class_name + "Error {")
            wrapper.appendLine("    LibraryNotLoaded,")
            wrapper.appendLine("    FunctionCallFailed(String),")
            wrapper.appendLine("}")
            wrapper.appendLine("")
            
            wrapper.appendLine("impl fmt::Display for " + options.class_name + "Error {")
            wrapper.appendLine("    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {")
            wrapper.appendLine("        match self {")
            wrapper.appendLine("            " + options.class_name + "Error::LibraryNotLoaded => write!(f, \"Library not loaded\"),")
            wrapper.appendLine("            " + options.class_name + "Error::FunctionCallFailed(msg) => write!(f, \"Function call failed: {}\", msg),")
            wrapper.appendLine("        }")
            wrapper.appendLine("    }")
            wrapper.appendLine("}")
            wrapper.appendLine("")
            
            wrapper.appendLine("impl Error for " + options.class_name + "Error {}")
            wrapper.appendLine("")
        }
        
        ; External function declarations
        wrapper.appendLine("extern \"C\" {")
        for func in functions {
            var return_type = type_mapper.mapToRustType(func.return_type)
            var params = buildRustParameterList(func.parameters)
            
            wrapper.appendLine("    /// " + func.name + " at 0x" + func.address.toHex())
            wrapper.appendLine("    pub fn " + func.name + "(" + params + ") -> " + return_type + ";")
        }
        wrapper.appendLine("}")
        wrapper.appendLine("")
        
        ; Wrapper struct
        wrapper.appendLine("pub struct " + options.class_name + " {")
        wrapper.appendLine("    _private: (),")
        wrapper.appendLine("}")
        wrapper.appendLine("")
        
        ; Implementation
        wrapper.appendLine("impl " + options.class_name + " {")
        wrapper.appendLine("    pub fn new() -> Self {")
        wrapper.appendLine("        " + options.class_name + " { _private: () }")
        wrapper.appendLine("    }")
        wrapper.appendLine("")
        
        ; Wrapper methods
        for func in functions {
            var return_type = type_mapper.mapToRustType(func.return_type)
            var params = buildRustParameterList(func.parameters)
            var result_type = if (options.include_error_handling) "Result<" + return_type + ", " + options.class_name + "Error>" else return_type
            
            wrapper.appendLine("    /// Wrapper for " + func.name)
            wrapper.appendLine("    /// Original address: 0x" + func.address.toHex())
            wrapper.appendLine("    pub fn " + func.name + "(&self, " + params + ") -> " + result_type + " {")
            wrapper.appendLine("        unsafe {")
            
            ; Build parameter list for call
            var param_names = Array<string>()
            for param in func.parameters {
                param_names.add(param.name)
            }
            
            var call_params = param_names.join(", ")
            
            if (options.include_error_handling) {
                wrapper.appendLine("            let result = " + func.name + "(" + call_params + ");")
                wrapper.appendLine("            Ok(result)")
            } else {
                wrapper.appendLine("            " + func.name + "(" + call_params + ")")
            }
            
            wrapper.appendLine("        }")
            wrapper.appendLine("    }")
            wrapper.appendLine("")
        }
        
        wrapper.appendLine("}")
        
        return wrapper.toString()
    }
    
    function generateAllWrappers() -> GenerationResult {
        var result = GenerationResult()
        result.files_created = Array<string>()
        
        try {
            ; Create output directory
            createDirectory(options.output_directory)
            
            ; Generate each selected language
            for language in options.languages {
                match language {
                    case "cpp": {
                        var cpp_code = generateCppWrapper()
                        var header_file = options.output_directory + "/" + options.class_name + ".h"
                        writeFile(header_file, cpp_code)
                        result.files_created.add(header_file)
                        
                        var cpp_impl = generateCppImplementation()
                        var cpp_file = options.output_directory + "/" + options.class_name + ".cpp"
                        writeFile(cpp_file, cpp_impl)
                        result.files_created.add(cpp_file)
                    }
                    case "python": {
                        var python_code = generatePythonWrapper()
                        var python_file = options.output_directory + "/" + options.class_name.toLowerCase() + ".py"
                        writeFile(python_file, python_code)
                        result.files_created.add(python_file)
                    }
                    case "rust": {
                        var rust_code = generateRustWrapper()
                        var rust_file = options.output_directory + "/lib.rs"
                        writeFile(rust_file, rust_code)
                        result.files_created.add(rust_file)
                        
                        var cargo_toml = generateCargoToml()
                        var cargo_file = options.output_directory + "/Cargo.toml"
                        writeFile(cargo_file, cargo_toml)
                        result.files_created.add(cargo_file)
                    }
                    ; Add more languages...
                }
            }
            
            result.success = true
            
        } catch (Exception ex) {
            result.success = false
            result.error_message = ex.getMessage()
        }
        
        return result
    }
}

; Data Structures
struct WrapperOptions {
    var languages: Array<string>
    var style: WrapperStyle
    var namespace: string
    var class_name: string
    var output_directory: string
    var include_error_handling: bool
    var include_logging: bool
    var thread_safe: bool
    var performance_optimized: bool
    var include_documentation: bool
    var type_safety: bool
}

struct GenerationResult {
    var success: bool
    var error_message: string
    var files_created: Array<string>
}

; === COMPLETE GUI FRAMEWORK ===

; Main IDE Window with Full GUI
class MainIDEWindow {
    var main_window: XCBWindow
    var central_widget: Widget
    var menu_bar_system: MenuBarSystem
    var main_toolbar: Toolbar
    var status_bar: StatusBar
    var dock_system: DockingSystem
    var tab_widget: TabWidget
    
    ; Core panels
    var disassembly_panel: DisassemblyPanel
    var hex_editor_panel: HexEditorPanel
    var decompiler_panel: DecompilerPanel
    var assembly_editor_panel: AssemblyEditor
    var function_list_panel: FunctionListPanel
    var strings_panel: StringsPanel
    var imports_exports_panel: ImportsExportsPanel
    
    ; Debug panels
    var registers_panel: RegistersPanel
    var memory_view_panel: MemoryViewPanel
    var stack_panel: StackPanel
    var breakpoints_panel: BreakpointsPanel
    var threads_panel: ThreadsPanel
    var debug_console_panel: DebugConsolePanel
    
    ; Analysis panels
    var call_graph_panel: CallGraphPanel
    var control_flow_panel: ControlFlowPanel
    var cross_references_panel: CrossReferencesPanel
    var symbols_panel: SymbolsPanel
    
    ; Game hacking panels
    var esp_system: ESPSystem
    var esp_radar_panel: ESPRadarPanel
    var esp_config_panel: ESPConfigurationPanel
    var memory_pattern_panel: MemoryPatternPanel
    
    ; File system
    var project_explorer: ProjectExplorerPanel
    var file_browser: FileBrowserPanel
    
    function init() {
        println("Initializing Complete GUI Framework...")
        
        createMainWindow()
        createCentralLayout()
        createMenuSystem()
        createToolbars()
        createStatusBar()
        createDockingSystem()
        createAllPanels()
        setupLayoutManagement()
        setupThemeSystem()
        
        println("Full GUI Framework Initialized!")
    }
    
    function createMainWindow() {
        main_window = XCBWindow()
        main_window.setTitle("RawrZ Professional Reverse Engineering IDE")
        main_window.setIcon("applications-development")
        main_window.setSize(1920, 1080)
        main_window.setMinimumSize(1024, 768)
        main_window.centerOnScreen()
        
        ; Set up window properties
        main_window.setWindowFlags(WindowFlag.RESIZABLE | WindowFlag.MAXIMIZABLE)
        main_window.setAttribute(WindowAttribute.ACCEPTS_FOCUS, true)
        
        ; Window event handlers
        main_window.onClose = onMainWindowClose
        main_window.onResize = onMainWindowResize
        main_window.onFocusChanged = onMainWindowFocus
    }
    
    function createCentralLayout() {
        central_widget = Widget()
        var main_layout = VerticalLayout()
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)
        
        central_widget.setLayout(main_layout)
        main_window.setCentralWidget(central_widget)
    }
    
    function createMenuSystem() {
        menu_bar_system = MenuBarSystem()
        menu_bar_system.init(main_window, this)
        central_widget.layout().addWidget(menu_bar_system.main_menu_bar)
    }
    
    function createToolbars() {
        ; Main toolbar
        main_toolbar = Toolbar()
        main_toolbar.setIconSize(24, 24)
        main_toolbar.setToolButtonStyle(ToolButtonStyle.TEXT_BESIDE_ICON)
        
        ; File operations
        var open_btn = ToolButton("Open Binary", "folder-open")
        open_btn.onClick = onOpenBinary
        open_btn.setToolTip("Open binary file for analysis (Ctrl+O)")
        main_toolbar.addWidget(open_btn)
        
        var save_btn = ToolButton("Save Project", "document-save")
        save_btn.onClick = onSaveProject
        save_btn.setToolTip("Save current project (Ctrl+S)")
        main_toolbar.addWidget(save_btn)
        
        main_toolbar.addSeparator()
        
        ; Analysis operations
        var analyze_btn = ToolButton("Analyze", "system-run")
        analyze_btn.onClick = onAnalyzeBinary
        analyze_btn.setToolTip("Start binary analysis (F5)")
        main_toolbar.addWidget(analyze_btn)
        
        var function_btn = ToolButton("Create Function", "code-function")
        function_btn.onClick = onCreateFunction
        function_btn.setToolTip("Create function at current address")
        main_toolbar.addWidget(function_btn)
        
        main_toolbar.addSeparator()
        
        ; Debug operations
        var debug_btn = ToolButton("Debug", "applications-debugging")
        debug_btn.onClick = onStartDebugging
        debug_btn.setToolTip("Start debugging session (F9)")
        main_toolbar.addWidget(debug_btn)
        
        var step_btn = ToolButton("Step Over", "media-skip-forward")
        step_btn.onClick = onStepOver
        step_btn.setToolTip("Step over instruction (F10)")
        main_toolbar.addWidget(step_btn)
        
        main_toolbar.addSeparator()
        
        ; View options
        var layout_combo = ComboBox()
        layout_combo.addItems(["Default Layout", "Analysis Layout", "Debug Layout", "Minimal Layout"])
        layout_combo.onSelectionChanged = onLayoutChanged
        layout_combo.setToolTip("Switch IDE layout")
        main_toolbar.addWidget(layout_combo)
        
        ; Add toolbar to window
        central_widget.layout().addWidget(main_toolbar)
    }
    
    function createStatusBar() {
        status_bar = StatusBar()
        
        ; Status sections
        var file_status = Label("No file loaded")
        var arch_status = Label("Architecture: Unknown")
        var progress_bar = ProgressBar()
        progress_bar.setVisible(false)
        var memory_usage = Label("Memory: 0 MB")
        
        status_bar.addWidget(file_status, 1)
        status_bar.addWidget(arch_status, 0)
        status_bar.addWidget(progress_bar, 0)
        status_bar.addPermanentWidget(memory_usage, 0)
        
        central_widget.layout().addWidget(status_bar)
    }
    
    function createDockingSystem() {
        dock_system = DockingSystem()
        dock_system.setParent(central_widget)
        
        ; Create tab widget as central area
        tab_widget = TabWidget()
        tab_widget.setTabsClosable(true)
        tab_widget.setMovable(true)
        tab_widget.setDocumentMode(true)
        
        dock_system.setCentralWidget(tab_widget)
        central_widget.layout().addWidget(dock_system, 1)
    }
    
    function createAllPanels() {
        println("Creating all GUI panels...")
        
        ; Core analysis panels
        createDisassemblyPanel()
        createHexEditorPanel()
        createDecompilerPanel()
        createAssemblyEditorPanel()
        
        ; Information panels
        createFunctionListPanel()
        createStringsPanel()
        createImportsExportsPanel()
        createProjectExplorerPanel()
        
        ; Debug panels
        createDebugPanels()
        
        ; Analysis panels
        createAnalysisPanels()
        
        println("All panels created successfully!")
    }
    
    function createDisassemblyPanel() {
        disassembly_panel = DisassemblyPanel()
        disassembly_panel.init()
        
        var dock = DockWidget("Disassembly")
        dock.setIcon("applications-development")
        dock.setWidget(disassembly_panel)
        dock.setFeatures(DockWidget.DOCKABLE | DockWidget.MOVABLE | DockWidget.FLOATABLE)
        
        dock_system.addDockWidget(DockArea.CENTER, dock)
    }
    
    function createHexEditorPanel() {
        hex_editor_panel = HexEditorPanel()
        hex_editor_panel.init()
        
        var dock = DockWidget("Hex Editor")
        dock.setIcon("applications-utilities")
        dock.setWidget(hex_editor_panel)
        
        dock_system.addDockWidget(DockArea.CENTER, dock)
    }
    
    function createDecompilerPanel() {
        decompiler_panel = DecompilerPanel()
        decompiler_panel.init()
        
        var dock = DockWidget("Decompiler")
        dock.setIcon("text-x-generic")
        dock.setWidget(decompiler_panel)
        
        dock_system.addDockWidget(DockArea.CENTER, dock)
    }
    
    function createAssemblyEditorPanel() {
        var assembly_engine = AssemblyEngine()
        assembly_engine.init()
        
        assembly_editor_panel = AssemblyEditor()
        assembly_editor_panel.init(null, assembly_engine)
        
        var dock = DockWidget("Assembly Editor")
        dock.setIcon("accessories-text-editor")
        dock.setWidget(assembly_editor_panel)
        
        dock_system.addDockWidget(DockArea.CENTER, dock)
    }
    
    function createFunctionListPanel() {
        function_list_panel = FunctionListPanel()
        function_list_panel.init()
        
        var dock = DockWidget("Functions")
        dock.setIcon("code-function")
        dock.setWidget(function_list_panel)
        
        dock_system.addDockWidget(DockArea.LEFT, dock)
    }
    
    function createStringsPanel() {
        strings_panel = StringsPanel()
        strings_panel.init()
        
        var dock = DockWidget("Strings")
        dock.setIcon("format-text")
        dock.setWidget(strings_panel)
        
        dock_system.addDockWidget(DockArea.BOTTOM, dock)
    }
    
    function createProjectExplorerPanel() {
        project_explorer = ProjectExplorerPanel()
        project_explorer.init()
        
        var dock = DockWidget("Project Explorer")
        dock.setIcon("folder-open")
        dock.setWidget(project_explorer)
        
        dock_system.addDockWidget(DockArea.LEFT, dock)
    }
    
    function createDebugPanels() {
        ; Registers panel
        registers_panel = RegistersPanel()
        registers_panel.init()
        
        var registers_dock = DockWidget("Registers")
        registers_dock.setIcon("applications-system")
        registers_dock.setWidget(registers_panel)
        dock_system.addDockWidget(DockArea.RIGHT, registers_dock)
        
        ; Memory view panel
        memory_view_panel = MemoryViewPanel()
        memory_view_panel.init()
        
        var memory_dock = DockWidget("Memory View")
        memory_dock.setIcon("utilities-system-monitor")
        memory_dock.setWidget(memory_view_panel)
        dock_system.addDockWidget(DockArea.RIGHT, memory_dock)
        
        ; Stack panel
        stack_panel = StackPanel()
        stack_panel.init()
        
        var stack_dock = DockWidget("Stack")
        stack_dock.setIcon("view-list-tree")
        stack_dock.setWidget(stack_panel)
        dock_system.addDockWidget(DockArea.RIGHT, stack_dock)
        
        ; Breakpoints panel
        breakpoints_panel = BreakpointsPanel()
        breakpoints_panel.init()
        
        var bp_dock = DockWidget("Breakpoints")
        bp_dock.setIcon("media-record")
        bp_dock.setWidget(breakpoints_panel)
        dock_system.addDockWidget(DockArea.BOTTOM, bp_dock)
        
        ; Debug console
        debug_console_panel = DebugConsolePanel()
        debug_console_panel.init()
        
        var console_dock = DockWidget("Debug Console")
        console_dock.setIcon("utilities-terminal")
        console_dock.setWidget(debug_console_panel)
        dock_system.addDockWidget(DockArea.BOTTOM, console_dock)
    }
    
    function createAnalysisPanels() {
        ; Call graph panel
        call_graph_panel = CallGraphPanel()
        call_graph_panel.init()
        
        var cg_dock = DockWidget("Call Graph")
        cg_dock.setIcon("network-wireless")
        cg_dock.setWidget(call_graph_panel)
        dock_system.addDockWidget(DockArea.RIGHT, cg_dock)
        
        ; Cross references panel
        cross_references_panel = CrossReferencesPanel()
        cross_references_panel.init()
        
        var xref_dock = DockWidget("Cross References")
        xref_dock.setIcon("go-jump")
        xref_dock.setWidget(cross_references_panel)
        dock_system.addDockWidget(DockArea.BOTTOM, xref_dock)
        
        ; Symbols panel
        symbols_panel = SymbolsPanel()
        symbols_panel.init()
        
        var symbols_dock = DockWidget("Symbols")
        symbols_dock.setIcon("bookmarks")
        symbols_dock.setWidget(symbols_panel)
        dock_system.addDockWidget(DockArea.LEFT, symbols_dock)
    }
    
    function setupLayoutManagement() {
        var layout_manager = LayoutManager()
        layout_manager.init(dock_system)
        
        ; Define standard layouts
        layout_manager.defineLayout("default", createDefaultLayout())
        layout_manager.defineLayout("analysis", createAnalysisLayout())
        layout_manager.defineLayout("debug", createDebugLayout())
        layout_manager.defineLayout("minimal", createMinimalLayout())
        
        ; Load last used layout
        var last_layout = getSettingsValue("ui.last_layout", "default")
        layout_manager.applyLayout(last_layout)
    }
    
    function setupThemeSystem() {
        var theme_manager = ThemeManager()
        theme_manager.init()
        
        ; Load available themes
        theme_manager.registerTheme("light", LightTheme())
        theme_manager.registerTheme("dark", DarkTheme())
        theme_manager.registerTheme("high_contrast", HighContrastTheme())
        
        ; Apply saved theme
        var current_theme = getSettingsValue("ui.theme", "dark")
        theme_manager.applyTheme(current_theme)
        
        ; Apply theme to all panels
        applyThemeToAllPanels(theme_manager.getCurrentTheme())
    }
    
    function show() {
        main_window.show()
        main_window.raise()
        main_window.activateWindow()
    }
}

