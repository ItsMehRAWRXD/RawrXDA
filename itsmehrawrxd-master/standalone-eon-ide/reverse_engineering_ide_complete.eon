; Natural Language to Code Generator
class IntelligentCodeGenerator {
    var nlp_processor: NLPProcessor
    var code_templates: Map<string, CodeTemplate>
    var language_mappings: Map<string, LanguageSpec>
    var pattern_matcher: PatternMatcher
    var context_analyzer: ContextAnalyzer
    var completion_engine: CompletionEngine
    
    function init() {
        println("Initializing Intelligent Code Generator...")
        
        nlp_processor = NLPProcessor()
        code_templates = Map<string, CodeTemplate>()
        language_mappings = Map<string, LanguageSpec>()
        pattern_matcher = PatternMatcher()
        context_analyzer = ContextAnalyzer()
        completion_engine = CompletionEngine()
        
        loadCodeTemplates()
        loadLanguageSpecs()
        setupNLPPatterns()
        
        println("Code generator ready - supports natural language input!")
    }
    
    function generateCodeFromInput(user_input: string, target_language: string, context: CodeContext) -> CodeGenerationResult {
        println("Analyzing user input: \"" + user_input + "\"")
        
        var result = CodeGenerationResult()
        result.input = user_input
        result.target_language = target_language
        
        ; Step 1: Parse natural language intent
        var intent = nlp_processor.parseIntent(user_input)
        println("Detected intent: " + intent.type + " (confidence: " + intent.confidence + "%)")
        
        ; Step 2: Extract code elements
        var elements = extractCodeElements(user_input, intent)
        
        ; Step 3: Match with templates
        var template = findBestTemplate(intent, elements, target_language)
        
        if (!template) {
            result.success = false
            result.error = "Could not understand request: " + user_input
            return result
        }
        
        ; Step 4: Generate code
        var generated_code = template.generate(elements, context)
        
        ; Step 5: Apply language-specific formatting
        var formatted_code = applyLanguageFormatting(generated_code, target_language)
        
        result.generated_code = formatted_code
        result.template_used = template.name
        result.success = true
        result.suggestions = generateSuggestions(intent, elements)
        
        return result
    }
    
    function loadCodeTemplates() {
        ; Function templates
        addTemplate("create_function", FunctionTemplate([
            "create function {name}",
            "make function {name}",
            "function {name}",
            "def {name}",
            "function called {name}"
        ]))
        
        ; Class templates  
        addTemplate("create_class", ClassTemplate([
            "create class {name}",
            "make class {name}",
            "class {name}",
            "define class {name}"
        ]))
        
        ; Loop templates
        addTemplate("for_loop", ForLoopTemplate([
            "for loop from {start} to {end}",
            "loop {var} from {start} to {end}",
            "iterate {var} from {start} to {end}",
            "for {var} in range {start} to {end}"
        ]))
        
        addTemplate("while_loop", WhileLoopTemplate([
            "while {condition}",
            "loop while {condition}",
            "keep looping while {condition}"
        ]))
        
        ; Conditional templates
        addTemplate("if_statement", IfTemplate([
            "if {condition}",
            "check if {condition}",
            "when {condition}",
            "if {condition} then"
        ]))
        
        ; Variable templates
        addTemplate("declare_variable", VariableTemplate([
            "variable {name}",
            "var {name}",
            "create variable {name}",
            "declare {name}"
        ]))
        
        ; Data structure templates
        addTemplate("create_array", ArrayTemplate([
            "array of {type}",
            "list of {type}",
            "create array {name}",
            "{type} array"
        ]))
        
        ; File I/O templates
        addTemplate("read_file", FileIOTemplate([
            "read file {filename}",
            "load file {filename}",
            "open file {filename}",
            "read from {filename}"
        ]))
        
        ; Network templates
        addTemplate("http_request", NetworkTemplate([
            "http request to {url}",
            "get data from {url}",
            "api call to {url}",
            "fetch {url}"
        ]))
        
        ; Database templates
        addTemplate("sql_query", DatabaseTemplate([
            "select from {table}",
            "query {table}",
            "get data from {table}",
            "select * from {table}"
        ]))
        
        ; GUI templates
        addTemplate("create_window", GUITemplate([
            "create window",
            "make window",
            "new window",
            "gui window"
        ]))
        
        ; Algorithm templates
        addTemplate("sort_algorithm", AlgorithmTemplate([
            "sort array",
            "sort list",
            "bubble sort",
            "quick sort",
            "merge sort"
        ]))
        
        println(" Loaded " + code_templates.size() + " code templates")
    }
    
    function loadLanguageSpecs() {
        ; EON language specification
        var eon_spec = LanguageSpec()
        eon_spec.name = "EON"
        eon_spec.function_syntax = "function {name}({params}) -> {return_type} { {body} }"
        eon_spec.class_syntax = "class {name} { {body} }"
        eon_spec.variable_syntax = "var {name}: {type} = {value}"
        eon_spec.if_syntax = "if ({condition}) { {body} }"
        eon_spec.for_syntax = "for {var} in {range} { {body} }"
        eon_spec.while_syntax = "while ({condition}) { {body} }"
        language_mappings["EON"] = eon_spec
        
        ; C++ specification
        var cpp_spec = LanguageSpec()
        cpp_spec.name = "C++"
        cpp_spec.function_syntax = "{return_type} {name}({params}) { {body} }"
        cpp_spec.class_syntax = "class {name} { {access}: {body} };"
        cpp_spec.variable_syntax = "{type} {name} = {value};"
        cpp_spec.if_syntax = "if ({condition}) { {body} }"
        cpp_spec.for_syntax = "for ({init}; {condition}; {increment}) { {body} }"
        cpp_spec.while_syntax = "while ({condition}) { {body} }"
        language_mappings["C++"] = cpp_spec
        
        ; Python specification
        var python_spec = LanguageSpec()
        python_spec.name = "Python"
        python_spec.function_syntax = "def {name}({params}):\n    {body}"
        python_spec.class_syntax = "class {name}:\n    {body}"
        python_spec.variable_syntax = "{name} = {value}"
        python_spec.if_syntax = "if {condition}:\n    {body}"
        python_spec.for_syntax = "for {var} in {range}:\n    {body}"
        python_spec.while_syntax = "while {condition}:\n    {body}"
        language_mappings["Python"] = python_spec
        
        ; JavaScript specification
        var js_spec = LanguageSpec()
        js_spec.name = "JavaScript"
        js_spec.function_syntax = "function {name}({params}) { {body} }"
        js_spec.class_syntax = "class {name} { {body} }"
        js_spec.variable_syntax = "let {name} = {value};"
        js_spec.if_syntax = "if ({condition}) { {body} }"
        js_spec.for_syntax = "for (let {var} = {start}; {var} < {end}; {var}++) { {body} }"
        js_spec.while_syntax = "while ({condition}) { {body} }"
        language_mappings["JavaScript"] = js_spec
        
        println(" Loaded " + language_mappings.size() + " language specifications")
    }
}

; NLP Processing Engine
class NLPProcessor {
    var intent_patterns: Array<IntentPattern>
    var entity_extractors: Map<string, EntityExtractor>
    
    function init() {
        loadIntentPatterns()
        setupEntityExtractors()
    }
    
    function parseIntent(input: string) -> Intent {
        var normalized = normalizeInput(input)
        var intent = Intent()
        intent.confidence = 0
        
        for pattern in intent_patterns {
            var match_score = pattern.match(normalized)
            if (match_score > intent.confidence) {
                intent.type = pattern.intent_type
                intent.confidence = match_score
                intent.parameters = pattern.extractParameters(normalized)
            }
        }
        
        return intent
    }
    
    function loadIntentPatterns() {
        intent_patterns = [
            IntentPattern("CREATE_FUNCTION", [
                "create function *",
                "make function *", 
                "function *",
                "def *",
                "define function *"
            ]),
            IntentPattern("CREATE_CLASS", [
                "create class *",
                "make class *",
                "class *", 
                "define class *"
            ]),
            IntentPattern("CREATE_LOOP", [
                "for loop *",
                "while loop *",
                "loop *",
                "iterate *"
            ]),
            IntentPattern("CREATE_CONDITION", [
                "if *",
                "check if *",
                "when *",
                "condition *"
            ]),
            IntentPattern("CREATE_VARIABLE", [
                "variable *",
                "var *",
                "create variable *",
                "declare *"
            ]),
            IntentPattern("FILE_OPERATION", [
                "read file *",
                "write file *",
                "open file *",
                "save file *"
            ]),
            IntentPattern("NETWORK_REQUEST", [
                "http request *",
                "api call *",
                "fetch *",
                "get data from *"
            ]),
            IntentPattern("DATABASE_QUERY", [
                "select from *",
                "query *",
                "database *",
                "sql *"
            ])
        ]
    }
}

; Code Generation Dialog
class CodeGenerationDialog {
    var dialog: Dialog
    var input_field: TextEdit
    var language_combo: ComboBox
    var preview_area: CodeEditor
    var generate_button: Button
    var insert_button: Button
    var code_generator: IntelligentCodeGenerator*
    var last_result: CodeGenerationResult
    
    function init(generator: IntelligentCodeGenerator*) {
        code_generator = generator
        createDialog()
        setupEventHandlers()
    }
    
    function createDialog() {
        dialog = Dialog()
        dialog.setTitle("Intelligent Code Generator")
        dialog.setSize(800, 600)
        dialog.setModal(true)
        
        var layout = VerticalLayout()
        
        ; Header
        var header_label = Label("Describe what you want to create in natural language:")
        header_label.setStyleSheet("font-weight: bold; font-size: 14px; color: #0078D4;")
        layout.addWidget(header_label)
        
        ; Input area
        var input_layout = HorizontalLayout()
        
        input_field = TextEdit()
        input_field.setPlaceholderText("e.g., 'Create a function called calculate_sum that takes two numbers and returns their sum'")
        input_field.setMaximumHeight(100)
        input_layout.addWidget(input_field, 1)
        
        language_combo = ComboBox()
        language_combo.addItems(["EON", "C++", "Python", "JavaScript", "C", "Rust", "Go"])
        language_combo.setCurrentText("EON")
        language_combo.setMaximumWidth(120)
        input_layout.addWidget(language_combo, 0)
        
        generate_button = Button("Generate Code")
        generate_button.setIcon("system-run")
        generate_button.onClick = onGenerateCode
        input_layout.addWidget(generate_button, 0)
        
        layout.addLayout(input_layout)
        
        ; Preview area
        var preview_label = Label("Generated Code Preview:")
        preview_label.setStyleSheet("font-weight: bold; margin-top: 10px;")
        layout.addWidget(preview_label)
        
        preview_area = CodeEditor()
        preview_area.setReadOnly(true)
        preview_area.setLineNumbersVisible(true)
        preview_area.setSyntaxHighlightingEnabled(true)
        layout.addWidget(preview_area, 1)
        
        ; Buttons
        var button_layout = HorizontalLayout()
        
        var examples_button = Button("Examples")
        examples_button.onClick = showExamples
        button_layout.addWidget(examples_button)
        
        button_layout.addStretch()
        
        insert_button = Button("Insert Code")
        insert_button.setIcon("edit-paste")
        insert_button.setEnabled(false)
        insert_button.onClick = onInsertCode
        button_layout.addWidget(insert_button)
        
        var close_button = Button("Close")
        close_button.onClick = onClose
        button_layout.addWidget(close_button)
        
        layout.addLayout(button_layout)
        
        dialog.setLayout(layout)
    }
    
    function onGenerateCode() {
        var user_input = input_field.getText().trim()
        if (user_input.length == 0) {
            showError("Please enter a description of what you want to create.")
            return
        }
        
        var target_language = language_combo.getCurrentText()
        var context = CodeContext()  ; Get from current editor
        
        generate_button.setEnabled(false)
        generate_button.setText("Generating...")
        
        ; Generate code in background thread
        var generation_thread = Thread(() -> {
            last_result = code_generator.generateCodeFromInput(user_input, target_language, context)
            
            ; Update UI on main thread
            runOnMainThread(() -> {
                generate_button.setEnabled(true)
                generate_button.setText("Generate Code")
                
                if (last_result.success) {
                    preview_area.setLanguage(target_language.toLowerCase())
                    preview_area.setText(last_result.generated_code)
                    insert_button.setEnabled(true)
                    
                    showSuccess("Code generated successfully using template: " + last_result.template_used)
                    
                    ; Show suggestions if any
                    if (last_result.suggestions.length > 0) {
                        showSuggestions(last_result.suggestions)
                    }
                } else {
                    preview_area.setText("// Error: " + last_result.error + "\n// Try rephrasing your request or check the examples.")
                    insert_button.setEnabled(false)
                    showError(last_result.error)
                }
            })
        })
        
        generation_thread.start()
    }
    
    function showExamples() {
        var examples_dialog = Dialog()
        examples_dialog.setTitle(" Code Generation Examples")
        examples_dialog.setSize(700, 500)
        
        var layout = VerticalLayout()
        
        var examples_text = TextEdit()
        examples_text.setReadOnly(true)
        examples_text.setHtml(generateExamplesHTML())
        
        layout.addWidget(examples_text)
        
        var close_btn = Button("Close")
        close_btn.onClick = () -> examples_dialog.close()
        layout.addWidget(close_btn)
        
        examples_dialog.setLayout(layout)
        examples_dialog.exec()
    }
    
    function generateExamplesHTML() -> string {
        return """
        <h3>Natural Language Code Generation Examples</h3>
        
        <h4> Functions</h4>
        <ul>
            <li><b>"Create a function called add_numbers that takes two integers and returns their sum"</b></li>
            <li><b>"Make a function to calculate fibonacci numbers"</b></li>
            <li><b>"Function that sorts an array of strings"</b></li>
        </ul>
        
        <h4> Classes</h4>
        <ul>
            <li><b>"Create a class called Person with name and age properties"</b></li>
            <li><b>"Make a class for managing a shopping cart"</b></li>
            <li><b>"Class that represents a binary tree"</b></li>
        </ul>
        
        <h4> Loops</h4>
        <ul>
            <li><b>"For loop from 1 to 10"</b></li>
            <li><b>"While loop that continues until user enters quit"</b></li>
            <li><b>"Loop through each item in the array"</b></li>
        </ul>
        
        <h4> Conditions</h4>
        <ul>
            <li><b>"If the number is greater than 10 then print success"</b></li>
            <li><b>"Check if the file exists before opening it"</b></li>
            <li><b>"When the user clicks the button, show a message"</b></li>
        </ul>
        
        <h4> File Operations</h4>
        <ul>
            <li><b>"Read the contents of data.txt"</b></li>
            <li><b>"Write the results to output.csv"</b></li>
            <li><b>"Open config.json and parse it"</b></li>
        </ul>
        
        <h4> Network Requests</h4>
        <ul>
            <li><b>"HTTP GET request to api.example.com"</b></li>
            <li><b>"Post data to the login endpoint"</b></li>
            <li><b>"Fetch user data from the REST API"</b></li>
        </ul>
        """
    }
    
    function show() {
        dialog.show()
        input_field.setFocus()
    }
}

