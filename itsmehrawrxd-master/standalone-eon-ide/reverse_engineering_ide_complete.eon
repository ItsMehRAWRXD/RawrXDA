; === PROCESS INTEGRITY & CRC LOGGING SYSTEM ===

; Process Integrity Monitor - Logs CRCs, hashes, and checksums
class ProcessIntegrityMonitor {
    var active_processes: Map<uint32, ProcessIntegrityData>
    var logging_enabled: bool
    var log_file_path: string
    var hash_algorithms: Array<HashAlgorithm>
    var crc_variants: Array<CRCVariant>
    var integrity_logger: IntegrityLogger
    
    function init() {
        println("Initializing Process Integrity Monitor...")
        
        active_processes = Map<uint32, ProcessIntegrityData>()
        logging_enabled = true
        log_file_path = "./integrity_logs/"
        
        ; Initialize hash algorithms
        hash_algorithms = [
            HashAlgorithm.MD5,
            HashAlgorithm.SHA1,  
            HashAlgorithm.SHA256,
            HashAlgorithm.SHA512,
            HashAlgorithm.CRC32,
            HashAlgorithm.CRC64,
            HashAlgorithm.BLAKE2B,
            HashAlgorithm.XXHASH64
        ]
        
        ; Initialize CRC variants
        crc_variants = [
            CRCVariant.CRC32_IEEE,    ; Standard CRC32
            CRCVariant.CRC32_CASTAGNOLI,  ; CRC32C
            CRCVariant.CRC32_KOOPMAN,
            CRCVariant.CRC16_CCITT,
            CRCVariant.CRC64_ISO,
            CRCVariant.CRC64_ECMA
        ]
        
        integrity_logger = IntegrityLogger()
        integrity_logger.init(log_file_path)
        
        createDirectory(log_file_path)
        println("Process Integrity Monitor ready")
    }
    
    function startMonitoring(process_id: uint32, process_name: string) -> ProcessIntegrityData {
        println("Starting integrity monitoring for: " + process_name + " (PID: " + process_id.toString() + ")")
        
        var integrity_data = ProcessIntegrityData()
        integrity_data.process_id = process_id
        integrity_data.process_name = process_name
        integrity_data.start_time = getCurrentTime()
        integrity_data.base_address = getProcessBaseAddress(process_id)
        integrity_data.image_size = getProcessImageSize(process_id)
        
        ; Calculate initial integrity hashes
        calculateInitialHashes(integrity_data)
        
        ; Start periodic monitoring
        integrity_data.monitor_timer = Timer(5000, monitorProcessIntegrity, integrity_data)  ; Every 5 seconds
        integrity_data.monitor_timer.start()
        
        active_processes[process_id] = integrity_data
        
        ; Log initial state
        logIntegrityEvent(integrity_data, "PROCESS_MONITORING_STARTED", "Initial integrity baseline established")
        
        return integrity_data
    }
    
    function calculateInitialHashes(data: ProcessIntegrityData*) {
        println(" Calculating baseline integrity hashes...")
        
        ; Read process memory regions
        var memory_regions = enumerateProcessMemoryRegions(data.process_id)
        data.memory_regions = memory_regions
        
        for region in memory_regions {
            if (region.protection.isExecutable()) {
                var region_data = readProcessMemory(data.process_id, region.base_address, region.size)
                
                ; Calculate all hash types for executable regions
                var region_hashes = RegionHashes()
                region_hashes.base_address = region.base_address
                region_hashes.size = region.size
                region_hashes.protection = region.protection
                
                ; Calculate MD5
                region_hashes.md5 = calculateMD5(region_data)
                
                ; Calculate SHA variants
                region_hashes.sha1 = calculateSHA1(region_data)
                region_hashes.sha256 = calculateSHA256(region_data)
                region_hashes.sha512 = calculateSHA512(region_data)
                
                ; Calculate CRC variants
                region_hashes.crc32_ieee = calculateCRC32IEEE(region_data)
                region_hashes.crc32c = calculateCRC32Castagnoli(region_data)
                region_hashes.crc64_iso = calculateCRC64ISO(region_data)
                
                ; Calculate modern hashes
                region_hashes.blake2b = calculateBLAKE2B(region_data)
                region_hashes.xxhash64 = calculateXXHash64(region_data)
                
                ; Calculate import table hash (if applicable)
                if (region.contains_import_table) {
                    var import_data = extractImportTableData(data.process_id, region.base_address)
                    region_hashes.import_table_hash = calculateSHA256(import_data)
                }
                
                data.baseline_hashes.add(region_hashes)
                
                ; Log hash calculation
                logHashCalculation(data, region_hashes)
            }
        }
        
        ; Calculate PE header hash (Windows)
        if (isWindowsProcess(data.process_id)) {
            var pe_header = readPEHeader(data.process_id, data.base_address)
            data.pe_header_hash = calculateSHA256(pe_header)
            
            ; Extract and hash PE sections
            var pe_sections = parsePESections(pe_header)
            for section in pe_sections {
                var section_data = readProcessMemory(data.process_id, 
                                                   data.base_address + section.virtual_address, 
                                                   section.virtual_size)
                var section_hash = SectionHash()
                section_hash.section_name = section.name
                section_hash.virtual_address = section.virtual_address
                section_hash.sha256 = calculateSHA256(section_data)
                section_hash.crc32 = calculateCRC32IEEE(section_data)
                
                data.section_hashes.add(section_hash)
            }
        }
        
        println("Baseline integrity hashes calculated: " + data.baseline_hashes.length.toString() + " regions")
    }
    
    function monitorProcessIntegrity(data: ProcessIntegrityData*) {
        if (!isProcessRunning(data.process_id)) {
            logIntegrityEvent(data, "PROCESS_TERMINATED", "Process no longer running")
            stopMonitoring(data.process_id)
            return
        }
        
        ; Re-read and compare hashes
        var changes_detected = false
        var change_log = Array<IntegrityChange>()
        
        for i in 0 to data.baseline_hashes.length {
            var baseline = data.baseline_hashes[i]
            
            ; Re-read memory region
            var current_data = readProcessMemory(data.process_id, baseline.base_address, baseline.size)
            
            ; Calculate current hashes
            var current_md5 = calculateMD5(current_data)
            var current_sha256 = calculateSHA256(current_data)
            var current_crc32 = calculateCRC32IEEE(current_data)
            
            ; Compare with baseline
            if (current_md5 != baseline.md5 || 
                current_sha256 != baseline.sha256 ||
                current_crc32 != baseline.crc32_ieee) {
                
                changes_detected = true
                
                var change = IntegrityChange()
                change.region_address = baseline.base_address
                change.region_size = baseline.size
                change.change_type = IntegrityChangeType.MEMORY_MODIFICATION
                change.old_md5 = baseline.md5
                change.new_md5 = current_md5
                change.old_sha256 = baseline.sha256
                change.new_sha256 = current_sha256
                change.old_crc32 = baseline.crc32_ieee
                change.new_crc32 = current_crc32
                change.timestamp = getCurrentTime()
                
                change_log.add(change)
                
                ; Update baseline with new hashes
                baseline.md5 = current_md5
                baseline.sha256 = current_sha256
                baseline.crc32_ieee = current_crc32
            }
        }
        
        ; Log any detected changes
        if (changes_detected) {
            logIntegrityChanges(data, change_log)
        }
    }
    
    function logHashCalculation(data: ProcessIntegrityData*, hashes: RegionHashes) {
        var log_entry = IntegrityLogEntry()
        log_entry.timestamp = getCurrentTime()
        log_entry.process_id = data.process_id
        log_entry.process_name = data.process_name
        log_entry.event_type = "HASH_CALCULATION"
        log_entry.region_address = hashes.base_address
        log_entry.region_size = hashes.size
        
        ; Build detailed hash information
        var hash_details = StringBuilder()
        hash_details.appendLine("Region: 0x" + hashes.base_address.toHex() + " - 0x" + (hashes.base_address + hashes.size).toHex())
        hash_details.appendLine("Size: " + hashes.size.toString() + " bytes")
        hash_details.appendLine("Protection: " + hashes.protection.toString())
        hash_details.appendLine("")
        hash_details.appendLine("Hash Values:")
        hash_details.appendLine("  MD5:        " + hashes.md5)
        hash_details.appendLine("  SHA1:       " + hashes.sha1) 
        hash_details.appendLine("  SHA256:     " + hashes.sha256)
        hash_details.appendLine("  SHA512:     " + hashes.sha512)
        hash_details.appendLine("  CRC32:      " + hashes.crc32_ieee)
        hash_details.appendLine("  CRC32C:     " + hashes.crc32c)
        hash_details.appendLine("  CRC64:      " + hashes.crc64_iso)
        hash_details.appendLine("  BLAKE2B:    " + hashes.blake2b)
        hash_details.appendLine("  XXHash64:   " + hashes.xxhash64)
        
        if (hashes.import_table_hash.length > 0) {
            hash_details.appendLine("  ImportTbl:  " + hashes.import_table_hash)
        }
        
        log_entry.details = hash_details.toString()
        
        integrity_logger.writeEntry(log_entry)
    }
    
    function generateIntegrityReport(process_id: uint32) -> IntegrityReport {
        var data = active_processes[process_id]
        if (!data) {
            throw Exception("Process not being monitored: " + process_id.toString())
        }
        
        var report = IntegrityReport()
        report.process_name = data.process_name
        report.process_id = process_id
        report.monitoring_duration = getCurrentTime() - data.start_time
        report.total_regions_monitored = data.baseline_hashes.length
        report.total_changes_detected = data.integrity_changes.length
        
        ; Generate comprehensive hash summary
        var hash_summary = StringBuilder()
        hash_summary.appendLine("=== PROCESS INTEGRITY REPORT ===")
        hash_summary.appendLine("Process: " + data.process_name + " (PID: " + process_id.toString() + ")")
        hash_summary.appendLine("Base Address: 0x" + data.base_address.toHex())
        hash_summary.appendLine("Image Size: " + data.image_size.toString() + " bytes")
        hash_summary.appendLine("Monitoring Started: " + data.start_time.toString())
        hash_summary.appendLine("Report Generated: " + getCurrentTime().toString())
        hash_summary.appendLine("")
        
        ; PE Header information (Windows)
        if (data.pe_header_hash.length > 0) {
            hash_summary.appendLine("PE Header SHA256: " + data.pe_header_hash)
            hash_summary.appendLine("")
            
            hash_summary.appendLine("PE Sections:")
            for section in data.section_hashes {
                hash_summary.appendLine("  " + section.section_name + ":")
                hash_summary.appendLine("    Virtual Address: 0x" + section.virtual_address.toHex())
                hash_summary.appendLine("    SHA256: " + section.sha256)
                hash_summary.appendLine("    CRC32:  " + section.crc32)
            }
            hash_summary.appendLine("")
        }
        
        ; Memory regions hash table
        hash_summary.appendLine("Memory Regions Hash Table:")
        hash_summary.appendLine("Address Range               | Size     | MD5                              | SHA256                                                           | CRC32")
        hash_summary.appendLine("---------------------------|----------|----------------------------------|------------------------------------------------------------------|----------")
        
        for region_hash in data.baseline_hashes {
            var addr_range = "0x" + region_hash.base_address.toHex() + "-0x" + (region_hash.base_address + region_hash.size).toHex()
            var size_str = formatBytes(region_hash.size)
            
            hash_summary.appendLine(addr_range.padRight(26) + " | " + 
                                  size_str.padRight(8) + " | " +
                                  region_hash.md5 + " | " +
                                  region_hash.sha256 + " | " +
                                  region_hash.crc32_ieee)
        }
        
        hash_summary.appendLine("")
        
        ; Changes detected
        if (data.integrity_changes.length > 0) {
            hash_summary.appendLine("INTEGRITY CHANGES DETECTED:")
            for change in data.integrity_changes {
                hash_summary.appendLine("  [" + change.timestamp.toString() + "] Region 0x" + change.region_address.toHex())
                hash_summary.appendLine("    Old MD5:  " + change.old_md5)
                hash_summary.appendLine("    New MD5:  " + change.new_md5)
                hash_summary.appendLine("    Old SHA256: " + change.old_sha256)
                hash_summary.appendLine("    New SHA256: " + change.new_sha256)
                hash_summary.appendLine("    Change Type: " + change.change_type.toString())
                hash_summary.appendLine("")
            }
        } else {
            hash_summary.appendLine("NO INTEGRITY VIOLATIONS DETECTED")
        }
        
        report.full_report = hash_summary.toString()
        return report
    }
    
    function exportIntegrityData(process_id: uint32, format: ExportFormat) -> string {
        var data = active_processes[process_id]
        var report = generateIntegrityReport(process_id)
        
        match format {
            case ExportFormat.JSON: {
                return exportAsJSON(report, data)
            }
            case ExportFormat.XML: {
                return exportAsXML(report, data)
            }
            case ExportFormat.CSV: {
                return exportAsCSV(report, data)
            }
            case ExportFormat.YARA: {
                return generateYARARule(report, data)
            }
            default: {
                return report.full_report
            }
        }
    }
    
    function generateYARARule(report: IntegrityReport, data: ProcessIntegrityData*) -> string {
        var yara = StringBuilder()
        
        yara.appendLine("rule " + data.process_name.replace(".", "_") + "_Integrity_" + data.process_id.toString())
        yara.appendLine("{")
        yara.appendLine("    meta:")
        yara.appendLine("        description = \"Generated integrity rule for " + data.process_name + "\"")
        yara.appendLine("        author = \"RawrZ Process Integrity Monitor\"")
        yara.appendLine("        date = \"" + getCurrentTime().toDateString() + "\"")
        yara.appendLine("        process_id = \"" + data.process_id.toString() + "\"")
        yara.appendLine("        base_address = \"0x" + data.base_address.toHex() + "\"")
        yara.appendLine("")
        yara.appendLine("    strings:")
        
        ; Add hash-based strings for each region
        var string_count = 1
        for region in data.baseline_hashes {
            yara.appendLine("        $hash" + string_count.toString() + " = { " + region.md5.replace("", " ") + " } // MD5 of region at 0x" + region.base_address.toHex())
            string_count++
        }
        
        yara.appendLine("")
        yara.appendLine("    condition:")
        yara.appendLine("        any of ($hash*)")
        yara.appendLine("}")
        
        return yara.toString()
    }
}

; Enhanced Header Generator with CRC/Hash Integration
class EnhancedHeaderGenerator extends NativeHeaderGenerator {
    var integrity_monitor: ProcessIntegrityMonitor*
    
    function init(monitor: ProcessIntegrityMonitor*) {
        super.init()
        integrity_monitor = monitor
    }
    
    function generateHeadersWithIntegrity(analysis: BinaryAnalysis, process_id: uint32) -> NativeHeaderGen {
        println("Generating headers with integrity data...")
        
        ; Generate standard headers
        var headers = super.generateHeaders(analysis)
        
        ; Get integrity data
        var integrity_data = integrity_monitor.active_processes[process_id]
        if (integrity_data) {
            ; Add integrity information to headers
            headers.c_header += generateCIntegritySection(integrity_data)
            headers.python_ctypes += generatePythonIntegritySection(integrity_data)
            headers.rust_definitions += generateRustIntegritySection(integrity_data)
            
            ; Create integrity report
            var integrity_report = integrity_monitor.generateIntegrityReport(process_id)
            headers.integrity_report = integrity_report.full_report
            
            ; Generate YARA rule
            headers.yara_rule = integrity_monitor.exportIntegrityData(process_id, ExportFormat.YARA)
        }
        
        return headers
    }
    
    function generateCIntegritySection(data: ProcessIntegrityData*) -> string {
        var section = StringBuilder()
        
        section.appendLine("")
        section.appendLine("/* === PROCESS INTEGRITY DATA === */")
        section.appendLine("")
        section.appendLine("/* Process Information */")
        section.appendLine("#define PROCESS_NAME \"" + data.process_name + "\"")
        section.appendLine("#define PROCESS_ID " + data.process_id.toString())
        section.appendLine("#define BASE_ADDRESS 0x" + data.base_address.toHex() + "ULL")
        section.appendLine("#define IMAGE_SIZE " + data.image_size.toString() + "ULL")
        section.appendLine("")
        
        section.appendLine("/* PE Header Hash */")
        if (data.pe_header_hash.length > 0) {
            section.appendLine("#define PE_HEADER_SHA256 \"" + data.pe_header_hash + "\"")
        }
        section.appendLine("")
        
        section.appendLine("/* Region Integrity Hashes */")
        section.appendLine("typedef struct {")
        section.appendLine("    uint64_t base_address;")
        section.appendLine("    uint64_t size;") 
        section.appendLine("    char md5[33];")
        section.appendLine("    char sha256[65];")
        section.appendLine("    uint32_t crc32;")
        section.appendLine("    uint64_t crc64;")
        section.appendLine("} region_integrity_t;")
        section.appendLine("")
        
        section.appendLine("static const region_integrity_t REGION_HASHES[] = {")
        for region in data.baseline_hashes {
            section.appendLine("    {")
            section.appendLine("        .base_address = 0x" + region.base_address.toHex() + "ULL,")
            section.appendLine("        .size = " + region.size.toString() + "ULL,")
            section.appendLine("        .md5 = \"" + region.md5 + "\",")
            section.appendLine("        .sha256 = \"" + region.sha256 + "\",")
            section.appendLine("        .crc32 = 0x" + region.crc32_ieee.toHex() + "U,")
            section.appendLine("        .crc64 = 0x" + region.crc64_iso.toHex() + "ULL")
            section.appendLine("    },")
        }
        section.appendLine("};")
        section.appendLine("")
        
        section.appendLine("#define REGION_COUNT " + data.baseline_hashes.length.toString())
        
        return section.toString()
    }
}

; Data Structures
struct ProcessIntegrityData {
    var process_id: uint32
    var process_name: string
    var start_time: DateTime
    var base_address: uint64
    var image_size: uint64
    var pe_header_hash: string
    var baseline_hashes: Array<RegionHashes>
    var section_hashes: Array<SectionHash>
    var integrity_changes: Array<IntegrityChange>
    var memory_regions: Array<MemoryRegion>
    var monitor_timer: Timer
}

struct RegionHashes {
    var base_address: uint64
    var size: uint64
    var protection: MemoryProtection
    var md5: string
    var sha1: string
    var sha256: string
    var sha512: string
    var crc32_ieee: string
    var crc32c: string
    var crc64_iso: string
    var blake2b: string
    var xxhash64: string
    var import_table_hash: string
}

struct IntegrityChange {
    var region_address: uint64
    var region_size: uint64
    var change_type: IntegrityChangeType
    var old_md5: string
    var new_md5: string
    var old_sha256: string
    var new_sha256: string
    var old_crc32: string
    var new_crc32: string
    var timestamp: DateTime
}

struct IntegrityReport {
    var process_name: string
    var process_id: uint32
    var monitoring_duration: TimeSpan
    var total_regions_monitored: uint32
    var total_changes_detected: uint32
    var full_report: string
}

; === DIRECTX/OPENGL CRC & HASH LOGGING SYSTEM ===

; Graphics API Integrity Monitor - Specialized for DirectX/OpenGL processes
class GraphicsAPIIntegrityMonitor {
    var directx_monitor: DirectXIntegrityMonitor
    var opengl_monitor: OpenGLIntegrityMonitor
    var graphics_processes: Map<uint32, GraphicsProcessData>
    var shader_cache: Map<string, ShaderIntegrityData>
    var texture_cache: Map<uint32, TextureIntegrityData>
    var api_call_logger: APICallLogger
    
    function init() {
        println("Initializing Graphics API Integrity Monitor...")
        
        directx_monitor = DirectXIntegrityMonitor()
        opengl_monitor = OpenGLIntegrityMonitor()
        graphics_processes = Map<uint32, GraphicsProcessData>()
        shader_cache = Map<string, ShaderIntegrityData>()
        texture_cache = Map<uint32, TextureIntegrityData>()
        api_call_logger = APICallLogger()
        
        directx_monitor.init()
        opengl_monitor.init()
        api_call_logger.init("./graphics_api_logs/")
        
        println("Graphics API Integrity Monitor ready")
    }
    
    function startGraphicsMonitoring(process_id: uint32, process_name: string, api_type: GraphicsAPI) {
        println("Starting graphics integrity monitoring for: " + process_name + " (PID: " + process_id.toString() + ")")
        
        var graphics_data = GraphicsProcessData()
        graphics_data.process_id = process_id
        graphics_data.process_name = process_name
        graphics_data.api_type = api_type
        graphics_data.start_time = getCurrentTime()
        graphics_data.frame_count = 0
        graphics_data.draw_calls_logged = 0
        graphics_data.shaders_analyzed = 0
        graphics_data.textures_analyzed = 0
        
        match api_type {
            case GraphicsAPI.DIRECTX11, GraphicsAPI.DIRECTX12: {
                directx_monitor.attachToProcess(process_id, graphics_data)
            }
            case GraphicsAPI.OPENGL, GraphicsAPI.OPENGL_ES: {
                opengl_monitor.attachToProcess(process_id, graphics_data)
            }
            case GraphicsAPI.VULKAN: {
                ; Future implementation
            }
        }
        
        graphics_processes[process_id] = graphics_data
        
        api_call_logger.logEvent("GRAPHICS_MONITORING_STARTED", process_name, process_id, 
                                "Started " + api_type.toString() + " integrity monitoring")
    }
    
    function generateGraphicsIntegrityReport(process_id: uint32) -> GraphicsIntegrityReport {
        var graphics_data = graphics_processes[process_id]
        if (!graphics_data) {
            throw Exception("Graphics process not being monitored: " + process_id.toString())
        }
        
        var report = GraphicsIntegrityReport()
        report.process_name = graphics_data.process_name
        report.process_id = process_id
        report.api_type = graphics_data.api_type
        report.monitoring_duration = getCurrentTime() - graphics_data.start_time
        report.total_frames_analyzed = graphics_data.frame_count
        report.total_draw_calls = graphics_data.draw_calls_logged
        report.shaders_analyzed = graphics_data.shaders_analyzed
        report.textures_analyzed = graphics_data.textures_analyzed
        
        ; Generate comprehensive graphics report
        var report_text = StringBuilder()
        report_text.appendLine("=== GRAPHICS API INTEGRITY REPORT ===")
        report_text.appendLine("Process: " + graphics_data.process_name + " (PID: " + process_id.toString() + ")")
        report_text.appendLine("Graphics API: " + graphics_data.api_type.toString())
        report_text.appendLine("Monitoring Duration: " + report.monitoring_duration.toString())
        report_text.appendLine("Frames Analyzed: " + report.total_frames_analyzed.toString())
        report_text.appendLine("Draw Calls Logged: " + report.total_draw_calls.toString())
        report_text.appendLine("")
        
        ; Add shader integrity data
        report_text.appendLine("=== SHADER INTEGRITY DATA ===")
        for shader_hash in shader_cache.keys() {
            var shader_data = shader_cache[shader_hash]
            report_text.appendLine("Shader: " + shader_data.shader_name)
            report_text.appendLine("  Type: " + shader_data.shader_type.toString())
            report_text.appendLine("  Size: " + shader_data.bytecode_size.toString() + " bytes")
            report_text.appendLine("  MD5: " + shader_data.md5_hash)
            report_text.appendLine("  SHA256: " + shader_data.sha256_hash)
            report_text.appendLine("  CRC32: " + shader_data.crc32_hash)
            report_text.appendLine("  First Seen: " + shader_data.first_seen.toString())
            report_text.appendLine("  Usage Count: " + shader_data.usage_count.toString())
            report_text.appendLine("")
        }
        
        ; Add texture integrity data
        report_text.appendLine("=== TEXTURE INTEGRITY DATA ===")
        for texture_id in texture_cache.keys() {
            var texture_data = texture_cache[texture_id]
            report_text.appendLine("Texture ID: " + texture_id.toString())
            report_text.appendLine("  Format: " + texture_data.format.toString())
            report_text.appendLine("  Dimensions: " + texture_data.width.toString() + "x" + texture_data.height.toString())
            report_text.appendLine("  Mip Levels: " + texture_data.mip_levels.toString())
            report_text.appendLine("  Data Size: " + texture_data.data_size.toString() + " bytes")
            report_text.appendLine("  MD5: " + texture_data.md5_hash)
            report_text.appendLine("  CRC32: " + texture_data.crc32_hash)
            report_text.appendLine("  First Loaded: " + texture_data.first_loaded.toString())
            report_text.appendLine("")
        }
        
        ; Add API call statistics
        match graphics_data.api_type {
            case GraphicsAPI.DIRECTX11, GraphicsAPI.DIRECTX12: {
                report_text.append(directx_monitor.generateAPICallReport(graphics_data))
            }
            case GraphicsAPI.OPENGL: {
                report_text.append(opengl_monitor.generateAPICallReport(graphics_data))
            }
        }
        
        report.full_report = report_text.toString()
        return report
    }
}

; DirectX-Specific Integrity Monitor
class DirectXIntegrityMonitor {
    var d3d11_hooks: D3D11HookManager
    var d3d12_hooks: D3D12HookManager
    var dxgi_hooks: DXGIHookManager
    var shader_compiler_hooks: ShaderCompilerHooks
    
    function init() {
        println(" Initializing DirectX Integrity Monitor...")
        
        d3d11_hooks = D3D11HookManager()
        d3d12_hooks = D3D12HookManager()
        dxgi_hooks = DXGIHookManager()
        shader_compiler_hooks = ShaderCompilerHooks()
        
        setupD3D11Hooks()
        setupD3D12Hooks()
        setupDXGIHooks()
        setupShaderCompilerHooks()
    }
    
    function attachToProcess(process_id: uint32, graphics_data: GraphicsProcessData*) {
        println("Hooking DirectX APIs in process: " + process_id.toString())
        
        ; Inject DLL into target process for API hooking
        var injection_result = injectHookingDLL(process_id, "directx_monitor.dll")
        if (!injection_result.success) {
            throw Exception("Failed to inject DirectX monitoring DLL: " + injection_result.error)
        }
        
        ; Setup communication channel
        var comm_channel = setupIPCChannel(process_id, "directx_integrity_" + process_id.toString())
        graphics_data.communication_channel = comm_channel
        
        ; Start monitoring thread
        var monitor_thread = Thread(directxMonitoringLoop, graphics_data)
        monitor_thread.start()
        
        api_call_logger.logEvent("DIRECTX_HOOKS_INSTALLED", graphics_data.process_name, process_id,
                                "DirectX API hooks successfully installed")
    }
    
    function setupD3D11Hooks() {
        ; Hook D3D11 device creation
        d3d11_hooks.hookFunction("D3D11CreateDevice", onD3D11CreateDevice)
        d3d11_hooks.hookFunction("D3D11CreateDeviceAndSwapChain", onD3D11CreateDeviceAndSwapChain)
        
        ; Hook rendering functions
        d3d11_hooks.hookDeviceMethod("Draw", onD3D11Draw)
        d3d11_hooks.hookDeviceMethod("DrawIndexed", onD3D11DrawIndexed)
        d3d11_hooks.hookDeviceMethod("DrawInstanced", onD3D11DrawInstanced)
        d3d11_hooks.hookDeviceMethod("DrawIndexedInstanced", onD3D11DrawIndexedInstanced)
        
        ; Hook shader operations
        d3d11_hooks.hookDeviceMethod("VSSetShader", onD3D11VSSetShader)
        d3d11_hooks.hookDeviceMethod("PSSetShader", onD3D11PSSetShader)
        d3d11_hooks.hookDeviceMethod("GSSetShader", onD3D11GSSetShader)
        d3d11_hooks.hookDeviceMethod("CSSetShader", onD3D11CSSetShader)
        
        ; Hook texture operations
        d3d11_hooks.hookDeviceMethod("CreateTexture2D", onD3D11CreateTexture2D)
        d3d11_hooks.hookDeviceMethod("PSSetShaderResources", onD3D11PSSetShaderResources)
        
        ; Hook buffer operations
        d3d11_hooks.hookDeviceMethod("CreateBuffer", onD3D11CreateBuffer)
        d3d11_hooks.hookDeviceMethod("UpdateSubresource", onD3D11UpdateSubresource)
    }
    
    function onD3D11CreateTexture2D(device: ID3D11Device*, desc: D3D11_TEXTURE2D_DESC*, initial_data: D3D11_SUBRESOURCE_DATA*, texture: ID3D11Texture2D**) {
        ; Call original function
        var result = originalD3D11CreateTexture2D(device, desc, initial_data, texture)
        
        if (result == S_OK && texture && *texture) {
            ; Calculate texture data integrity
            var texture_data = TextureIntegrityData()
            texture_data.texture_id = cast(uint32, *texture)
            texture_data.format = desc.Format
            texture_data.width = desc.Width
            texture_data.height = desc.Height
            texture_data.mip_levels = desc.MipLevels
            texture_data.first_loaded = getCurrentTime()
            
            if (initial_data) {
                ; Calculate hash of texture data
                var data_size = calculateTextureDataSize(desc)
                texture_data.data_size = data_size
                texture_data.md5_hash = calculateMD5(initial_data.pSysMem, data_size)
                texture_data.crc32_hash = calculateCRC32IEEE(initial_data.pSysMem, data_size)
                texture_data.sha256_hash = calculateSHA256(initial_data.pSysMem, data_size)
                
                ; Store in cache
                texture_cache[texture_data.texture_id] = texture_data
                
                ; Log texture creation
                api_call_logger.logEvent("D3D11_TEXTURE_CREATED", getCurrentProcessName(), getCurrentProcessId(),
                                        "Texture created: " + desc.Width.toString() + "x" + desc.Height.toString() + 
                                        " Format=" + desc.Format.toString() + " MD5=" + texture_data.md5_hash)
            }
        }
        
        return result
    }
    
    function onD3D11VSSetShader(context: ID3D11DeviceContext*, shader: ID3D11VertexShader*, class_instances: ID3D11ClassInstance**, num_instances: uint32) {
        ; Call original function
        originalD3D11VSSetShader(context, shader, class_instances, num_instances)
        
        if (shader) {
            ; Get shader bytecode and calculate integrity
            var bytecode = getShaderBytecode(shader)
            if (bytecode.size > 0) {
                analyzeShaderIntegrity(shader, bytecode, ShaderType.VERTEX_SHADER)
            }
        }
    }
    
    function analyzeShaderIntegrity(shader: void*, bytecode: Array<uint8>, shader_type: ShaderType) {
        ; Calculate shader hashes
        var md5_hash = calculateMD5(bytecode.data, bytecode.size)
        var sha256_hash = calculateSHA256(bytecode.data, bytecode.size)
        var crc32_hash = calculateCRC32IEEE(bytecode.data, bytecode.size)
        
        ; Check if we've seen this shader before
        var shader_key = sha256_hash  ; Use SHA256 as unique identifier
        
        if (shader_cache.containsKey(shader_key)) {
            ; Update usage count
            shader_cache[shader_key].usage_count++
        } else {
            ; New shader - create integrity data
            var shader_data = ShaderIntegrityData()
            shader_data.shader_name = "Shader_" + shader_key.substring(0, 8)
            shader_data.shader_type = shader_type
            shader_data.bytecode_size = bytecode.size
            shader_data.md5_hash = md5_hash
            shader_data.sha256_hash = sha256_hash
            shader_data.crc32_hash = crc32_hash
            shader_data.first_seen = getCurrentTime()
            shader_data.usage_count = 1
            
            ; Disassemble shader for analysis
            shader_data.disassembly = disassembleShaderBytecode(bytecode, shader_type)
            
            ; Extract shader constants/uniforms
            shader_data.constants = extractShaderConstants(bytecode)
            
            shader_cache[shader_key] = shader_data
            
            ; Log new shader discovery
            api_call_logger.logEvent("SHADER_DISCOVERED", getCurrentProcessName(), getCurrentProcessId(),
                                    "New " + shader_type.toString() + " shader: Size=" + bytecode.size.toString() + 
                                    " MD5=" + md5_hash + " CRC32=" + crc32_hash)
        }
    }
    
    function generateAPICallReport(graphics_data: GraphicsProcessData*) -> string {
        var report = StringBuilder()
        
        report.appendLine("=== DIRECTX API CALL STATISTICS ===")
        report.appendLine("Draw Calls: " + graphics_data.draw_calls_logged.toString())
        report.appendLine("Shader Bindings: " + graphics_data.shader_bindings.toString())
        report.appendLine("Texture Bindings: " + graphics_data.texture_bindings.toString())
        report.appendLine("Buffer Updates: " + graphics_data.buffer_updates.toString())
        report.appendLine("")
        
        report.appendLine("Device Creation Events:")
        for event in graphics_data.device_events {
            report.appendLine("  [" + event.timestamp.toString() + "] " + event.event_type + ": " + event.details)
        }
        report.appendLine("")
        
        return report.toString()
    }
}

; OpenGL-Specific Integrity Monitor  
class OpenGLIntegrityMonitor {
    var gl_hooks: OpenGLHookManager
    var shader_program_cache: Map<uint32, GLProgramIntegrityData>
    
    function init() {
        println(" Initializing OpenGL Integrity Monitor...")
        
        gl_hooks = OpenGLHookManager()
        shader_program_cache = Map<uint32, GLProgramIntegrityData>()
        
        setupOpenGLHooks()
    }
    
    function setupOpenGLHooks() {
        ; Hook OpenGL rendering functions
        gl_hooks.hookFunction("glDrawArrays", onGLDrawArrays)
        gl_hooks.hookFunction("glDrawElements", onGLDrawElements)
        gl_hooks.hookFunction("glDrawArraysInstanced", onGLDrawArraysInstanced)
        gl_hooks.hookFunction("glDrawElementsInstanced", onGLDrawElementsInstanced)
        
        ; Hook shader functions
        gl_hooks.hookFunction("glCreateProgram", onGLCreateProgram)
        gl_hooks.hookFunction("glLinkProgram", onGLLinkProgram)
        gl_hooks.hookFunction("glUseProgram", onGLUseProgram)
        gl_hooks.hookFunction("glCompileShader", onGLCompileShader)
        
        ; Hook texture functions
        gl_hooks.hookFunction("glTexImage2D", onGLTexImage2D)
        gl_hooks.hookFunction("glTexSubImage2D", onGLTexSubImage2D)
        gl_hooks.hookFunction("glBindTexture", onGLBindTexture)
        
        ; Hook buffer functions
        gl_hooks.hookFunction("glBufferData", onGLBufferData)
        gl_hooks.hookFunction("glBufferSubData", onGLBufferSubData)
    }
    
    function onGLTexImage2D(target: GLenum, level: GLint, internal_format: GLint, width: GLsizei, height: GLsizei, 
                           border: GLint, format: GLenum, type: GLenum, data: void*) {
        ; Call original function
        originalGLTexImage2D(target, level, internal_format, width, height, border, format, type, data)
        
        if (data) {
            ; Calculate texture data integrity
            var data_size = calculateGLTextureDataSize(width, height, format, type)
            var texture_data = TextureIntegrityData()
            texture_data.texture_id = getCurrentBoundTexture(target)
            texture_data.format = format
            texture_data.width = width
            texture_data.height = height
            texture_data.mip_levels = level + 1
            texture_data.data_size = data_size
            texture_data.first_loaded = getCurrentTime()
            
            ; Calculate hashes
            texture_data.md5_hash = calculateMD5(data, data_size)
            texture_data.crc32_hash = calculateCRC32IEEE(data, data_size)
            texture_data.sha256_hash = calculateSHA256(data, data_size)
            
            texture_cache[texture_data.texture_id] = texture_data
            
            ; Log texture loading
            api_call_logger.logEvent("GL_TEXTURE_LOADED", getCurrentProcessName(), getCurrentProcessId(),
                                    "Texture loaded: " + width.toString() + "x" + height.toString() + 
                                    " Format=0x" + format.toHex() + " MD5=" + texture_data.md5_hash)
        }
    }
    
    function onGLLinkProgram(program: GLuint) {
        ; Call original function
        originalGLLinkProgram(program)
        
        ; Check if program linked successfully
        var link_status = getGLProgramLinkStatus(program)
        if (link_status) {
            ; Analyze the complete shader program
            var program_data = GLProgramIntegrityData()
            program_data.program_id = program
            program_data.link_time = getCurrentTime()
            
            ; Get all attached shaders
            var attached_shaders = getAttachedShaders(program)
            for shader_id in attached_shaders {
                var shader_source = getShaderSource(shader_id)
                var shader_type = getShaderType(shader_id)
                
                ; Calculate shader source integrity
                var shader_info = ShaderIntegrityData()
                shader_info.shader_name = "GLShader_" + shader_id.toString()
                shader_info.shader_type = mapGLShaderType(shader_type)
                shader_info.source_code = shader_source
                shader_info.bytecode_size = shader_source.length
                shader_info.md5_hash = calculateMD5(shader_source.data, shader_source.length)
                shader_info.sha256_hash = calculateSHA256(shader_source.data, shader_source.length)
                shader_info.crc32_hash = calculateCRC32IEEE(shader_source.data, shader_source.length)
                shader_info.first_seen = getCurrentTime()
                shader_info.usage_count = 1
                
                program_data.shaders.add(shader_info)
                
                ; Store in global shader cache
                shader_cache[shader_info.sha256_hash] = shader_info
            }
            
            ; Get program uniforms
            program_data.uniforms = getProgramUniforms(program)
            
            ; Get program attributes
            program_data.attributes = getProgramAttributes(program)
            
            shader_program_cache[program] = program_data
            
            ; Log program linking
            api_call_logger.logEvent("GL_PROGRAM_LINKED", getCurrentProcessName(), getCurrentProcessId(),
                                    "Program linked: ID=" + program.toString() + 
                                    " Shaders=" + attached_shaders.length.toString())
        }
    }
    
    function generateAPICallReport(graphics_data: GraphicsProcessData*) -> string {
        var report = StringBuilder()
        
        report.appendLine("=== OPENGL API CALL STATISTICS ===")
        report.appendLine("Draw Calls: " + graphics_data.draw_calls_logged.toString())
        report.appendLine("Shader Programs: " + shader_program_cache.size().toString())
        report.appendLine("Texture Bindings: " + graphics_data.texture_bindings.toString())
        report.appendLine("Buffer Operations: " + graphics_data.buffer_operations.toString())
        report.appendLine("")
        
        report.appendLine("Shader Programs:")
        for program_id in shader_program_cache.keys() {
            var program_data = shader_program_cache[program_id]
            report.appendLine("  Program " + program_id.toString() + ":")
            report.appendLine("    Linked: " + program_data.link_time.toString())
            report.appendLine("    Shaders: " + program_data.shaders.length.toString())
            report.appendLine("    Uniforms: " + program_data.uniforms.length.toString())
            report.appendLine("    Attributes: " + program_data.attributes.length.toString())
        }
        report.appendLine("")
        
        return report.toString()
    }
}

; Enhanced Header Generator for Graphics APIs
class GraphicsAPIHeaderGenerator extends EnhancedHeaderGenerator {
    var graphics_monitor: GraphicsAPIIntegrityMonitor*
    
    function init(monitor: GraphicsAPIIntegrityMonitor*) {
        graphics_monitor = monitor
        super.init(monitor.integrity_monitor)
    }
    
    function generateGraphicsHeaders(analysis: BinaryAnalysis, process_id: uint32) -> GraphicsHeaderPackage {
        println("Generating graphics API headers with integrity data...")
        
        var graphics_data = graphics_monitor.graphics_processes[process_id]
        var package = GraphicsHeaderPackage()
        
        match graphics_data.api_type {
            case GraphicsAPI.DIRECTX11, GraphicsAPI.DIRECTX12: {
                package.directx_wrapper = generateDirectXWrapper(graphics_data)
                package.directx_shaders = generateDirectXShaderHeaders(graphics_data)
            }
            case GraphicsAPI.OPENGL: {
                package.opengl_wrapper = generateOpenGLWrapper(graphics_data)  
                package.opengl_shaders = generateOpenGLShaderHeaders(graphics_data)
            }
        }
        
        ; Generate integrity report
        var integrity_report = graphics_monitor.generateGraphicsIntegrityReport(process_id)
        package.integrity_report = integrity_report.full_report
        
        ; Generate texture catalog
        package.texture_catalog = generateTextureCatalog()
        
        ; Generate YARA rules for graphics assets
        package.yara_rules = generateGraphicsYARARule(graphics_data)
        
        return package
    }
    
    function generateTextureCatalog() -> string {
        var catalog = StringBuilder()
        
        catalog.appendLine("/* === TEXTURE INTEGRITY CATALOG === */")
        catalog.appendLine("")
        
        for texture_id in texture_cache.keys() {
            var texture_data = texture_cache[texture_id]
            
            catalog.appendLine("/* Texture ID: " + texture_id.toString() + " */")
            catalog.appendLine("#define TEXTURE_" + texture_id.toString() + "_WIDTH " + texture_data.width.toString())
            catalog.appendLine("#define TEXTURE_" + texture_id.toString() + "_HEIGHT " + texture_data.height.toString())
            catalog.appendLine("#define TEXTURE_" + texture_id.toString() + "_FORMAT " + texture_data.format.toString())
            catalog.appendLine("#define TEXTURE_" + texture_id.toString() + "_MD5 \"" + texture_data.md5_hash + "\"")
            catalog.appendLine("#define TEXTURE_" + texture_id.toString() + "_CRC32 0x" + texture_data.crc32_hash + "U")
            catalog.appendLine("")
        }
        
        return catalog.toString()
    }
}

; Data Structures
struct GraphicsProcessData {
    var process_id: uint32
