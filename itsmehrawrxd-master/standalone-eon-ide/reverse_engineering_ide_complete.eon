        ; Edit operations
        registerShortcut("Ctrl+Z", edit_menu.onUndo)
        registerShortcut("Ctrl+Y", edit_menu.onRedo)
        registerShortcut("Ctrl+C", edit_menu.onCopy)
        registerShortcut("Ctrl+V", edit_menu.onPaste)
        registerShortcut("Ctrl+F", edit_menu.onFind)
        registerShortcut("Ctrl+H", edit_menu.onReplace)
        
        ; View operations
        registerShortcut("F11", view_menu.onToggleFullscreen)
        registerShortcut("Ctrl+1", view_menu.onShowDisassembly)
        registerShortcut("Ctrl+2", view_menu.onShowHexView)
        registerShortcut("Ctrl+3", view_menu.onShowDecompiler)
        registerShortcut("Ctrl+4", view_menu.onShowDebugPanels)
        
        ; Analysis operations
        registerShortcut("F5", analysis_menu.onAnalyzeFile)
        registerShortcut("Shift+F5", analysis_menu.onAnalyzeFunction)
        registerShortcut("Ctrl+F5", analysis_menu.onFullAnalysis)
        
        ; Debug operations
        registerShortcut("F9", debug_menu.onToggleBreakpoint)
        registerShortcut("F10", debug_menu.onStepOver)
        registerShortcut("F11", debug_menu.onStepInto)
        registerShortcut("Shift+F11", debug_menu.onStepOut)
        registerShortcut("F5", debug_menu.onContinue)
        registerShortcut("Shift+F5", debug_menu.onStop)
        registerShortcut("Ctrl+Alt+P", debug_menu.onAttachProcess)
        
        ; Tools operations
        registerShortcut("F12", tools_menu.onOpenScriptConsole)
        registerShortcut("Ctrl+Shift+P", tools_menu.onPluginManager)
    }
}

; File Menu - File operations and project management
class FileMenu {
    var menu_bar: MenuBarSystem*
    var menu: Menu
    
    function init(parent_menu_bar: MenuBarSystem*) {
        menu_bar = parent_menu_bar
        createMenu()
    }
    
    function createMenu() {
        menu = Menu("File")
        
        ; File operations
        menu.addAction("&Open Binary...", onOpenFile, "Ctrl+O", "folder-open")
        menu.addAction("Open &Project...", onOpenProject, "", "folder-open")
        menu.addSeparator()
        
        ; Recent files submenu
        var recent_menu = menu.addSubMenu("&Recent Files", "document-recent")
        updateRecentFilesMenu(recent_menu)
        
        menu.addSeparator()
        
        ; Save operations
        menu.addAction("&Save Project", onSaveProject, "Ctrl+S", "document-save")
        menu.addAction("Save Project &As...", onSaveAsProject, "Ctrl+Shift+S", "document-save-as")
        menu.addSeparator()
        
        ; Import/Export
        var import_menu = menu.addSubMenu("&Import", "document-import")
        import_menu.addAction("IDA Pro Database (.idb)", onImportIDA, "", "")
        import_menu.addAction("Ghidra Project (.gpr)", onImportGhidra, "", "")
        import_menu.addAction("Binary Ninja Database (.bndb)", onImportBinaryNinja, "", "")
        import_menu.addAction("Radare2 Project (.r2)", onImportRadare2, "", "")
        import_menu.addAction("x64dbg Database (.dd64)", onImportx64dbg, "", "")
        
        var export_menu = menu.addSubMenu("&Export", "document-export")
        export_menu.addAction("C/C++ Headers", onExportHeaders, "", "")
        export_menu.addAction("Disassembly Report", onExportDisassembly, "", "")
        export_menu.addAction("Analysis Report", onExportAnalysis, "", "")
        export_menu.addAction("YARA Rules", onExportYARA, "", "")
        export_menu.addAction("IOCs (Indicators)", onExportIOCs, "", "")
        
        menu.addSeparator()
        
        ; Exit
        menu.addAction("E&xit", onExit, "Ctrl+Q", "application-exit")
    }
    
    function onOpenFile() {
        var file_dialog = FileDialog()
        file_dialog.setTitle("Open Binary File")
        file_dialog.setFilters([
            "Executable Files (*.exe *.dll *.sys)",
            "ELF Files (*.so *.elf)",
            "Mach-O Files (*.dylib *.app)",
            "All Files (*.*)"
        ])
        
        var file_path = file_dialog.getOpenFileName()
        if (file_path.length > 0) {
            menu_bar.ide_instance.handleOpenFile(file_path)
            addToRecentFiles(file_path)
        }
    }
    
    function onOpenProject() {
        var project_dialog = FileDialog()
        project_dialog.setTitle("Open RawrZ Project")
        project_dialog.setFilters(["RawrZ Projects (*.rzp)", "All Files (*.*)"])
        
        var project_path = project_dialog.getOpenFileName()
        if (project_path.length > 0) {
            menu_bar.ide_instance.openProject(project_path)
            addToRecentFiles(project_path)
        }
    }
    
    function onSaveProject() {
        if (menu_bar.ide_instance.current_project_path.length > 0) {
            menu_bar.ide_instance.saveProject(menu_bar.ide_instance.current_project_path)
        } else {
            onSaveAsProject()
        }
    }
    
    function onSaveAsProject() {
        var save_dialog = FileDialog()
        save_dialog.setTitle("Save RawrZ Project As")
        save_dialog.setFilters(["RawrZ Projects (*.rzp)"])
        
        var project_path = save_dialog.getSaveFileName()
        if (project_path.length > 0) {
            menu_bar.ide_instance.saveProject(project_path)
            menu_bar.ide_instance.current_project_path = project_path
        }
    }
}

; Edit Menu - Editing operations
class EditMenu {
    var menu_bar: MenuBarSystem*
    var menu: Menu
    
    function init(parent_menu_bar: MenuBarSystem*) {
        menu_bar = parent_menu_bar
        createMenu()
    }
    
    function createMenu() {
        menu = Menu("Edit")
        
        ; Undo/Redo
        menu.addAction("&Undo", onUndo, "Ctrl+Z", "edit-undo")
        menu.addAction("&Redo", onRedo, "Ctrl+Y", "edit-redo")
        menu.addSeparator()
        
        ; Clipboard operations
        menu.addAction("Cu&t", onCut, "Ctrl+X", "edit-cut")
        menu.addAction("&Copy", onCopy, "Ctrl+C", "edit-copy")
        menu.addAction("&Paste", onPaste, "Ctrl+V", "edit-paste")
        menu.addAction("&Delete", onDelete, "Delete", "edit-delete")
        menu.addSeparator()
        
        ; Selection
        menu.addAction("Select &All", onSelectAll, "Ctrl+A", "edit-select-all")
        menu.addSeparator()
        
        ; Search operations
        menu.addAction("&Find...", onFind, "Ctrl+F", "edit-find")
        menu.addAction("Find &Next", onFindNext, "F3", "go-next")
        menu.addAction("Find &Previous", onFindPrevious, "Shift+F3", "go-previous")
        menu.addAction("&Replace...", onReplace, "Ctrl+H", "edit-find-replace")
        menu.addSeparator()
        
        ; Navigation
        menu.addAction("&Go to Address...", onGotoAddress, "Ctrl+G", "go-jump")
        menu.addAction("Go to &Function...", onGotoFunction, "Ctrl+Shift+G", "go-jump")
        menu.addAction("&Back", onNavigateBack, "Alt+Left", "go-previous")
        menu.addAction("&Forward", onNavigateForward, "Alt+Right", "go-next")
        menu.addSeparator()
        
        ; Comments and annotations
        menu.addAction("Add &Comment...", onAddComment, "Semicolon", "accessories-text-editor")
        menu.addAction("&Rename Function...", onRenameFunction, "N", "edit-rename")
        menu.addAction("Set Function &Signature...", onSetSignature, "", "accessories-text-editor")
    }
    
    function onFind() {
        var find_dialog = FindDialog()
        find_dialog.setSearchScope(["Current View", "All Functions", "Entire Binary"])
        find_dialog.setSearchTypes(["Text", "Hex Pattern", "Assembly Instruction"])
        find_dialog.show()
    }
    
    function onGotoAddress() {
        var goto_dialog = GotoAddressDialog()
        goto_dialog.show()
        
        if (goto_dialog.wasAccepted()) {
            var address = goto_dialog.getAddress()
            menu_bar.ide_instance.navigateToAddress(address)
        }
    }
    
    function onAddComment() {
        var current_address = menu_bar.ide_instance.getCurrentAddress()
        var comment_dialog = CommentDialog()
        comment_dialog.setAddress(current_address)
        comment_dialog.show()
        
        if (comment_dialog.wasAccepted()) {
            var comment = comment_dialog.getComment()
            menu_bar.ide_instance.program_database.addUserComment(current_address, comment, getCurrentUser())
        }
    }
}

; View Menu - UI layout and display options
class ViewMenu {
    var menu_bar: MenuBarSystem*
    var menu: Menu
    
    function init(parent_menu_bar: MenuBarSystem*) {
        menu_bar = parent_menu_bar
        createMenu()
    }
    
    function createMenu() {
        menu = Menu("View")
        
        ; Main panels
        var panels_menu = menu.addSubMenu("&Panels", "view-split")
        panels_menu.addCheckableAction("&Disassembly", onToggleDisassembly, "Ctrl+1", true)
        panels_menu.addCheckableAction("&Hex View", onToggleHexView, "Ctrl+2", true)
        panels_menu.addCheckableAction("D&ecompiler", onToggleDecompiler, "Ctrl+3", true)
        panels_menu.addCheckableAction("&Functions List", onToggleFunctionsList, "", true)
        panels_menu.addCheckableAction("&Strings", onToggleStrings, "", true)
        panels_menu.addCheckableAction("&Imports/Exports", onToggleImportsExports, "", true)
        
        ; Debug panels
        var debug_panels_menu = menu.addSubMenu("&Debug Panels", "applications-debugging")
        debug_panels_menu.addCheckableAction("&Registers", onToggleRegisters, "", true)
        debug_panels_menu.addCheckableAction("&Memory View", onToggleMemoryView, "", true)
        debug_panels_menu.addCheckableAction("&Stack", onToggleStack, "", true)
        debug_panels_menu.addCheckableAction("&Breakpoints", onToggleBreakpoints, "", true)
        debug_panels_menu.addCheckableAction("&Threads", onToggleThreads, "", true)
        debug_panels_menu.addCheckableAction("Debug &Console", onToggleDebugConsole, "", true)
        
        menu.addSeparator()
        
        ; Layout options
        var layout_menu = menu.addSubMenu("&Layout", "view-restore")
        layout_menu.addAction("&Default Layout", onDefaultLayout, "", "view-restore")
        layout_menu.addAction("&Analysis Layout", onAnalysisLayout, "", "applications-science")
        layout_menu.addAction("&Debug Layout", onDebugLayout, "", "applications-debugging")
        layout_menu.addAction("&Minimal Layout", onMinimalLayout, "", "view-fullscreen")
        layout_menu.addSeparator()
        layout_menu.addAction("&Save Current Layout...", onSaveLayout, "", "document-save")
        layout_menu.addAction("&Load Custom Layout...", onLoadLayout, "", "document-open")
        layout_menu.addSeparator()
        layout_menu.addAction("&Save Layout...", onSaveLayout, "", "")
        layout_menu.addAction("&Load Layout...", onLoadLayout, "", "")
        
        menu.addSeparator()
        
        ; Display options
        var display_menu = menu.addSubMenu("&Display", "preferences-desktop-display")
        display_menu.addCheckableAction("Show &Addresses", onToggleAddresses, "", true)
        display_menu.addCheckableAction("Show &Opcodes", onToggleOpcodes, "", true)
        display_menu.addCheckableAction("Show &Line Numbers", onToggleLineNumbers, "", false)
        display_menu.addCheckableAction("Show &Comments", onToggleComments, "", true)
        display_menu.addSeparator()
        display_menu.addCheckableAction("Show &Cross References", onToggleXrefs, "", true)
        display_menu.addCheckableAction("Show &Function Boundaries", onToggleFunctionBounds, "", false)
        display_menu.addCheckableAction("Show &Data References", onToggleDataRefs, "", true)
        display_menu.addCheckableAction("&Color Code Instructions", onToggleColorCoding, "", true)
        
        ; Advanced visualization
        var visualization_menu = menu.addSubMenu("&Visualization", "applications-graphics")
        visualization_menu.addAction("&Call Graph", onShowCallGraph, "", "network-wireless")
        visualization_menu.addAction("&Control Flow Graph", onShowCFG, "", "preferences-system-network")
        visualization_menu.addAction("&Import/Export Graph", onShowImportExportGraph, "", "applications-internet")
        visualization_menu.addAction("&Memory Map", onShowMemoryMap, "", "applications-system")
        visualization_menu.addAction("&Entropy Analysis", onShowEntropyAnalysis, "", "utilities-system-monitor")
        
        ; Zoom options
        menu.addSeparator()
        menu.addAction("Zoom &In", onZoomIn, "Ctrl+Plus", "zoom-in")
        menu.addAction("Zoom &Out", onZoomOut, "Ctrl+Minus", "zoom-out")
        menu.addAction("&Reset Zoom", onResetZoom, "Ctrl+0", "zoom-original")
        
        menu.addSeparator()
        
        ; Themes
        var theme_menu = menu.addSubMenu("&Theme", "preferences-desktop-theme")
        theme_menu.addRadioAction("&Light Theme", onLightTheme, "", false)
        theme_menu.addRadioAction("&Dark Theme", onDarkTheme, "", true)
        theme_menu.addRadioAction("&High Contrast", onHighContrastTheme, "", false)
        theme_menu.addRadioAction("&Custom Theme...", onCustomTheme, "", false)
        
        menu.addSeparator()
        
        ; Fullscreen
        menu.addAction("&Full Screen", onToggleFullscreen, "F11", "view-fullscreen")
    }
    
    function onToggleDisassembly() {
        menu_bar.ide_instance.togglePanel("disassembly")
    }
    
    function onToggleDecompiler() {
        menu_bar.ide_instance.togglePanel("decompiler")
    }
    
    function onDefaultLayout() {
        menu_bar.ide_instance.applyLayout("default")
    }
    
    function onDebugLayout() {
        menu_bar.ide_instance.applyLayout("debug")
    }
    
    function onSaveLayout() {
        var layout_dialog = SaveLayoutDialog()
        layout_dialog.setTitle("Save Current Layout")
        
        if (layout_dialog.exec() == DialogResult.Accepted) {
            var layout_name = layout_dialog.getLayoutName()
            menu_bar.ide_instance.saveCustomLayout(layout_name)
            println("Layout '" + layout_name + "' saved successfully!")
        }
    }
    
    function onLoadLayout() {
        var layout_dialog = LoadLayoutDialog()
        layout_dialog.setLayouts(menu_bar.ide_instance.getCustomLayouts())
        
        if (layout_dialog.exec() == DialogResult.Accepted) {
            var layout_name = layout_dialog.getSelectedLayout()
            menu_bar.ide_instance.applyLayout(layout_name)
        }
    }
    
    function onToggleXrefs() {
        menu_bar.ide_instance.toggleDisplayOption("show_xrefs")
    }
    
    function onToggleFunctionBounds() {
        menu_bar.ide_instance.toggleDisplayOption("show_function_bounds")
    }
    
    function onToggleDataRefs() {
        menu_bar.ide_instance.toggleDisplayOption("show_data_refs")
    }
    
    function onToggleColorCoding() {
        menu_bar.ide_instance.toggleDisplayOption("color_code_instructions")
    }
    
    function onShowCallGraph() {
        var call_graph_window = CallGraphWindow()
        call_graph_window.setTitle("Call Graph - " + menu_bar.ide_instance.getCurrentFileName())
        call_graph_window.generateGraph(menu_bar.ide_instance.binary_analysis)
        call_graph_window.show()
    }
    
    function onShowCFG() {
        var current_function = menu_bar.ide_instance.getCurrentFunction()
        if (current_function != null) {
            var cfg_window = ControlFlowGraphWindow()
            cfg_window.setTitle("CFG - " + current_function.name)
            cfg_window.generateCFG(current_function)
            cfg_window.show()
        }
    }
    
    function onShowImportExportGraph() {
        var ie_graph_window = ImportExportGraphWindow()
        ie_graph_window.setTitle("Import/Export Graph - " + menu_bar.ide_instance.getCurrentFileName())
        ie_graph_window.generateGraph(menu_bar.ide_instance.binary_analysis)
        ie_graph_window.show()
    }
    
    function onShowMemoryMap() {
        var memory_map_window = MemoryMapWindow()
        memory_map_window.setTitle("Memory Map - " + menu_bar.ide_instance.getCurrentFileName())
        memory_map_window.generateMap(menu_bar.ide_instance.binary_analysis)
        memory_map_window.show()
    }
    
    function onShowEntropyAnalysis() {
        var entropy_window = EntropyAnalysisWindow()
        entropy_window.setTitle("Entropy Analysis - " + menu_bar.ide_instance.getCurrentFileName())
        entropy_window.performAnalysis(menu_bar.ide_instance.binary_analysis)
        entropy_window.show()
    }
}

; Analysis Menu - Analysis and reverse engineering operations
class AnalysisMenu {
    var menu_bar: MenuBarSystem*
    var menu: Menu
    
    function init(parent_menu_bar: MenuBarSystem*) {
        menu_bar = parent_menu_bar
        createMenu()
    }
    
    function createMenu() {
        menu = Menu("Analysis")
        
        ; Main analysis operations
        menu.addAction("&Analyze Binary", onAnalyzeFile, "F5", "system-run")
        menu.addAction("Analyze &Function", onAnalyzeFunction, "Shift+F5", "")
        menu.addAction("&Full Analysis", onFullAnalysis, "Ctrl+F5", "")
        menu.addSeparator()
        
        ; Specific analysis types
        var functions_menu = menu.addSubMenu("&Functions", "code-function")
        functions_menu.addAction("&Create Function", onCreateFunction, "", "")
        functions_menu.addAction("&Delete Function", onDeleteFunction, "", "")
        functions_menu.addAction("&Reanalyze Function", onReanalyzeFunction, "", "")
        functions_menu.addAction("Find &Library Functions", onFindLibraryFunctions, "", "")
        
        var strings_menu = menu.addSubMenu("&Strings", "format-text")
        strings_menu.addAction("&Find All Strings", onFindStrings, "", "")
        strings_menu.addAction("Find &Unicode Strings", onFindUnicodeStrings, "", "")
        strings_menu.addAction("Analyze String &Usage", onAnalyzeStringUsage, "", "")
        
        var crypto_menu = menu.addSubMenu("&Cryptography", "applications-encryption")
        crypto_menu.addAction("Find &Crypto Functions", onFindCryptoFunctions, "", "")
        crypto_menu.addAction("Find Crypto &Constants", onFindCryptoConstants, "", "")
        crypto_menu.addAction("Analyze &Algorithms", onAnalyzeCryptoAlgorithms, "", "")
        
        menu.addSeparator()
        
        ; Advanced analysis
        var advanced_menu = menu.addSubMenu("A&dvanced", "preferences-system")
        advanced_menu.addAction("&Data Flow Analysis", onDataFlowAnalysis, "", "")
        advanced_menu.addAction("&Control Flow Analysis", onControlFlowAnalysis, "", "")
        advanced_menu.addAction("&Vulnerability Scan", onVulnerabilityScan, "", "")
        advanced_menu.addAction("&Malware Detection", onMalwareDetection, "", "")
        advanced_menu.addAction("&Obfuscation Analysis", onObfuscationAnalysis, "", "")
        
        menu.addSeparator()
        
        ; Decompilation
        menu.addAction("&Decompile Function", onDecompileFunction, "", "code-context")
        menu.addAction("Decompile &All Functions", onDecompileAll, "", "")
        
        menu.addSeparator()
        
        ; Cross-references
        menu.addAction("Find &References To", onFindReferencesTo, "", "")
        menu.addAction("Find References &From", onFindReferencesFrom, "", "")
        menu.addAction("&Update Cross References", onUpdateXRefs, "", "")
    }
    
    function onAnalyzeFile() {
        if (menu_bar.ide_instance.current_analysis) {
            menu_bar.ide_instance.performAdvancedAnalysis()
        } else {
            showError("No binary file loaded for analysis")
        }
    }
    
    function onDecompileFunction() {
        var current_address = menu_bar.ide_instance.getCurrentAddress()
        var func = menu_bar.ide_instance.getFunctionAt(current_address)
        
        if (func) {
            var decompiled = menu_bar.ide_instance.decompiler_engine.decompileFunction(func, menu_bar.ide_instance.current_analysis.architecture)
            menu_bar.ide_instance.showDecompiledFunction(decompiled)
        } else {
            showError("No function found at current address")
        }
    }
}

