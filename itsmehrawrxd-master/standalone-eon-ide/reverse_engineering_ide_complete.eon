    function onAttachProcess() {
        var process_dialog = ProcessSelectionDialog()
        process_dialog.show()
        
        if (process_dialog.wasAccepted()) {
            var pid = process_dialog.getSelectedPID()
            menu_bar.ide_instance.debugger.attachToProcess(pid)
        }
    }
    
    function onToggleBreakpoint() {
        var current_address = menu_bar.ide_instance.getCurrentAddress()
        menu_bar.ide_instance.debug_panel_manager.breakpoint_panel.toggleBreakpoint(current_address)
    }
}

