{
  "dotnet": {
    "version": "9.0",
    "sdkPath": "%USERPROFILE%\\.dotnet",
    "runtimes": ["Microsoft.NETCore.App", "Microsoft.WindowsDesktop.App"],
    "targetFrameworks": ["net9.0", "net9.0-windows"],
    "buildConfiguration": "Debug",
    "optional": true
