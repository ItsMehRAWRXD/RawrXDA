#pragma once

/**
 * @file enhanced_loader_config.h.in
 * @brief CMake-generated configuration for enhanced streaming GGUF loader
 */

// Feature flags (configured by CMake)
#define ENABLE_PREDICTIVE_CACHE @ENABLE_PREDICTIVE_CACHE@
#define ENABLE_NVME_DIRECT_IO @ENABLE_NVME_DIRECT_IO@
#define ENABLE_IORING_BATCH @ENABLE_IORING_BATCH@
#define ENABLE_HUGE_PAGES @ENABLE_HUGE_PAGES@
#define ENABLE_TENSOR_PARALLEL @ENABLE_TENSOR_PARALLEL@
#define ENABLE_ADAPTIVE_COMPRESSION @ENABLE_ADAPTIVE_COMPRESSION@
#define ENABLE_AVX512 @ENABLE_AVX512@

// Platform detection
#ifdef _WIN32
    #define PLATFORM_WINDOWS 1
    #define HAVE_IORING 1
    #define HAVE_NVME 1
#else
    #define PLATFORM_WINDOWS 0
#endif

// Performance constants
#define PREDICTIVE_CACHE_SIZE 256
#define ACCESS_HISTORY_DEPTH 16
#define PREFETCH_WINDOW 8
#define HUGE_PAGE_SIZE 2097152
#define TENSOR_PARALLEL_MAX 8

// Logging
#define ENHANCED_LOADER_DEBUG @CMAKE_BUILD_TYPE@ == "Debug"
