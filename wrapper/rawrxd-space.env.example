# RawrXD bootable space — copy to rawrxd-space.env and adjust.
# RAWRXD_SPACE_ROOT  — Wine prefix root (default: ~/.rawrxd-space or macOS App Support)
# RAWRXD_IDE_EXE    — Path to RawrXD-Win32IDE.exe (optional)
# RAWRXD_IDE_URL    — URL to zip of Windows IDE (optional)
# WINE              — Path to wine (optional)
# RAWRXD_USE_DOCKER — Set to 1 to use Docker instead of host Wine
